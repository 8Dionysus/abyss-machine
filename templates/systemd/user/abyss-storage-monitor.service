[Unit]
Description=Abyss Machine read-only storage monitor
Documentation=file://{{ABYSS_MACHINE_ETC}}/AGENTS.md
Documentation=file://{{ABYSS_MACHINE_STATE}}/storage/AGENTS.md

[Service]
Type=oneshot
Nice=10
IOSchedulingClass=idle
CPUWeight=20
IOWeight=20
TimeoutStartSec=2min
ExecStart={{ABYSS_LOCAL_BIN_DIR}}/abyss-machine storage monitor --json
StandardOutput=null
StandardError=journal
