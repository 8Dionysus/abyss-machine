{
  "schema": "abyss_machine_nervous_index_config_v1",
  "version": "0.8.38",
  "enabled": true,
  "backend": "sqlite_fts5",
  "db_path": "{{ABYSS_MACHINE_SRV}}/storage/nervous/indexes/sqlite/nervous.db",
  "source": {
    "kind": "passive_fact_events_episodes",
    "facts_root": "{{ABYSS_MACHINE_STATE}}/nervous/facts",
    "facts_glob": "{{ABYSS_MACHINE_STATE}}/nervous/facts/YYYY/MM/YYYY-MM-DD.jsonl",
    "latest": "{{ABYSS_MACHINE_STATE}}/nervous/facts/latest.json",
    "events_root": "{{ABYSS_MACHINE_STATE}}/nervous/events",
    "events_glob": "{{ABYSS_MACHINE_STATE}}/nervous/events/YYYY/MM/YYYY-MM-DD.jsonl",
    "events_latest": "{{ABYSS_MACHINE_STATE}}/nervous/events/latest.json",
    "episodes_root": "{{ABYSS_MACHINE_STATE}}/nervous/episodes",
    "episodes_glob": "{{ABYSS_MACHINE_STATE}}/nervous/episodes/YYYY/MM/YYYY-MM-DD.jsonl",
    "episodes_latest": "{{ABYSS_MACHINE_STATE}}/nervous/episodes/latest.json",
    "raw_private_content": false
  },
  "storage": {
    "large_root": "{{ABYSS_MACHINE_SRV}}/storage",
    "index_root": "{{ABYSS_MACHINE_SRV}}/storage/nervous/indexes",
    "compact_state_latest": "{{ABYSS_MACHINE_STATE}}/nervous/indexes/latest.json",
    "schema_path": "{{ABYSS_MACHINE_SRV}}/storage/nervous/indexes/sqlite/schema.sql",
    "no_symlink_tails": true
  },
  "privacy": {
    "enforce_global_pause": true,
    "index_only_existing_fact_snapshots": true,
    "index_only_existing_fact_event_episode_records": true,
    "deferred_sources_allowed": true,
    "redact_before_insert": true,
    "forget_requires_rebuild": true
  },
  "search": {
    "tokenizer": "unicode61",
    "default_limit": 12,
    "max_limit": 50,
    "snippet_tokens": 18,
    "rerank": {
      "source_prior_profile": "host_machine_evidence_v1",
      "weights": {
        "lexical": 0.36,
        "semantic": 0.28,
        "query_overlap": 0.15,
        "recency": 0.07,
        "severity": 0.05,
        "source_prior": 0.09
      },
      "neural": {
        "enabled": true,
        "backend": "openvino_qwen3_reranker",
        "model_dir": "{{ABYSS_MACHINE_SRV}}/cache/ai/qwen3-reranker-0.6b-int8-ov",
        "device": "GPU",
        "cache_dir": "{{ABYSS_MACHINE_SRV}}/cache/ai/openvino/qwen3-reranker-0.6b-int8-ov",
        "scorer": "{{ABYSS_MACHINE_SRV}}/tools/ai/rerankers/qwen3_reranker_openvino_canary.py",
        "max_length": 2048,
        "batch_size": 4,
        "candidate_limit": 24,
        "weight": 0.35,
        "machine_context_weight": 0.0,
        "timeout_sec": 240,
        "resource_class": "medium",
        "instruction": "Given a local machine memory search query, retrieve relevant evidence chunks that answer the query"
      },
      "source_priors": {
        "nervous_events": {
          "default": 1.0,
          "matched": 1.0,
          "tokens": ["event", "events", "episode", "episodes", "thermal", "temperature", "memory", "ram", "swap", "zram", "system", "resource", "machine", "service", "timer", "index", "indexing", "embedding", "rerank", "gemma", "llama", "tts", "dictation", "cpu", "gpu", "podman"],
          "reason": "derived host event evidence is canonical for machine-state queries"
        },
        "nervous_episodes": {
          "default": 1.0,
          "matched": 1.0,
          "tokens": ["event", "events", "episode", "episodes", "thermal", "temperature", "memory", "ram", "swap", "zram", "system", "resource", "machine", "service", "timer", "index", "indexing", "embedding", "rerank", "gemma", "llama", "tts", "dictation", "cpu", "gpu", "podman"],
          "reason": "derived host episode evidence is canonical for machine-state queries"
        },
        "abyss_machine_facts": {
          "default": 1.0,
          "matched": 1.0,
          "tokens": ["thermal", "temperature", "memory", "ram", "swap", "zram", "storage", "resource", "system", "machine", "timer", "service", "index", "indexing", "embedding", "rerank", "gemma", "llama", "tts", "dictation", "cpu", "gpu", "podman"],
          "reason": "first-party host facts outrank contextual desktop noise for machine-state queries"
        },
        "browser_active_tab": {
          "default": 0.2,
          "matched": 0.95,
          "tokens": ["browser", "firefox", "url", "tab", "web", "page", "history"],
          "reason": "browser evidence should rise only for browser-shaped queries"
        },
        "clipboard": {
          "default": 0.15,
          "matched": 0.95,
          "tokens": ["clipboard", "copy", "paste", "buffer"],
          "reason": "clipboard evidence should rise only for clipboard-shaped queries"
        },
        "terminal_stdout_stderr": {
          "default": 0.35,
          "matched": 0.85,
          "tokens": ["terminal", "shell", "command", "stdout", "stderr", "console"],
          "reason": "terminal evidence should rise for command-output queries"
        }
      }
    }
  },
  "automation": {
    "scope": "user",
    "service": "abyss-nervous-index-build.service",
    "timer": "abyss-nervous-index-build.timer",
    "interval": "45min",
    "command": "abyss-machine nervous index-build --json",
    "stdout": "null",
    "priority": "nice+ionice"
  },
  "semantic": {
    "enabled": true,
    "backend": "sqlite_float32_sidecar",
    "db_path": "{{ABYSS_MACHINE_SRV}}/storage/nervous/indexes/semantic/semantic.db",
    "latest": "{{ABYSS_MACHINE_STATE}}/nervous/indexes/semantic/latest.json",
    "automation": {
      "enabled": false,
      "reason": "semantic embeddings are maintained by a resource-gated timer and on-demand command, not a resident embedding service"
    },
    "maintain": {
      "enabled": true,
      "command": "abyss-machine nervous semantic-maintain --json",
      "service": "abyss-nervous-semantic-maintain.service",
      "timer": "abyss-nervous-semantic-maintain.timer",
      "interval": "90min",
      "min_delta_chunks": 128,
      "max_stale_minutes": 90,
      "timeout_sec": 3600,
      "resource_class": "medium",
      "resource_kind": "indexing",
      "unattended": true,
      "success_on_block": true,
      "rule": "Skip tiny fresh drift; launch semantic-build through resource gates when drift or stale age crosses threshold.",
      "embedding_window_chunks": 1024
    },
    "embedding": {
      "batch_size": 32,
      "pooling": "last_token",
      "padding_side": "left"
    }
  },
  "bridge_contract": {
    "consumer": "future abyss-stack bridge",
    "read_commands": [
      "abyss-machine nervous events-latest --json",
      "abyss-machine nervous episodes-latest --json",
      "abyss-machine nervous index-status --json",
      "abyss-machine nervous index-validate --json",
      "abyss-machine nervous semantic-status --json",
      "abyss-machine nervous search --query TEXT --json",
      "abyss-machine nervous search --query TEXT --source nervous_events --json",
      "abyss-machine nervous search --query TEXT --schema abyss_machine_nervous_episode_v1 --json",
      "abyss-machine nervous recall --query TEXT --json",
      "abyss-machine nervous synthesis-latest --json",
      "abyss-machine nervous synthesis-validate --json",
      "abyss-machine nervous eval-latest --json",
      "abyss-machine nervous eval-validate --json",
      "abyss-machine nervous retention-plan --json",
      "abyss-machine nervous retention-validate --json"
    ],
    "write_commands": [
      "abyss-machine nervous events-build --json",
      "abyss-machine nervous episodes-build --json",
      "abyss-machine nervous synthesis-build --scope daily --json",
      "abyss-machine nervous eval-run --json",
      "abyss-machine nervous retention-apply --dry-run --json",
      "abyss-machine nervous index-build --json",
      "abyss-machine nervous index-vacuum --json",
      "abyss-machine nervous semantic-maintain --json"
    ],
    "no_repo_mutation": [
      "{{ABYSS_USER_HOME}}/src/abyss-stack",
      "{{ABYSS_OS_ROOT}}/abyss-stack",
      "/srv/abyss-stack"
    ]
  }
}
