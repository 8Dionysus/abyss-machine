    for path in (ROOT, ROOT / "status", ROOT / "monitor", ROOT / "digests", ROOT / "logs", ROOT / "policy", EVENT_ROOT, MONITOR_ROOT, DIGEST_ROOT, POLICY_ROOT / "jsonl", JOBS_ROOT, MICRO_ROOT, CANDIDATES_ROOT, AUDIT_ROOT, EVALS_ROOT, EVALS_ROOT / "validate", EVALS_ROOT / "fixture-candidates", RESEARCH_ROOT, PROMPT_ROOT):
