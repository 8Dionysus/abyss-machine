        "bounded_hint_generator": 200,
        "risk_sentinel": 180,
        "short_doc_classifier": 220,
    }
    minimums = {
        "intent_candidates": 96,
        "thermal_performance": 120,
        "dictation_quality": 96,
        "daily_work_blocks": 120,
        "command_grammar": 120,
