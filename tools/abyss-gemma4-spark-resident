def compact_text(text: str, limit: int = 520) -> str:
    cleaned = re.sub(r"\s+", " ", str(text or "")).strip()
    if len(cleaned) <= limit:
        return cleaned
    head = max(120, (limit - 24) // 2)
    tail = max(120, limit - head - 18)
    return f"{cleaned[:head].rstrip()} ... {cleaned[-tail:].lstrip()}"


