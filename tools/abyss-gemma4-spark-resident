def temperature_values_from_text(value: Any) -> list[float]:
    text = str(value or "")
    values: list[float] = []
    for match in re.finditer(r"(-?\d+(?:\.\d+)?)\s*(?:°\s*)?[cC]\b", text):
        parsed = float_value(match.group(1))
        if parsed is not None:
            values.append(parsed)
    return values


def local_thermal_severity(temp_c: float | None, thresholds: dict[str, float] | None = None) -> str:
    if temp_c is None:
        return "info"
    thresholds = thresholds or resident_thermal_thresholds()
    if temp_c >= thresholds["critical_c"]:
        return "critical"
    if temp_c >= thresholds["hot_c"]:
        return "warning"
    if temp_c >= thresholds["warm_c"]:
        return "watch"
    return "info"


def severity_rank(value: Any) -> int:
    return {"info": 0, "watch": 1, "warning": 2, "critical": 3}.get(str(value or "info"), 0)


def material_event_titles_by_id(material: dict[str, Any]) -> dict[str, str]:
    events = material.get("nervous_events") if isinstance(material.get("nervous_events"), list) else []
    result: dict[str, str] = {}
    for event in events:
        if not isinstance(event, dict):
            continue
        event_id = str(event.get("event_id") or "")
        if event_id:
            result[event_id] = str(event.get("title") or "")
    return result


def incident_observed_temperature_c(incident: dict[str, Any], material: dict[str, Any]) -> float | None:
    candidates: list[float] = []
    for key in ("summary", "possible_cause", "watch_next"):
        candidates.extend(temperature_values_from_text(incident.get(key)))
    titles = material_event_titles_by_id(material)
    for ref in list_value(incident.get("evidence")):
        candidates.extend(temperature_values_from_text(titles.get(str(ref), "")))
        candidates.extend(temperature_values_from_text(ref))
    if not candidates:
        resident = material.get("resident_status") if isinstance(material.get("resident_status"), dict) else {}
        temp = float_value(resident.get("temp"))
        if temp is not None:
            candidates.append(temp)
    return max(candidates) if candidates else None


def apply_thermal_quality_gate(result: dict[str, Any], material: dict[str, Any]) -> dict[str, Any]:
    thresholds = resident_thermal_thresholds()
    incidents = []
    corrections = 0
    source_label_parroted = False
    for incident in list_value(result.get("incidents")):
        if not isinstance(incident, dict):
            continue
        item = dict(incident)
        observed_temp = incident_observed_temperature_c(item, material)
        local_severity = local_thermal_severity(observed_temp, thresholds)
        original_severity = str(item.get("severity") or "info")
        if observed_temp is not None and severity_rank(original_severity) != severity_rank(local_severity):
            if severity_rank(original_severity) > severity_rank(local_severity):
                corrections += 1
                item["severity_corrected_from"] = original_severity
                item["severity_correction_reason"] = (
                    f"observed_temp_c={observed_temp:.1f} below local critical_c={thresholds['critical_c']:.1f}; "
                    "local abyss-machine thresholds override source labels"
                )
            item["severity"] = local_severity
        text_for_label = " ".join(
            [str(item.get("summary") or ""), str(item.get("possible_cause") or ""), str(item.get("watch_next") or "")]
            + [material_event_titles_by_id(material).get(str(ref), str(ref)) for ref in list_value(item.get("evidence"))]
        ).lower()
        if observed_temp is not None and "critical" in text_for_label and observed_temp < thresholds["critical_c"]:
            source_label_parroted = True
            item["source_parroted_policy_label"] = True
        if observed_temp is not None:
            item["observed_temp_c"] = round(observed_temp, 1)
        incidents.append(item)
    gated = dict(result)
    gated["incidents"] = incidents
    gated["quality_gate"] = {
        "local_thresholds": {
            "warm_c": thresholds["warm_c"],
            "hot_c": thresholds["hot_c"],
            "critical_c": thresholds["critical_c"],
            "hard_emergency_c": thresholds["hard_emergency_c"],
        },
        "source_parroted_policy_label": source_label_parroted,
        "severity_corrections": corrections,
    }
    return gated


def storage_coverage_gate(result: dict[str, Any], material: dict[str, Any]) -> dict[str, Any]:
    storage = material.get("storage") if isinstance(material.get("storage"), dict) else {}
    actions = [item for item in list_value(storage.get("actions")) if isinstance(item, dict) and item.get("id")]
    action_by_id = {str(item.get("id")): item for item in actions}
    existing_items: dict[str, dict[str, Any]] = {}
    for item in list_value(result.get("items")):
        if not isinstance(item, dict):
            continue
        action_id = str(item.get("action_id") or "")
        if action_id in action_by_id and action_id not in existing_items:
            normalized = dict(item)
            normalized["operator_required"] = True
            existing_items[action_id] = normalized

    completed_items: list[dict[str, Any]] = []
    auto_completed: list[str] = []
    for action_id, action in action_by_id.items():
        if action_id in existing_items:
            completed_items.append(existing_items[action_id])
            continue
        auto_completed.append(action_id)
        readiness = str(action.get("readiness") or "unknown")
        reclaimability = str(action.get("reclaimability") or "unknown")
        if "blocked" in readiness:
            klass = "blocked"
        elif reclaimability in {"redownloadable", "temporary", "rebuildable"}:
            klass = "safe_regenerable"
        else:
            klass = "manual_review"
        completed_items.append({
            "action_id": action_id,
            "class": klass,
            "reason": f"auto-completed coverage: readiness={readiness}; reclaimability={reclaimability}; operator review still required",
            "operator_required": True,
        })

    gated = dict(result)
    gated["items"] = completed_items
    gated["coverage"] = {
        "complete": len(auto_completed) == 0,
        "total_actions": len(action_by_id),
        "covered_actions": len(completed_items),
        "auto_completed_missing": auto_completed,
        "omitted_count": max(0, len(action_by_id) - len(completed_items)),
    }
    return gated


def is_placeholder_trigger(value: Any) -> bool:
    text = re.sub(r"\s+", " ", str(value or "")).strip().lower()
    return not text or "..." in text or "…" in text or text in {"команда,", "команда"}


def sanitize_command_grammar_result(result: dict[str, Any]) -> dict[str, Any]:
    rejected = []
    placeholder_rejected = 0
    for item in list_value(result.get("proposed_triggers")):
        if not isinstance(item, dict):
            continue
        trigger = str(item.get("trigger") or "")
        placeholder = is_placeholder_trigger(trigger)
        if placeholder:
            placeholder_rejected += 1
            rejected.append(trigger)
            continue
        rejected.append(trigger)
    sanitized = dict(result)
    sanitized["proposed_triggers"] = []
    sanitized["quality_gate"] = {
        "placeholder_triggers_rejected": placeholder_rejected,
        "proposed_triggers_rejected": len(rejected),
        "rejected_triggers": rejected[:8],
    }
    return sanitized


def daily_brief_quality_gate(result: dict[str, Any], material: dict[str, Any]) -> dict[str, Any]:
    thresholds = resident_thermal_thresholds()
    parts = [str(result.get("summary") or "")]
    for section in list_value(result.get("sections")):
        if isinstance(section, dict):
            parts.append(str(section.get("title") or ""))
            parts.append(str(section.get("text") or ""))
    text = " ".join(parts)
    temps = temperature_values_from_text(text)
    if not temps:
        for title in material_event_titles_by_id(material).values():
            temps.extend(temperature_values_from_text(title))
    observed = max(temps) if temps else None
    parroted = bool(observed is not None and observed < thresholds["critical_c"] and "critical" in text.lower())
    gated = dict(result)
    gated["quality_gate"] = {
        "source_parroted_policy_label": parroted,
        "observed_temp_c": round(observed, 1) if observed is not None else None,
        "local_critical_c": thresholds["critical_c"],
    }
    return gated


