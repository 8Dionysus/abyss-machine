def source_quality_class(record: dict[str, Any]) -> tuple[str, float, list[str]]:
    quality = record.get("quality") if isinstance(record.get("quality"), dict) else {}
    classification = str(quality.get("classification") or "")
    score = float_value(quality.get("score"))
    flags = [str(flag) for flag in list_value(quality.get("flags"))]
    text = source_text(record, 1200)
    age = float_value(record.get("age_sec"))
    if age is not None and age > max(DICTATION_SOURCE_MAX_AGE_SEC, BROWSER_SOURCE_MAX_AGE_SEC):
        return "stale", 0.2, flags + ["age_outside_window"]
    if any(flag in {"browser_internal_url", "media_player_controls"} for flag in flags):
        return "noise", min(score or 0.2, 0.25), flags
    if "password" in text.lower() or "token" in text.lower() or "secret" in text.lower():
        return "sensitive", min(score or 0.4, 0.4), flags + ["secret_like_text"]
    if classification in {"usable", "machine_event"}:
        return "usable", score if score is not None else 0.8, flags
    if classification in {"low_signal", "derived_candidate"}:
        return "low_signal", score if score is not None else 0.55, flags
    if len(text) < 180:
        return "low_signal", 0.35, flags + ["short_text"]
    return "usable", score if score is not None else 0.65, flags


RISK_PATTERNS: list[tuple[str, str, str]] = [
    ("medical", r"\b(doctor|medical|medicine|dose|dosage|surgery|first aid|airway|bleeding|лекар|медицин|дозиров|первая помощь|кровотеч|дыхательн)\b", "curated_source_needed"),
    ("emergency", r"\b(emergency|survival|war|disaster|grid collapse|эвакуац|катастроф|выживан|чрезвычай)\b", "curated_source_needed"),
    ("weapons", r"\b(weapon|gun|firearm|explosive|самооборон|оруж|взрыв|патрон)\b", "blocked_by_policy"),
    ("unsafe_automation", r"\b(delete|rm -rf|wipe|format|kill process|restart service|останови сервис|удали|форматируй|убей процесс)\b", "operator_needed"),
    ("privacy", r"\b(password|token|secret|private key|пароль|токен|секрет|ключ)\b", "operator_needed"),
]


def risk_route_for_text(text: str) -> tuple[str, str, str]:
    low = text.lower()
    for risk, pattern, route in RISK_PATTERNS:
        if re.search(pattern, low, re.IGNORECASE):
            return risk, route, f"matched_{risk}_pattern"
    return "none", "e2b_ok", "no_high_risk_pattern"


def simple_tags(text: str, limit: int = 5) -> list[str]:
    tags: list[str] = []
    for match in re.findall(r"[A-Za-zА-Яа-я][A-Za-zА-Яа-я0-9_.-]{2,}", text):
        tag = match.lower()[:40]
        if tag not in tags and tag not in {"что", "как", "для", "this", "that", "with", "from", "the", "and"}:
            tags.append(tag)
        if len(tags) >= limit:
            break
    return tags


def fallback_extension_result(job: str, records: list[dict[str, Any]], intents: list[dict[str, Any]] | None = None) -> dict[str, Any]:
    intents = intents or []
    if job == "query_expansion":
        queries = []
        for record in records[:2]:
            text = source_text(record, 260)
            tags = simple_tags(text, 3)
            query = " ".join(tags) or text[:120]
            queries.append({"source_id": str(record.get("id")), "query": query[:180], "purpose": "local_recall", "tags": tags, "time_anchor": str(record.get("generated_at") or ""), "confidence": "low"})
        return {"queries": queries, "aliases": [], "fallback_search": queries[0]["query"] if queries else ""}
    if job == "rerank_lite":
        ranked = []
        for rank, record in enumerate(records[:8], start=1):
            klass, score, flags = source_quality_class(record)
            ranked.append({"source_id": str(record.get("id")), "rank": rank, "score": round(score, 3), "reason": f"{klass}; flags={','.join(flags[:3])}"})
        return {"query": "latest local context", "ranked": ranked, "fallback": "bm25_rrf_order_when_model_unavailable"}
    if job == "source_quality_scorer":
        rows = []
        for record in records[:8]:
            klass, score, flags = source_quality_class(record)
            rows.append({"source_id": str(record.get("id")), "classification": klass, "score": round(score, 3), "reason": ",".join(flags[:4]) or "deterministic_quality", "allowed_use": "model_input" if klass in {"usable", "low_signal"} else "review_only"})
        return {"records": rows, "summary": f"scored={len(rows)}"}
    if job == "resident_quality_eval":
        rows = []
        for record in records:
            status = str(record.get("status") or "")
            text = source_text(record, 1000)
            risk = []
            if "raw_excerpt" in text:
                risk.append("raw_excerpt_present")
            if "execute\": true" in text.lower():
                risk.append("action_leakage")
            score = 0.8 if record.get("ok") and status.startswith("ok") else 0.45 if record.get("ok") else 0.2
            rows.append({"job": str(record.get("title")), "score": round(score, 3), "verdict": "pass" if score >= 0.7 and not risk else "degraded", "issues": risk, "next_action": "keep" if score >= 0.7 and not risk else "review"})
        return {"evaluated_jobs": rows, "summary": {"jobs": len(rows), "passes": sum(1 for row in rows if row.get("verdict") == "pass")}}
    if job == "action_card_compiler":
        cards = []
        for item in intents[:6]:
            text = str(item.get("text") or "")
            risk, route, reason = risk_route_for_text(text)
            cards.append({"card_id": stable_id("action-card", item), "source_id": str(item.get("source_id") or item.get("id")), "intent": compact_text(text, 220), "params": [], "risk": risk, "missing_data": ["operator_confirmation"], "confirm_required": True, "route": route, "reason": reason})
        return {"cards": cards, "summary": f"cards={len(cards)}; no automatic execution"}
    if job == "bounded_hint_generator":
        hints = []
        for record in records[:6]:
            hints.append({"source_id": str(record.get("id")), "kind": "review_note", "text": compact_text(source_text(record, 180), 160), "use_for": "human_review"})
        return {"hints": hints, "summary": f"hints={len(hints)}"}
    if job == "risk_sentinel":
        findings = []
        for record in records[:8]:
            risk, route, reason = risk_route_for_text(source_text(record, 900))
            if risk != "none":
                findings.append({"source_id": str(record.get("id")), "risk": risk, "route": route, "reason": reason})
        return {"findings": findings, "summary": f"risk_findings={len(findings)}"}
    if job == "short_doc_classifier":
        docs = []
        for record in records[:8]:
            kind = str(record.get("kind") or "unknown")
            doc_type = "web_page" if kind == "browser" else "note" if kind == "dictation" else "machine_event" if kind == "nervous_event" else "unknown"
            docs.append({"source_id": str(record.get("id")), "doc_type": doc_type, "summary": source_text(record, 260), "fields": [{"key": "kind", "value": kind}], "next_review": "use_if_relevant"})
        return {"documents": docs, "summary": f"classified={len(docs)}"}
    return {}


