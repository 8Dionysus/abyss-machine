def run_browser_reading(limit: int = 6, request_class: str = "job") -> dict[str, Any]:
    job = "browser_reading"
    items = recent_browser_records(limit=min(limit, 3))
    source = source_record_summary("browser_content", items)
    if not items:
        return idle_job(job, "no_recent_browser_content_text", source)
    allowed, gate = llm_available_for_jobs(job=job, request_class=request_class)
    policy = gate.get("policy") if isinstance(gate.get("policy"), dict) else {}
    if not allowed:
        pages = [
            {
                "source_id": str(item.get("id")),
                "title": str(item.get("title") or "")[:240],
                "summary": compact_text(str(item.get("text") or ""), 700),
                "tags": ["browser", "capture"],
                "usefulness": "medium" if ((item.get("quality") or {}).get("classification") == "usable") else "low",
                "follow_up": f"Gate fallback: LLM не запускался; quality={((item.get('quality') or {}).get('classification') or 'unknown')}.",
            }
            for item in items
            if item.get("id")
        ][:4]
        return write_job_artifact(job, {
            "ok": True,
            "status": "ok_gate_fallback",
            "reason": gate.get("reason"),
            "source": source,
            "result": {
                "pages": pages,
                "themes": [],
                "quality_notes": [f"LLM gate blocked: {gate.get('reason')}; deterministic cleaned page summaries written."],
            },
            "feedback": {
                "gate": gate,
                "operator_check": "Проверить, не попали ли пустые/дублирующиеся страницы; полезные темы можно потом связать с daily brief.",
                "quality_gate": {"source_ids_preserved": True, "pages": len(pages)},
            },
            "model": {"used": False, "fallback_used": True, "gate": gate},
        })
    job_items = items[:policy_source_limit(policy, len(items))]
    if not job_items:
        job_items = items[:1]
    usable_items = [
        item for item in job_items
        if ((item.get("quality") or {}).get("classification") == "usable")
    ]
    if usable_items:
        useful_contexts = {"ai_interaction", "project", "docs", "tooling", "research"}
        usable_ids = {str(item.get("id") or "") for item in usable_items}
        related_items = [
            item for item in job_items
            if str(item.get("id") or "") not in usable_ids
            and str(((item.get("web_context_quality") or {}).get("class") or "")) in useful_contexts
        ]
        job_items = (usable_items + related_items)[:1]
    source = source_record_summary("browser_content", job_items)
    n_predict = policy_n_predict(144, policy, job)
    prompt_items = browser_reading_prompt_items(job_items, text_limit=260)
    attempts: list[dict[str, Any]] = []
    out, parsed = completion_json_relaxed(browser_reading_prompt(prompt_items), n_predict=n_predict, timeout=policy_timeout(180.0, policy))
    attempts.append({"items": len(prompt_items), "n_predict": n_predict, "http": out.get("_http"), "slot_lock": out.get("_slot_lock"), "error": out.get("error"), "parsed": isinstance(parsed, dict)})
    if not isinstance(parsed, dict) and len(job_items) > 1:
        retry_items = job_items[:1]
        retry_prompt_items = browser_reading_prompt_items(retry_items, text_limit=180)
        retry_n_predict = min(n_predict, 96)
        retry_out, retry_parsed = completion_json_relaxed(browser_reading_prompt(retry_prompt_items), n_predict=retry_n_predict, timeout=policy_timeout(120.0, policy))
        attempts.append({"items": len(retry_prompt_items), "n_predict": retry_n_predict, "http": retry_out.get("_http"), "slot_lock": retry_out.get("_slot_lock"), "error": retry_out.get("error"), "parsed": isinstance(retry_parsed, dict)})
        if isinstance(retry_parsed, dict):
            job_items = retry_items
            source = source_record_summary("browser_content", job_items)
            out = retry_out
            parsed = retry_parsed
            n_predict = retry_n_predict
    allowed_ids = set(source["ids"])
    source_by_id = {str(item.get("id") or ""): item for item in job_items if item.get("id")}
    pages = []
    parsed_page_items = []
    if isinstance(parsed, dict):
        if isinstance(parsed.get("page"), dict):
            parsed_page_items = [parsed.get("page")]
        else:
            parsed_page_items = list_value(parsed.get("pages"))
    for item in parsed_page_items:
        if not isinstance(item, dict):
            continue
        sid = str(item.get("source_id") or "")
        if sid not in allowed_ids:
            continue
        source_item = source_by_id.get(sid) or {}
        pages.append({
            "source_id": sid,
            "title": str(item.get("title") or source_item.get("title") or "")[:240],
            "summary": str(item.get("summary") or "")[:700],
            "tags": [str(tag)[:80] for tag in list_value(item.get("tags"))[:8]],
            "usefulness": item.get("usefulness") or "medium",
            "follow_up": str(item.get("follow_up") or "")[:300],
        })
    parsed_ok = isinstance(parsed, dict) and (isinstance(parsed.get("pages"), list) or isinstance(parsed.get("page"), dict))
    fallback_used = False
    if not pages:
        fallback_used = True
        pages = [
            {
                "source_id": str(item.get("id")),
                "title": str(item.get("title") or "")[:240],
                "summary": compact_text(str(item.get("text") or ""), 700),
                "tags": ["browser", "capture"],
                "usefulness": "medium" if ((item.get("quality") or {}).get("classification") == "usable") else "low",
                "follow_up": f"Fallback summary from cleaned capture; quality={((item.get('quality') or {}).get('classification') or 'unknown')}.",
            }
            for item in job_items
            if item.get("id")
        ][:4]
    ok = True
    return write_job_artifact(job, {
        "ok": ok,
        "status": "ok_degraded" if parsed_ok and not fallback_used and policy.get("decision") == "degraded" else "ok" if parsed_ok and not fallback_used else "ok_fallback",
        "source": source,
        "result": {
            "pages": pages,
            "themes": [str(item)[:240] for item in list_value((parsed or {}).get("themes") if isinstance(parsed, dict) else [])[:12]],
            "quality_notes": [str(item)[:240] for item in list_value((parsed or {}).get("quality_notes") if isinstance(parsed, dict) else [])[:12]],
        },
        "feedback": {
