        ],
    }


def machine_job_prompt(job: str, material: dict[str, Any]) -> str:
    thresholds = resident_thermal_thresholds()
    schemas = {
        "thermal_performance": {"incidents": [{"summary": "summary", "severity": "info|watch|warning|critical", "evidence": ["id or process"], "possible_cause": "cause", "confidence": "low|medium|high", "watch_next": "what to observe"}]},
        "storage_classifier": {"items": [{"action_id": "id", "class": "safe_regenerable|probably_keep|manual_review|blocked|protected", "reason": "reason", "operator_required": True}], "summary": "short summary"},
        "daily_brief": {"summary": "short Russian brief", "sections": [{"title": "title", "text": "text", "source_refs": ["ref"]}], "watchlist": ["thing"], "next_review": ["thing"]},
    }
    limits = {
        "thermal_performance": "incidents <= 2.",
        "storage_classifier": "items <= 16 and must cover every STORAGE_ACTION_IDS entry. action_id must be an exact id from STORAGE_ACTION_IDS.",
        "daily_brief": "sections <= 1, watchlist <= 1, next_review <= 1. Every text field <= 140 chars.",
    }
    prompt_material = machine_job_prompt_material(job, material)
    storage_action_ids = [
        str(item.get("id"))
        for item in material.get("storage", {}).get("actions", [])
        if isinstance(item, dict) and item.get("id")
    ] if job == "storage_classifier" else []
    return (
        "<|turn>user\n"
        f"Ты локальный аналитик Abyss Machine. Выполни только задачу {job} по свежей телеметрии. "
        "Ничего не удаляй, не запускай и не рекомендуй как факт без evidence. "
        "Thermal severity must follow LOCAL_THERMAL_THRESHOLDS; do not repeat source labels like critical when max temperature is below critical_c. "
        f"Лимиты вывода: {limits[job]} Пиши коротко и только валидный JSON без markdown.\n"
        f"STORAGE_ACTION_IDS: {json.dumps(storage_action_ids, ensure_ascii=False)}\n"
        f"LOCAL_THERMAL_THRESHOLDS: {json.dumps(thresholds, ensure_ascii=False)}\n"
        f"SCHEMA: {json.dumps(schemas[job], ensure_ascii=False)}\n"
        f"INPUT: {json.dumps(prompt_material, ensure_ascii=False, separators=(',', ':'))}\n"
        "<turn|>\n<|turn>model\n<|channel>final\n"
    )


def machine_job_json_schema(job: str) -> dict[str, Any]:
    string = {"type": "string"}
    if job == "thermal_performance":
        return {
            "type": "object",
            "additionalProperties": False,
            "properties": {
                "incidents": {
                    "type": "array",
                    "maxItems": 2,
                    "items": {
                        "type": "object",
                        "additionalProperties": False,
                        "properties": {
                            "summary": string,
                            "severity": {"type": "string", "enum": ["info", "watch", "warning", "critical"]},
                            "evidence": {"type": "array", "maxItems": 5, "items": string},
                            "possible_cause": string,
                            "confidence": {"type": "string", "enum": ["low", "medium", "high"]},
                            "watch_next": string,
                        },
                        "required": ["summary", "severity", "evidence", "possible_cause", "confidence", "watch_next"],
                    },
                },
            },
            "required": ["incidents"],
        }
    if job == "storage_classifier":
        return {
            "type": "object",
            "additionalProperties": False,
            "properties": {
                "items": {
                    "type": "array",
                    "maxItems": 16,
                    "items": {
                        "type": "object",
                        "additionalProperties": False,
                        "properties": {
                            "action_id": string,
                            "class": {"type": "string", "enum": ["safe_regenerable", "probably_keep", "manual_review", "blocked", "protected"]},
                            "reason": string,
                            "operator_required": {"type": "boolean"},
                        },
                        "required": ["action_id", "class", "reason", "operator_required"],
                    },
                },
                "summary": string,
            },
            "required": ["items", "summary"],
        }
    short_string = {"type": "string", "maxLength": 140}
    ref_string = {"type": "string", "maxLength": 96}
    return {
        "type": "object",
        "additionalProperties": False,
        "properties": {
            "summary": short_string,
            "sections": {
                "type": "array",
                "maxItems": 1,
                "items": {
                    "type": "object",
                    "additionalProperties": False,
                    "properties": {
                        "title": short_string,
                        "text": short_string,
                        "source_refs": {"type": "array", "maxItems": 3, "items": ref_string},
                    },
                    "required": ["title", "text", "source_refs"],
                },
            },
            "watchlist": {"type": "array", "maxItems": 1, "items": short_string},
            "next_review": {"type": "array", "maxItems": 1, "items": short_string},
        },
        "required": ["summary", "sections", "watchlist", "next_review"],
    }


def normalize_machine_job(job: str, parsed: dict[str, Any] | None, material: dict[str, Any]) -> tuple[bool, dict[str, Any]]:
    if not isinstance(parsed, dict):
        return False, {}
    payload = parsed.get(job) if isinstance(parsed.get(job), dict) else parsed
    expected_keys = {
        "thermal_performance": {"incidents"},
        "storage_classifier": {"items", "summary"},
        "daily_brief": {"summary", "sections", "watchlist", "next_review"},
    }[job]
    if not any(key in payload for key in expected_keys):
        return False, {}
    if job == "storage_classifier" and not list_value(payload.get("items")):
        return False, {}
    result = normalize_machine_bundle({job: payload}, material)[job]
    if job == "thermal_performance" and not result.get("incidents"):
        return False, {}
    if job == "storage_classifier":
        raw_ids = {
            str(item.get("action_id") or "")
            for item in list_value(payload.get("items"))
            if isinstance(item, dict) and item.get("action_id")
        }
        expected_ids = {
            str(item.get("id") or "")
            for item in list_value((material.get("storage") if isinstance(material.get("storage"), dict) else {}).get("actions"))
            if isinstance(item, dict) and item.get("id")
        }
        if not result.get("items") or raw_ids != expected_ids:
            return False, result
    if job == "storage_classifier" and not result.get("items"):
        return False, {}
    if job == "daily_brief" and not result.get("summary"):
        return False, {}
    return True, result


def machine_job_feedback(job: str, gate: dict[str, Any] | None = None, result: dict[str, Any] | None = None) -> dict[str, Any]:
    if job == "thermal_performance":
        feedback = {"operator_check": "Сверять incidents с фактическими пиками температуры и процессами; это кандидатная атрибуция, не доказательство."}
    elif job == "storage_classifier":
        feedback = {"operator_check": "Классы не удаляют данные. Использовать только как подготовку к ручному cleanup-plan review."}
    else:
        feedback = {"operator_check": "Daily brief должен помогать ориентироваться утром/вечером; неверные акценты потом пойдут в калибрацию."}
    if isinstance(result, dict):
        if isinstance(result.get("quality_gate"), dict):
            feedback["quality_gate"] = result.get("quality_gate")
        if isinstance(result.get("coverage"), dict):
            feedback["coverage"] = result.get("coverage")
    if gate is not None:
        feedback["gate"] = gate
    return feedback


def mcp_context_summary_text(label: str, payload: dict[str, Any]) -> str:
    summary = payload.get("summary") if isinstance(payload.get("summary"), dict) else {}
    parts = [label]
    schema = str(payload.get("schema") or "").strip()
    if schema:
        parts.append(f"schema={schema}")
    if payload.get("ok") is not None:
        parts.append(f"ok={bool(payload.get('ok'))}")
    status = str(payload.get("status") or "").strip()
    if status:
        parts.append(f"status={status}")
    query = str(payload.get("query") or "").strip()
    if query:
        parts.append(f"query={query[:120]}")
    trace_id = str(payload.get("trace_id") or summary.get("trace_id") or "").strip()
    if trace_id:
        parts.append(f"trace_id={trace_id[:120]}")
    if summary:
        parts.append("summary=" + compact_text(json.dumps(summary, ensure_ascii=False, sort_keys=True), 220))
    return compact_text("; ".join(parts), 380)


def mcp_context_brief_item(label: str, path: Path, payload: dict[str, Any]) -> dict[str, Any]:
    summary = payload.get("summary") if isinstance(payload.get("summary"), dict) else {}
    return {
        "source_id": str(path),
        "label": label,
        "path": str(path),
        "exists": path.exists(),
        "schema": payload.get("schema"),
        "ok": payload.get("ok"),
        "status": payload.get("status"),
        "generated_at": payload.get("generated_at"),
        "age_sec": source_age_sec(payload.get("generated_at")),
        "query": payload.get("query"),
        "trace_id": payload.get("trace_id") or summary.get("trace_id"),
        "summary": summary,
        "summary_text": mcp_context_summary_text(label, payload),
        "raw_payload_exposed": False,
    }


def mcp_context_health_check(contexts: list[dict[str, Any]], missing: list[dict[str, Any]]) -> dict[str, Any]:
    checks: list[dict[str, Any]] = []

    def add(level: str, key: str, message: str, details: dict[str, Any]) -> None:
        item = {"level": level, "key": key, "message": message}
        item.update(details)
        checks.append(item)

    for item in missing:
        add("fail", "source_missing", "MCP-facing machine context source is missing", {
            "source_id": item.get("path"),
            "label": item.get("label"),
            "path": item.get("path"),
            "exists": item.get("exists"),
        })
    for context in contexts:
        age = float_value(context.get("age_sec"))
        label = str(context.get("label") or "context")
        source_id = str(context.get("source_id") or context.get("path") or "")
        if context.get("ok") is False:
            add("fail", "source_not_ok", "MCP-facing machine context source reports not ok", {
                "source_id": source_id,
                "label": label,
                "path": context.get("path"),
                "ok": context.get("ok"),
                "status": context.get("status"),
            })
        if age is None:
            add("warn", "source_age_unknown", "MCP-facing machine context source has no generated_at age", {
                "source_id": source_id,
                "label": label,
                "path": context.get("path"),
                "generated_at": context.get("generated_at"),
            })
        elif age > MCP_CONTEXT_SOURCE_HARD_MAX_AGE_SEC:
            add("fail", "source_stale_hard", "MCP-facing machine context source is hard stale", {
                "source_id": source_id,
                "label": label,
                "path": context.get("path"),
                "age_sec": age,
                "max_age_sec": MCP_CONTEXT_SOURCE_MAX_AGE_SEC,
                "hard_max_age_sec": MCP_CONTEXT_SOURCE_HARD_MAX_AGE_SEC,
            })
        elif age > MCP_CONTEXT_SOURCE_MAX_AGE_SEC:
            add("warn", "source_stale", "MCP-facing machine context source is stale", {
                "source_id": source_id,
                "label": label,
                "path": context.get("path"),
                "age_sec": age,
                "max_age_sec": MCP_CONTEXT_SOURCE_MAX_AGE_SEC,
                "hard_max_age_sec": MCP_CONTEXT_SOURCE_HARD_MAX_AGE_SEC,
            })
        else:
            add("ok", "source_fresh", "MCP-facing machine context source is fresh", {
                "source_id": source_id,
                "label": label,
                "path": context.get("path"),
                "age_sec": age,
                "max_age_sec": MCP_CONTEXT_SOURCE_MAX_AGE_SEC,
            })
    fails = sum(1 for item in checks if item.get("level") == "fail")
    warnings = sum(1 for item in checks if item.get("level") == "warn")
    return {
        "schema": f"{SCHEMA_PREFIX}_mcp_context_health_v1",
        "status": "fail" if fails else "warn" if warnings else "ok",
        "ok": fails == 0,
        "summary": {
            "fails": fails,
            "warnings": warnings,
            "checks": len(checks),
            "contexts": len(contexts),
            "missing": len(missing),
            "max_age_sec": MCP_CONTEXT_SOURCE_MAX_AGE_SEC,
            "hard_max_age_sec": MCP_CONTEXT_SOURCE_HARD_MAX_AGE_SEC,
        },
        "checks": checks,
        "policy": {
            "read_only": True,
            "action_execution": False,
            "automatic_repair": False,
            "surfaces_stale_context_as_candidate": True,
        },
    }


def run_mcp_context_brief(limit: int = 8) -> dict[str, Any]:
    sources: list[tuple[str, Path]] = [
        ("machine_maps", MAPS_LATEST),
        ("rag_refresh", RAG_REFRESH_LATEST),
        ("rag_trace", RAG_TRACE_LATEST),
        ("rag_eval", RAG_EVAL_LATEST),
        ("rag_validate", RAG_VALIDATE_LATEST),
    ]
    contexts: list[dict[str, Any]] = []
    missing: list[dict[str, Any]] = []
    refs = {label: str(path) for label, path in sources}
    for label, path in sources:
        payload = load_json(path)
        if not payload:
            missing.append({"label": label, "path": str(path), "exists": path.exists()})
            continue
        contexts.append(mcp_context_brief_item(label, path, payload))
    contexts = contexts[: max(1, min(limit, 16))]
    source_ages = [float_value(item.get("age_sec")) for item in contexts]
    source_ages = [age for age in source_ages if age is not None]
    health = mcp_context_health_check(contexts, missing)
    source = {
        "kind": "mcp_facing_machine_context",
        "count": len(contexts),
        "refs": refs,
        "missing": missing,
        "freshness": {
            "max_age_sec": MCP_CONTEXT_SOURCE_MAX_AGE_SEC,
            "hard_max_age_sec": MCP_CONTEXT_SOURCE_HARD_MAX_AGE_SEC,
            "usable_count": len(contexts),
            "newest_age_sec": min(source_ages) if source_ages else None,
            "oldest_age_sec": max(source_ages) if source_ages else None,
        },
        "health_status": health.get("status"),
        "newest_age_sec": min(source_ages) if source_ages else None,
        "oldest_age_sec": max(source_ages) if source_ages else None,
    }
    source_refs = [str(item.get("source_id")) for item in contexts if item.get("source_id")]
    routes = []
    if contexts:
        routes.append({
            "source_id": str(RAG_REFRESH_LATEST if any(item.get("path") == str(RAG_REFRESH_LATEST) for item in contexts) else Path(source_refs[0])),
