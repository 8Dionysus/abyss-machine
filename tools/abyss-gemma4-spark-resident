def normalize_machine_bundle(payload: dict[str, Any] | None, material: dict[str, Any]) -> dict[str, Any]:
    payload = payload if isinstance(payload, dict) else {}
    thermal = payload.get("thermal_performance") if isinstance(payload.get("thermal_performance"), dict) else {}
    storage = payload.get("storage_classifier") if isinstance(payload.get("storage_classifier"), dict) else {}
    brief = payload.get("daily_brief") if isinstance(payload.get("daily_brief"), dict) else {}
    storage_ids = {str(item.get("id")) for item in material.get("storage", {}).get("actions", []) if isinstance(item, dict) and item.get("id")}
    normalized = {
        "thermal_performance": apply_thermal_quality_gate({
            "incidents": [
                {
                    "summary": str(item.get("summary") or "")[:700],
                    "severity": item.get("severity") or "info",
                    "evidence": [str(ref)[:240] for ref in list_value(item.get("evidence"))[:8]],
                    "possible_cause": str(item.get("possible_cause") or "")[:500],
                    "confidence": item.get("confidence") or "low",
                    "watch_next": str(item.get("watch_next") or "")[:400],
                }
                for item in list_value(thermal.get("incidents")) if isinstance(item, dict)
            ][:12],
        }, material),
        "storage_classifier": storage_coverage_gate({
            "items": [
                {
                    "action_id": str(item.get("action_id") or ""),
                    "class": item.get("class") or "manual_review",
                    "reason": str(item.get("reason") or "")[:600],
                    "operator_required": True,
                }
                for item in list_value(storage.get("items"))
                if isinstance(item, dict) and str(item.get("action_id") or "") in storage_ids
            ][:16],
            "summary": str(storage.get("summary") or "")[:700],
        }, material),
        "daily_brief": daily_brief_quality_gate({
            "summary": str(brief.get("summary") or "")[:900],
            "sections": [
                {"title": str(item.get("title") or "")[:160], "text": str(item.get("text") or "")[:700], "source_refs": [str(ref)[:240] for ref in list_value(item.get("source_refs"))[:8]]}
                for item in list_value(brief.get("sections")) if isinstance(item, dict)
            ][:10],
            "watchlist": [str(item)[:300] for item in list_value(brief.get("watchlist"))[:12]],
            "next_review": [str(item)[:300] for item in list_value(brief.get("next_review"))[:12]],
        }, material),
    }
    return normalized


