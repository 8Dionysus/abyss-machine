def resident_default_source_cap(job: str | None, request_class: str) -> int | None:
    job_name = str(job or "")
    if job_name == "dictation_digest":
        return 3 if request_class != "foreground" else 5
    if job_name in {"dictation_quality", "daily_work_blocks", "intent_candidates", "operator_input_context", "command_grammar", "mcp_context_brief"}:
        return 4
    if job_name == "browser_reading":
