        "dictation_quality": "quality_issues <= 5, vocabulary_candidates <= 6, punctuation_patterns <= 4, calibration_notes <= 4.",
        "daily_work_blocks": "blocks <= 2.",
        "intent_candidates": "candidates <= 2; execute must always be false.",
        "command_grammar": "patterns <= 2, proposed_triggers must be [], safety_notes <= 2. Do not emit placeholder triggers like 'Команда, ...'.",
    }
    compact_limits = {
        "dictation_quality": "quality_issues <= 1. vocabulary_candidates=[], punctuation_patterns=[], calibration_notes=[] unless the issue is obvious.",
        "daily_work_blocks": "blocks <= 1.",
        "intent_candidates": "candidates <= 1; execute must always be false.",
        "command_grammar": "patterns <= 1, proposed_triggers <= 0, safety_notes <= 1.",
    }
    compact_schemas = {
        **schemas,
        "dictation_quality": {
