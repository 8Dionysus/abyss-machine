                    "text": f"gemma4.spark {resident.get('status')} temp={resident.get('temp')}C; loadavg={resident.get('loadavg')}",
                    "source_refs": ["resident.status/latest"],
                },
                {
                    "title": "Storage/Thermal",
                    "text": f"cleanup actions={actions_total}; ready={ready_gb:.1f}GB; root={root_gb:.1f}GB; thermal={thermal.get('incident_severity')}",
                    "source_refs": ["storage.cleanup-plan/latest", "processes.thermal-attribution/latest"],
                },
            ],
            "watchlist": ["Смотреть, не возвращаются ли ok_fallback/parse_failed в E2B jobs."],
            "next_review": ["Сверить daily brief после следующего цикла автоматики."],
        },
    }
    data["thermal_performance"] = apply_thermal_quality_gate(data["thermal_performance"], material)
    data["storage_classifier"] = storage_coverage_gate(data["storage_classifier"], material)
    data["daily_brief"] = daily_brief_quality_gate(data["daily_brief"], material)
    return data


def machine_job_prompt_material(job: str, material: dict[str, Any]) -> dict[str, Any]:
    if job != "daily_brief":
        return material
    thermal = material.get("thermal") if isinstance(material.get("thermal"), dict) else {}
    storage = material.get("storage") if isinstance(material.get("storage"), dict) else {}
    resident = material.get("resident_status") if isinstance(material.get("resident_status"), dict) else {}
    return {
        "generated_at": material.get("generated_at"),
        "resident_status": resident,
        "thermal": {
            "incident_kind": thermal.get("incident_kind"),
            "incident_severity": thermal.get("incident_severity"),
            "hottest_candidate": thermal.get("hottest_candidate"),
            "top_candidate_confidence": thermal.get("top_candidate_confidence"),
