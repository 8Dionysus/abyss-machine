def normalize_dictation_job(job: str, parsed: dict[str, Any] | None, source_ids: list[str]) -> tuple[bool, dict[str, Any]]:
    if not isinstance(parsed, dict):
        return False, {}
    payload = parsed.get(job) if isinstance(parsed.get(job), dict) else parsed
    expected_keys = {
        "dictation_quality": {"quality_issues", "vocabulary_candidates", "punctuation_patterns", "calibration_notes"},
        "daily_work_blocks": {"blocks"},
        "intent_candidates": {"candidates"},
        "command_grammar": {"patterns", "proposed_triggers", "safety_notes"},
    }[job]
    if not any(key in payload for key in expected_keys):
        return False, {}
    return True, normalize_dictation_bundle({job: payload}, source_ids)[job]


def dictation_job_feedback(job: str, result: dict[str, Any], gate: dict[str, Any] | None = None) -> dict[str, Any]:
    feedback: dict[str, Any]
    if job == "dictation_quality":
        feedback = {
            "operator_check": "Смотреть quality_issues/vocabulary_candidates; через несколько дней перенести подтвержденное в dictation replacements/profile.",
            "quality_gate": {"source_ids_preserved": True, "issues": len(result.get("quality_issues") or [])},
        }
    elif job == "daily_work_blocks":
        feedback = {
            "operator_check": "Сравнить blocks с реальным ходом работы; неверные блоки помечать при будущей калибрации.",
            "quality_gate": {"source_ids_preserved": True, "blocks": len(result.get("blocks") or [])},
        }
    elif job == "intent_candidates":
        feedback = {
            "operator_check": "Это только кандидаты. Ничего из candidates не исполняется автоматически.",
            "quality_gate": {"source_ids_preserved": True, "candidates": len(result.get("candidates") or [])},
        }
    else:
        feedback = {
            "operator_check": "Собирать устойчивые фразы для будущей голосовой грамматики; рискованные trigger не подключать без ручного решения.",
            "quality_gate": {"source_ids_preserved": True, "patterns": len(result.get("patterns") or [])},
        }
        if isinstance(result.get("quality_gate"), dict):
            feedback["quality_gate"].update(result["quality_gate"])
    if gate is not None:
        feedback["gate"] = gate
    return feedback


def run_dictation_bundle(limit: int = 8, selected_jobs: list[str] | None = None, request_class: str = "job") -> dict[str, dict[str, Any]]:
    all_jobs = ["dictation_quality", "daily_work_blocks", "intent_candidates", "command_grammar"]
    jobs = selected_jobs if selected_jobs is not None else all_jobs
    items = recent_dictation_records(limit=limit)
    source = source_record_summary("dictation_transcripts", items)
    source["model_window"] = source_window("dictation_model_input")
    if not items:
        return {job: idle_job(job, "no_recent_dictation_records", source) for job in jobs}
    source_issue = dictation_model_source_issue(items)
    if source_issue:
        return {job: idle_job(job, source_issue, source) for job in jobs}
    predict = {"dictation_quality": 420, "daily_work_blocks": 380, "intent_candidates": 360, "command_grammar": 420}
    artifacts: dict[str, dict[str, Any]] = {}
    for job in jobs:
        job_allowed, job_gate = llm_available_for_jobs(job=job, request_class=request_class)
        policy = job_gate.get("policy") if isinstance(job_gate.get("policy"), dict) else {}
        job_items = items[:policy_source_limit(policy, len(items))] if job_allowed else items
        if not job_items:
            job_items = items[:1]
        job_source = source_record_summary("dictation_transcripts", job_items)
        job_source["model_window"] = source_window("dictation_model_input")
        fallback = fallback_dictation_bundle(job_items)
        if not job_allowed:
            result = fallback[job]
            artifacts[job] = write_job_artifact(job, {
                "ok": True,
                "status": "ok_gate_fallback",
                "reason": job_gate.get("reason"),
                "source": job_source,
                "result": result,
                "feedback": dictation_job_feedback(job, result, gate=job_gate),
                "model": {"used": False, "fallback_used": True, "gate": job_gate},
            })
            continue
        n_predict = policy_n_predict(predict[job], policy, job)
        compact_prompt = policy.get("decision") == "degraded"
        out, parsed = completion_json(dictation_job_prompt(job, job_items, compact=compact_prompt), n_predict=n_predict, timeout=policy_timeout(90.0, policy), json_schema=dictation_job_json_schema(job, compact=compact_prompt))
        parsed_ok, result = normalize_dictation_job(job, parsed, job_source["ids"])
        if not parsed_ok:
            result = fallback[job]
        payload = {
            "ok": True,
            "status": "ok_degraded" if parsed_ok and policy.get("decision") == "degraded" else "ok" if parsed_ok else "ok_fallback",
            "source": job_source,
            "result": result,
            "feedback": dictation_job_feedback(job, result, gate=job_gate),
            "model": {
                "used": True,
                "parsed_job": parsed_ok,
                "fallback_used": not parsed_ok,
                "policy": policy,
                "n_predict": n_predict,
                "compact_prompt": compact_prompt,
                "http": out.get("_http"),
                "error": out.get("error"),
                "raw_excerpt": str(out.get("_content") or "")[:1800],
            },
        }
        artifacts[job] = write_job_artifact(job, payload)
    return artifacts


