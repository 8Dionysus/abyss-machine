        candidate_id = str(candidate.get("candidate_id"))
        current = deduped.get(candidate_id)
        if current is None or candidate_selection_sort_key(candidate) < candidate_selection_sort_key(current):
            deduped[candidate_id] = candidate
    return sorted(deduped.values(), key=candidate_selection_sort_key)


def resident_candidates(limit: int = 64) -> dict[str, Any]:
    candidates = build_resident_candidates()[: max(1, min(limit, 256))]
    by_kind: dict[str, int] = {}
    by_route: dict[str, int] = {}
    by_source_job: dict[str, int] = {}
    by_selection_lane: dict[str, int] = {}
    risk_counts: dict[str, int] = {}
    freshness_counts: dict[str, int] = {}
    correctness_risk_counts: dict[str, int] = {}
    for candidate in candidates:
        increment_count(by_kind, candidate.get("kind"))
        increment_count(by_route, candidate.get("route"))
        increment_count(by_source_job, candidate.get("source_job"))
        increment_count(by_selection_lane, candidate.get("selection_lane"))
        increment_count(risk_counts, candidate.get("risk"))
        increment_count(freshness_counts, candidate.get("freshness_class"))
        increment_count(correctness_risk_counts, candidate.get("correctness_risk"))
    selected = pick_selected_candidates(candidates, 24)
    selected_for_heartbeat = pick_selected_candidates(
        [item for item in candidates if int_value(item.get("heartbeat_priority"), 0) > 0 and item.get("selection_tier") in {"operator_attention", "e4b_review", "heartbeat_watch"}],
        16,
    )
    selected_for_e4b_review = pick_selected_candidates(
        [item for item in candidates if item.get("e4b_review_eligible") is True and item.get("selection_tier") in {"operator_attention", "e4b_review", "heartbeat_watch"}],
        24,
    )
    queues = {
        "recall_queries": [item for item in candidates if item.get("kind") in {"recall_query", "alias"}],
        "rank_hints": [item for item in candidates if item.get("kind") == "rank_hint"],
        "model_input_candidates": [item for item in candidates if item.get("route") == "model_input_candidate"],
        "review_cards": [item for item in candidates if item.get("kind") == "action_card" or item.get("review_required")],
        "risk_routes": [item for item in candidates if item.get("kind") == "risk_route" or item.get("risk") not in {"none", "low"}],
        "short_documents": [item for item in candidates if item.get("kind") == "short_document"],
        "heartbeat_candidates": [item for item in candidates if int_value(item.get("heartbeat_priority"), 0) > 0],
        "e4b_review_candidates": [item for item in candidates if item.get("e4b_review_eligible") is True],
        "selected": selected,
        "selected_for_heartbeat": selected_for_heartbeat,
        "selected_for_e4b_review": selected_for_e4b_review,
    }
    summary = {
        "candidates": len(candidates),
        "kinds": [{"kind": key, "count": value} for key, value in sorted(by_kind.items())],
        "routes": [{"route": key, "count": value} for key, value in sorted(by_route.items())],
        "source_jobs": [{"job": key, "count": value} for key, value in sorted(by_source_job.items())],
        "selection_lanes": [{"lane": key, "count": value} for key, value in sorted(by_selection_lane.items(), key=lambda item: (SELECTION_LANE_ORDER.index(item[0]) if item[0] in SELECTION_LANE_ORDER else 999, item[0]))],
        "risk": [{"risk": key, "count": value} for key, value in sorted(risk_counts.items())],
        "freshness": [{"class": key, "count": value} for key, value in sorted(freshness_counts.items())],
        "correctness_risk": [{"risk": key, "count": value} for key, value in sorted(correctness_risk_counts.items())],
        "review_required": sum(1 for item in candidates if item.get("review_required")),
        "heartbeat_candidates": len(queues["heartbeat_candidates"]),
        "e4b_review_candidates": len(queues["e4b_review_candidates"]),
        "selected": len(queues["selected"]),
        "selected_for_heartbeat": len(queues["selected_for_heartbeat"]),
        "selected_for_e4b_review": len(queues["selected_for_e4b_review"]),
        "action_execution": False,
    }
    selection = candidate_selection_summary(candidates)
    prefix_pack = gemma_prefix_pack_contract(
        consumer=PROFILE,
        producer="resident_candidate_readmodel_v2",
        suffix_material=[
            "current operator request",
            "current resident job or micro-loop question",
            "fresh candidate deltas",
            "short-lived RAG snippets",
        ],
    )
    prompt_pack = gemma_prompt_pack_contract(
        prefix_pack,
        lane="resident_candidate_readmodel_v2",
        suffix_material=[
            "current resident command",
            "new source artifact summaries",
            "candidate queue limits",
            "validation or audit question",
        ],
    )
    data = {
        "schema": f"{SCHEMA_PREFIX}_candidate_readmodel_v2",
        "version": VERSION,
        "generated_at": now_iso(),
        "profile": PROFILE,
        "ok": True,
        "status": "ok" if candidates else "empty",
        "raw_private_content": False,
        "mode": "derived_candidate_read_model",
        "read_model_version": 2,
        "summary": summary,
        "prefix_pack": prefix_pack,
        "prompt_pack": prompt_pack,
        "source_jobs": resident_candidate_source_artifacts(),
        "candidates": candidates,
        "queues": queues,
        "selection": selection,
        "heartbeat_delta": {
            "new_or_current": len(queues["heartbeat_candidates"]),
            "review_required": summary["review_required"],
            "stale": freshness_counts.get("stale", 0),
            "top": sorted(queues["heartbeat_candidates"], key=candidate_selection_sort_key)[:12],
            "selected_top": [compact_selection_candidate(item) for item in queues["selected_for_heartbeat"][:8]],
        },
        "paths": {
            "latest": str(CANDIDATES_LATEST),
            "history_glob": str(CANDIDATES_ROOT / "jsonl" / "YYYY" / "MM" / "YYYY-MM-DD.jsonl"),
            "validate_latest": str(CANDIDATES_ROOT / "validate" / "latest.json"),
            "jobs_root": str(JOBS_ROOT),
        },
        "commands": {
