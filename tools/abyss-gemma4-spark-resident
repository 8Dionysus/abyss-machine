def write_job_artifact(job: str, payload: dict[str, Any]) -> dict[str, Any]:
    payload.setdefault("schema", f"{SCHEMA_PREFIX}_job_v1")
    payload.setdefault("version", VERSION)
    payload.setdefault("generated_at", now_iso())
    payload.setdefault("profile", PROFILE)
    payload.setdefault("job", job)
    payload.setdefault("non_claims", [
        "This artifact is a local derived candidate, not canonical truth.",
        "This job never executes actions; it only writes evidence and review candidates.",
    ])
