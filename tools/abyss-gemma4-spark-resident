def candidate_selection_lane(candidate: dict[str, Any]) -> str:
    kind = str(candidate.get("kind") or "")
    source_job = str(candidate.get("source_job") or "")
    risk = str(candidate.get("risk") or "none")
    if kind == "action_card" or source_job == "action_card_compiler":
        return "operator_action"
    if source_job == "operator_input_context" or kind in {"operator_input_context", "operator_input_lane"}:
        return "operator_input"
    if kind.startswith("intent_") or kind in {"operator_attention", "work_block", "command_pattern", "proposed_trigger_review"}:
        return "operator_intent"
    if source_job == "dictation_quality" or kind in {"dictation_quality_issue", "vocabulary_candidate"}:
        return "dictation_quality"
    if source_job == "risk_sentinel" or kind == "risk_route" or risk not in {"", "none", "low"}:
        return "risk_watch"
    if kind == "mcp_context_health":
        return "quality_monitor"
    if source_job == "storage_classifier" or kind == "storage_review_item":
        return "storage_review"
    if source_job == "thermal_performance" or kind == "thermal_signal":
        return "thermal_watch"
    if source_job in {"daily_work_blocks", "daily_brief"} or kind in {"daily_brief_section", "short_document"}:
        return "work_context"
    if source_job == "mcp_context_brief" or kind in {"mcp_context", "mcp_context_route"}:
        return "retrieval_hint"
    if source_job in {"query_expansion", "rerank_lite"} or kind in {"recall_query", "alias", "rank_hint", "label"}:
        return "retrieval_hint"
    if source_job in {"browser_reading", "short_doc_classifier"} or kind == "browser_page_summary":
        return "context_digest"
    if source_job in {"source_quality_scorer", "resident_quality_eval"} or kind in {"source_quality", "quality_eval"}:
        return "quality_monitor"
    return "support"


def candidate_selection_fields(candidate: dict[str, Any]) -> dict[str, Any]:
    kind = str(candidate.get("kind") or "")
    source_job = str(candidate.get("source_job") or "")
    route = str(candidate.get("route") or "")
    risk = str(candidate.get("risk") or "none")
    correctness = str(candidate.get("correctness_risk") or "low")
    freshness = str(candidate.get("freshness_class") or "unknown")
    payload = candidate.get("payload") if isinstance(candidate.get("payload"), dict) else {}
    utility = candidate_score(candidate.get("utility_score"), 0.5)
    heartbeat = max(0, min(5, int_value(candidate.get("heartbeat_priority"), 0)))
    review_required = candidate.get("review_required") is True
    e4b_review = candidate.get("e4b_review_eligible") is True
    lane = candidate_selection_lane(candidate)
    reasons: list[str] = []

    score = utility * 0.45
    score += (heartbeat / 5.0) * 0.12

    if review_required:
        score += 0.16
        reasons.append("review_required")
    if e4b_review:
        score += 0.10
        reasons.append("e4b_review_eligible")
    if risk not in {"", "none", "low"}:
        score += 0.12 if risk in {"medium", "watch"} else 0.16
        reasons.append(f"risk={risk[:32]}")
    if correctness == "medium":
        score += 0.05
        reasons.append("correctness_risk=medium")
    elif correctness == "high":
        score += 0.08
        reasons.append("correctness_risk=high")

    if kind.startswith("intent_"):
        score += 0.16
        reasons.append("operator_intent")
    elif kind in SELECTION_OPERATOR_KINDS:
        score += 0.14
        reasons.append("operator_value")
    elif kind in {"vocabulary_candidate"}:
        score += 0.08
        reasons.append("operator_vocabulary")
    elif kind in {"short_document", "browser_page_summary", "daily_brief_section", "mcp_context"}:
        score += 0.05
        reasons.append("context_support")
    elif kind in {"recall_query", "alias", "rank_hint", "mcp_context_route"}:
        score += 0.03
        reasons.append("retrieval_support")
    elif kind == "mcp_context_health":
        score += 0.09
        reasons.append("context_health_watch")

    if route in {"model_input_candidate", "nervous_recall_candidate", "brief_candidate"}:
        score += 0.04
        reasons.append("model_input_support")
    if source_job in {"action_card_compiler", "risk_sentinel", "intent_candidates", "operator_input_context", "command_grammar"}:
        score += 0.06
        reasons.append(f"source_job={source_job}")
    elif source_job == "mcp_context_brief":
        score += 0.05
        reasons.append(f"source_job={source_job}")
    elif source_job in {"dictation_quality", "daily_work_blocks", "storage_classifier"}:
        score += 0.04
        reasons.append(f"source_job={source_job}")

    if kind == "source_quality":
        classification = str(payload.get("classification") or "")
        allowed_use = str(payload.get("allowed_use") or "")
        reasons.append("source_quality_support")
        score -= 0.18
        if allowed_use == "model_input" and classification not in {"sensitive", "noise", "stale", "low_signal"}:
            score += 0.03
        else:
            score -= 0.08
    if kind == "quality_eval":
        verdict = str(payload.get("verdict") or "")
        if verdict == "pass":
            score -= 0.14
            reasons.append("routine_quality_eval")
        else:
            score += 0.08
            reasons.append("quality_eval_needs_review")

    if freshness == "aging":
        score -= 0.08
        reasons.append("freshness=aging")
    elif freshness == "stale":
        score -= 0.34
        reasons.append("freshness=stale")
    elif freshness == "unknown":
        score -= 0.04
        reasons.append("freshness=unknown")
    if payload.get("source_refs_missing") is True:
        score -= 0.18
        reasons.append("source_refs_missing")
    if route == "reject":
        score -= 0.30
        reasons.append("reject_route")

    selection_score = candidate_score(score)
    if route == "reject" or freshness == "stale":
        tier = "archive"
    elif selection_score >= 0.68 and (review_required or risk not in {"", "none", "low"} or kind in SELECTION_OPERATOR_KINDS or kind.startswith("intent_")):
        tier = "operator_attention"
    elif e4b_review and selection_score >= 0.50:
        tier = "e4b_review"
    elif heartbeat > 0 and selection_score >= 0.50 and kind not in SELECTION_BACKGROUND_KINDS:
        tier = "heartbeat_watch"
    elif route in {"model_input_candidate", "nervous_recall_candidate", "brief_candidate"} or kind in SELECTION_SUPPORT_KINDS:
        tier = "model_input_support" if selection_score >= 0.25 else "background_monitor"
    elif selection_score >= 0.35:
        tier = "background_monitor"
    else:
        tier = "archive"

    if not reasons:
        reasons.append("derived_candidate")
    return {
        "selection_score": selection_score,
        "selection_tier": tier,
        "selection_lane": lane,
        "selection_reasons": reasons[:8],
    }


def candidate_selection_tier_priority(value: Any) -> int:
    return SELECTION_TIER_PRIORITY.get(str(value or ""), 0)


def candidate_selection_sort_key(candidate: dict[str, Any]) -> tuple[float, int, int, float, str, str]:
    selection_score = candidate.get("selection_score")
    if not isinstance(selection_score, (int, float)):
        selection_score = candidate_selection_fields(candidate).get("selection_score")
    return (
        -candidate_score(selection_score),
        -candidate_selection_tier_priority(candidate.get("selection_tier")),
        -int_value(candidate.get("heartbeat_priority"), 0),
        -candidate_score(candidate.get("utility_score")),
        str(candidate.get("kind") or ""),
        str(candidate.get("candidate_id") or ""),
    )


def candidate_selected(candidate: dict[str, Any]) -> bool:
    tier = str(candidate.get("selection_tier") or "")
    return tier in {"operator_attention", "e4b_review", "heartbeat_watch"} or (
        tier == "model_input_support" and candidate_score(candidate.get("selection_score")) >= 0.52
    )


def selected_candidate_pool(candidates: list[dict[str, Any]]) -> list[dict[str, Any]]:
    return [item for item in candidates if candidate_selected(item)]


def pick_selected_candidates(
    candidates: list[dict[str, Any]],
    limit: int,
    *,
    per_source_job: int = 4,
    per_kind: int = 6,
    per_lane: int = 4,
) -> list[dict[str, Any]]:
    picked: list[dict[str, Any]] = []
    source_counts: dict[str, int] = {}
    kind_counts: dict[str, int] = {}
    lane_counts: dict[str, int] = {}
    picked_ids: set[str] = set()
    pool = selected_candidate_pool(candidates)
    lanes = [lane for lane in SELECTION_LANE_ORDER if any(str(item.get("selection_lane") or "") == lane for item in pool)]

    def can_pick(candidate: dict[str, Any]) -> bool:
        candidate_id = str(candidate.get("candidate_id") or id(candidate))
        source_job = str(candidate.get("source_job") or "")
        kind = str(candidate.get("kind") or "")
        lane = str(candidate.get("selection_lane") or "support")
        return (
            candidate_id not in picked_ids
            and source_counts.get(source_job, 0) < per_source_job
            and kind_counts.get(kind, 0) < per_kind
            and lane_counts.get(lane, 0) < per_lane
        )

    def mark(candidate: dict[str, Any]) -> None:
        candidate_id = str(candidate.get("candidate_id") or id(candidate))
        source_job = str(candidate.get("source_job") or "")
        kind = str(candidate.get("kind") or "")
        lane = str(candidate.get("selection_lane") or "support")
        picked_ids.add(candidate_id)
        picked.append(candidate)
        source_counts[source_job] = source_counts.get(source_job, 0) + 1
        kind_counts[kind] = kind_counts.get(kind, 0) + 1
        lane_counts[lane] = lane_counts.get(lane, 0) + 1

    while len(picked) < limit:
        progressed = False
        for lane in lanes:
            for candidate in pool:
                if str(candidate.get("selection_lane") or "") != lane:
                    continue
                if can_pick(candidate):
                    mark(candidate)
                    progressed = True
                    break
            if len(picked) >= limit:
                break
        if not progressed:
            break
    if len(picked) >= limit:
        return picked
    for candidate in pool:
        candidate_id = str(candidate.get("candidate_id") or id(candidate))
        if candidate_id in picked_ids:
            continue
        picked.append(candidate)
        picked_ids.add(candidate_id)
        if len(picked) >= limit:
            break
    return picked


def compact_selection_candidate(candidate: dict[str, Any]) -> dict[str, Any]:
    return {
        "candidate_id": candidate.get("candidate_id"),
        "kind": candidate.get("kind"),
        "source_job": candidate.get("source_job"),
        "source_ids": list_value(candidate.get("source_ids"))[:6],
        "title": candidate.get("title"),
        "route": candidate.get("route"),
        "risk": candidate.get("risk"),
        "utility_score": candidate.get("utility_score"),
        "selection_score": candidate.get("selection_score"),
        "selection_tier": candidate.get("selection_tier"),
        "selection_lane": candidate.get("selection_lane"),
        "selection_reasons": list_value(candidate.get("selection_reasons"))[:8],
        "heartbeat_priority": candidate.get("heartbeat_priority"),
        "e4b_review_eligible": candidate.get("e4b_review_eligible") is True,
        "review_required": candidate.get("review_required") is True,
    }


def candidate_selection_summary(candidates: list[dict[str, Any]]) -> dict[str, Any]:
    by_tier: dict[str, int] = {}
    by_lane: dict[str, int] = {}
    by_reason: dict[str, int] = {}
    for candidate in candidates:
        increment_count(by_tier, candidate.get("selection_tier"))
        increment_count(by_lane, candidate.get("selection_lane"))
        for reason in list_value(candidate.get("selection_reasons")):
            increment_count(by_reason, reason)
    selected = selected_candidate_pool(candidates)
    selected_top = pick_selected_candidates(candidates, 12)
    suppressed_background = [
        item
        for item in candidates
        if int_value(item.get("heartbeat_priority"), 0) > 0
        and item.get("selection_tier") in {"background_monitor", "model_input_support"}
        and not candidate_selected(item)
    ]
    return {
        "schema": f"{SCHEMA_PREFIX}_candidate_selection_v1",
        "policy": {
            "action_execution": False,
            "derived_candidate_not_truth": True,
            "score_is_routing_hint": True,
            "does_not_promote_readiness": True,
            "top_is_lane_diverse": True,
        },
        "selected_count": len(selected),
        "diverse_top_count": len(selected_top),
        "suppressed_background_count": len(suppressed_background),
        "by_tier": [{"tier": key, "count": value} for key, value in sorted(by_tier.items(), key=lambda item: (-candidate_selection_tier_priority(item[0]), item[0]))],
        "by_lane": [{"lane": key, "count": value} for key, value in sorted(by_lane.items(), key=lambda item: (SELECTION_LANE_ORDER.index(item[0]) if item[0] in SELECTION_LANE_ORDER else 999, item[0]))],
        "by_reason": [{"reason": key, "count": value} for key, value in sorted(by_reason.items())],
        "top": [compact_selection_candidate(item) for item in selected_top],
    }


def append_candidate(
    candidates: list[dict[str, Any]],
    *,
    source_job: str,
    kind: str,
    source_id: str,
    text: str,
    title: str | None = None,
    score: Any = None,
    confidence: str | None = None,
    risk: str = "none",
    route: Any = None,
    review_required: bool = True,
    payload: dict[str, Any] | None = None,
    source_generated_at: Any = None,
    source_ids: list[str] | None = None,
    source_item: dict[str, Any] | None = None,
) -> None:
    sid = str(source_id or "").strip()
    if not sid:
        return
    ids = []
    for value in [sid] + list_value(source_ids):
        source_ref = str(value or "").strip()
        if source_ref and source_ref not in ids:
            ids.append(source_ref)
    route_value = candidate_route(route, risk=str(risk or "none"))
    if source_item is None:
        source_item = load_json(job_latest_path(source_job))
    freshness = candidate_freshness_meta(source_item, source_generated_at)
    correctness_risk = candidate_correctness_risk(str(risk or "none"), source_item, ids)
    if (payload or {}).get("source_refs_missing") is True:
        correctness_risk = "medium"
    utility_score = candidate_utility_score(candidate_score(score), route_value, bool(review_required), str(freshness.get("freshness_class") or "unknown"), correctness_risk)
    entry = {
        "candidate_id": stable_id("resident-candidate-v2", {"source_job": source_job, "kind": kind, "source_ids": ids, "text": text, "payload": payload or {}}),
        "kind": kind,
        "source_job": source_job,
        "source_id": sid,
        "source_ids": ids,
        "title": compact_text(title or kind.replace("_", " "), 160),
        "text": compact_text(text, 420),
        "score": candidate_score(score),
        "utility_score": utility_score,
        "confidence": str(confidence or "medium")[:40],
        "risk": str(risk or "none")[:80],
        "correctness_risk": correctness_risk,
        "route": route_value,
        "review_required": bool(review_required),
        "action_execution": False,
        "source_artifact": str(job_latest_path(source_job)),
        "source_generated_at": source_generated_at,
        "source_age_sec": freshness.get("source_age_sec"),
        "artifact_age_sec": freshness.get("artifact_age_sec"),
        "freshness_class": freshness.get("freshness_class"),
        "expires_at": freshness.get("expires_at"),
        "heartbeat_priority": candidate_heartbeat_priority(utility_score, bool(review_required), str(risk or "none"), str(freshness.get("freshness_class") or "unknown")),
        "e4b_review_eligible": bool(review_required) or source_job == "operator_input_context" or correctness_risk != "low" or str(risk or "none") not in {"", "none", "low"},
        "payload": payload or {},
    }
    if (payload or {}).get("source_refs_missing") is True:
        entry["heartbeat_priority"] = 0
    entry.update(candidate_selection_fields(entry))
    candidates.append(entry)


def resident_candidate_source_artifacts() -> list[dict[str, Any]]:
    artifacts: list[dict[str, Any]] = []
    for job in CANDIDATE_SOURCE_JOBS:
        path = job_latest_path(job)
        item = load_json(path)
        artifacts.append({
            "job": job,
            "path": str(path),
            "exists": bool(item),
            "schema": item.get("schema"),
            "generated_at": item.get("generated_at"),
            "age_sec": source_age_sec(item.get("generated_at")),
            "ok": item.get("ok"),
            "status": item.get("status"),
            "model": {
                "used": (item.get("model") or {}).get("used") if isinstance(item.get("model"), dict) else None,
                "parsed_job": (item.get("model") or {}).get("parsed_job") if isinstance(item.get("model"), dict) else None,
                "fallback_used": (item.get("model") or {}).get("fallback_used") if isinstance(item.get("model"), dict) else None,
            },
        })
    return artifacts


def build_resident_candidates() -> list[dict[str, Any]]:
    candidates: list[dict[str, Any]] = []
    for job in CANDIDATE_SOURCE_JOBS:
        item = load_json(job_latest_path(job))
        result = item.get("result") if isinstance(item.get("result"), dict) else {}
        generated_at = item.get("generated_at")
        if job == "dictation_quality":
            for issue in list_value(result.get("quality_issues")):
                if not isinstance(issue, dict):
                    continue
                append_candidate(
                    candidates,
                    source_job=job,
                    kind="dictation_quality_issue",
                    source_id=str(issue.get("source_id") or ""),
                    title=str(issue.get("issue_type") or "dictation issue"),
                    text=f"{issue.get('excerpt') or ''} -> {issue.get('suspected_fix') or ''}",
                    score=confidence_score(issue.get("confidence"), 0.55),
                    confidence=str(issue.get("confidence") or "medium"),
                    route="human_review",
                    review_required=True,
                    payload={"issue_type": issue.get("issue_type"), "excerpt": issue.get("excerpt"), "suspected_fix": issue.get("suspected_fix")},
                    source_generated_at=generated_at,
                    source_item=item,
                )
            for vocab in list_value(result.get("vocabulary_candidates")):
                if not isinstance(vocab, dict):
                    continue
                ids = [str(value) for value in list_value(vocab.get("source_ids")) if str(value or "").strip()]
                append_candidate(
                    candidates,
                    source_job=job,
                    kind="vocabulary_candidate",
                    source_id=ids[0] if ids else "",
                    source_ids=ids,
                    title=str(vocab.get("term") or "vocabulary"),
                    text=str(vocab.get("reason") or ""),
                    score=0.52,
                    route="human_review",
                    review_required=True,
                    payload={"term": vocab.get("term")},
                    source_generated_at=generated_at,
                    source_item=item,
                )
        elif job == "daily_work_blocks":
            for block in list_value(result.get("blocks")):
                if not isinstance(block, dict):
                    continue
                ids = [str(value) for value in list_value(block.get("source_ids")) if str(value or "").strip()]
                append_candidate(
                    candidates,
                    source_job=job,
                    kind="work_block",
                    source_id=ids[0] if ids else str(block.get("block_id") or ""),
                    source_ids=ids,
                    title=str(block.get("topic") or "work block"),
                    text=f"{block.get('summary') or ''} Next: {block.get('next_review') or ''}",
                    score=0.5,
                    route="human_review",
                    review_required=True,
                    payload={"block_id": block.get("block_id"), "state": block.get("state"), "next_review": block.get("next_review")},
                    source_generated_at=generated_at,
                    source_item=item,
                )
        elif job == "intent_candidates":
            for intent in list_value(result.get("candidates")):
                if not isinstance(intent, dict):
                    continue
                append_candidate(
                    candidates,
                    source_job=job,
                    kind=f"intent_{str(intent.get('kind') or 'candidate')}",
                    source_id=str(intent.get("source_id") or ""),
                    title=str(intent.get("kind") or "intent"),
                    text=str(intent.get("text") or ""),
                    score=confidence_score(intent.get("confidence"), 0.55),
                    confidence=str(intent.get("confidence") or "medium"),
                    route="candidate_only",
                    review_required=True,
