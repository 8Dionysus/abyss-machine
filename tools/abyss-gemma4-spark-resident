            "text": "Use generated maps/RAG/context-refresh artifacts as read-only retrieval context; do not execute actions from this packet.",
            "review_required": False,
        })
        routes.append({
            "source_id": str(MAPS_LATEST if any(item.get("path") == str(MAPS_LATEST) for item in contexts) else Path(source_refs[0])),
            "source_refs": source_refs,
            "route": "machine_maps_retrieval",
            "title": "machine maps retrieval route",
            "text": "Prefer the machine maps and RAG traces as orientation inputs before resident background synthesis.",
            "review_required": False,
        })
    result = {
        "context_set_id": stable_id("mcp-context-brief", [{"path": item.get("path"), "generated_at": item.get("generated_at")} for item in contexts]),
        "contexts": contexts,
        "routes": routes,
        "health": health,
        "missing": missing,
        "limits": {"context_limit": max(1, min(limit, 16)), "raw_payload_exposed": False},
    }
    return write_job_artifact("mcp_context_brief", {
        "ok": True,
        "status": "ok_deterministic" if contexts else "idle",
        "reason": None if contexts else "no_mcp_facing_context_artifacts",
        "source": source,
        "result": result,
        "feedback": {
            "operator_check": "MCP context is generated read-only orientation material; use it as retrieval input, not as authority or an action source.",
            "coverage": {
                "contexts": len(contexts),
                "routes": len(routes),
                "missing": len(missing),
                "health_status": health.get("status"),
            },
        },
        "model": {
            "used": False,
            "parsed_job": None,
            "fallback_used": False,
            "policy": {
                "decision": "deterministic_low_latency",
                "serving": serving_payload(),
                "action_execution": False,
            },
            "n_predict": 0,
            "http": None,
            "raw_excerpt": "",
        },
        "non_claims": [
            "This job reads generated host context only; it does not call MCP tools.",
            "This job never mutates maps, RAG artifacts, MCP state, or project repositories.",
            "This job emits retrieval candidates, not proof, memory writeback, or operator action.",
        ],
