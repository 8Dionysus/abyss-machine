def run(cmd: list[str], timeout: float = 8.0) -> dict[str, Any]:
    try:
        completed = subprocess.run(cmd, check=False, capture_output=True, text=True, timeout=timeout)
    except FileNotFoundError:
        return {"ok": False, "returncode": 127, "stdout": "", "stderr": f"{cmd[0]} not found", "command": cmd}
    except subprocess.TimeoutExpired:
        return {"ok": False, "returncode": 124, "stdout": "", "stderr": "timeout", "command": cmd}
    return {"ok": completed.returncode == 0, "returncode": completed.returncode, "stdout": completed.stdout, "stderr": completed.stderr, "command": cmd}


def run_json(cmd: list[str], timeout: float = 12.0) -> dict[str, Any]:
    out = run(cmd, timeout=timeout)
    if not out.get("ok"):
        return {"ok": False, "error": out.get("stderr") or out.get("stdout"), "command": cmd, "returncode": out.get("returncode")}
    try:
        parsed = json.loads(str(out.get("stdout") or "{}"))
    except json.JSONDecodeError as exc:
        return {"ok": False, "error": f"invalid JSON: {exc}", "command": cmd}
    return parsed if isinstance(parsed, dict) else {"ok": False, "error": "non-object JSON", "command": cmd}


def http_json(method: str, path: str, payload: dict[str, Any] | None = None, timeout: float = 5.0) -> dict[str, Any]:
    body = None
    headers = {"Accept": "application/json"}
    if payload is not None:
        body = json.dumps(payload, ensure_ascii=False).encode("utf-8")
        headers["Content-Type"] = "application/json"
    req = Request(BASE_URL + path, data=body, headers=headers, method=method)
    started = time.monotonic()
    try:
        with urlopen(req, timeout=timeout) as resp:
            raw = resp.read().decode("utf-8", errors="replace")
            latency_ms = round((time.monotonic() - started) * 1000, 1)
            try:
                data = json.loads(raw) if raw.strip() else {}
            except json.JSONDecodeError:
                data = {"raw": raw[:2000]}
            if not isinstance(data, dict):
                data = {"data": data}
            data["_http"] = {"ok": True, "status": resp.status, "latency_ms": latency_ms}
            return data
    except HTTPError as exc:
        return {"ok": False, "error": str(exc), "_http": {"ok": False, "status": exc.code}}
    except (URLError, TimeoutError, OSError) as exc:
        return {"ok": False, "error": str(exc), "_http": {"ok": False}}


def package_temp_c() -> float | None:
    out = run(["sensors"], timeout=3.0)
    match = re.search(r"Package id 0:\s+\+([0-9.]+)°C", str(out.get("stdout") or ""))
    if not match:
        return None
    try:
        return float(match.group(1))
    except ValueError:
        return None


def power_state() -> dict[str, Any]:
    profile = run(["powerprofilesctl", "get"], timeout=3.0)
    online_values = []
    for path in Path("/sys/class/power_supply").glob("A*/online"):
        try:
            online_values.append(path.read_text(encoding="utf-8").strip() == "1")
        except OSError:
            pass
    return {"profile": str(profile.get("stdout") or "").strip() or None, "on_ac": any(online_values) if online_values else None, "online_values_seen": len(online_values)}


