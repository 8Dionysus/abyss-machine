def normalize_extension_job(job: str, parsed: dict[str, Any] | None, records: list[dict[str, Any]], intents: list[dict[str, Any]]) -> tuple[bool, dict[str, Any]]:
    if not isinstance(parsed, dict):
        return False, {}
    allowed = {str(record.get("id")) for record in records if record.get("id")}
    allowed.update(str(item.get("source_id") or item.get("id")) for item in intents if item.get("source_id") or item.get("id"))
    result = fallback_extension_result(job, records, intents)
    if job == "query_expansion":
        queries = []
        for item in list_value(parsed.get("queries")):
            if isinstance(item, dict) and str(item.get("source_id") or "") in allowed:
                queries.append({"source_id": str(item.get("source_id")), "query": str(item.get("query") or "")[:220], "purpose": str(item.get("purpose") or "recall"), "tags": [str(tag)[:60] for tag in list_value(item.get("tags"))[:3]], "time_anchor": str(item.get("time_anchor") or "")[:80], "confidence": str(item.get("confidence") or "low")})
        aliases = []
        for item in list_value(parsed.get("aliases")):
            if isinstance(item, dict):
                ids = normalize_source_ids(item.get("source_ids"), allowed)
                if ids:
                    aliases.append({"term": str(item.get("term") or "")[:120], "aliases": [str(alias)[:80] for alias in list_value(item.get("aliases"))[:5]], "source_ids": ids})
        return bool(queries), {"queries": queries[:2], "aliases": aliases[:0], "fallback_search": str(parsed.get("fallback_search") or (queries[0]["query"] if queries else ""))[:220]}
    if job == "rerank_lite":
        ranked = []
        seen: set[str] = set()
        for item in list_value(parsed.get("ranked")):
            if not isinstance(item, dict):
                continue
            sid = str(item.get("source_id") or "")
            if sid in allowed and sid not in seen:
                seen.add(sid)
                ranked.append({"source_id": sid, "rank": int_value(item.get("rank"), len(ranked) + 1), "score": round(float_value(item.get("score")) or 0.0, 3), "reason": str(item.get("reason") or "")[:260]})
        return bool(ranked), {"query": str(parsed.get("query") or "latest local context")[:220], "ranked": sorted(ranked, key=lambda item: item["rank"]), "fallback": str(parsed.get("fallback") or "bm25_rrf_order_when_model_unavailable")[:220]}
    if job == "source_quality_scorer":
        rows = []
        for item in list_value(parsed.get("records")):
            if isinstance(item, dict) and str(item.get("source_id") or "") in allowed:
                rows.append({"source_id": str(item.get("source_id")), "classification": str(item.get("classification") or "low_signal"), "score": round(float_value(item.get("score")) or 0.0, 3), "reason": str(item.get("reason") or "")[:260], "allowed_use": str(item.get("allowed_use") or "review_only")})
        return bool(rows), {"records": rows, "summary": str(parsed.get("summary") or "")[:400]}
    if job == "resident_quality_eval":
        return True, fallback_extension_result(job, records, intents)
    if job == "action_card_compiler":
        cards = []
        for item in list_value(parsed.get("cards")):
            if not isinstance(item, dict):
                continue
            sid = str(item.get("source_id") or "")
            if sid not in allowed:
                continue
            route = str(item.get("route") or "operator_needed")
            risk, risk_route, reason = risk_route_for_text(str(item.get("intent") or ""))
            if risk != "none":
                route = risk_route
            cards.append({"card_id": str(item.get("card_id") or stable_id("action-card", item))[:80], "source_id": sid, "intent": str(item.get("intent") or "")[:360], "params": [{"key": str(param.get("key") or "")[:80], "value": str(param.get("value") or "")[:160]} for param in list_value(item.get("params")) if isinstance(param, dict)][:8], "risk": risk if risk != "none" else str(item.get("risk") or "low"), "missing_data": [str(value)[:120] for value in list_value(item.get("missing_data"))[:8]], "confirm_required": True, "route": route, "reason": str(item.get("reason") or reason)[:260]})
        if not cards:
            fallback = fallback_extension_result(job, records, intents)
            cards = [item for item in list_value(fallback.get("cards")) if isinstance(item, dict)]
            if cards:
                return True, {"cards": cards, "summary": str(fallback.get("summary") or f"cards={len(cards)}; no automatic execution")[:400]}
        return True, {"cards": cards, "summary": str(parsed.get("summary") or f"cards={len(cards)}; no automatic execution")[:400]}
    if job == "bounded_hint_generator":
        hints = []
        for item in list_value(parsed.get("hints")):
            if isinstance(item, dict) and str(item.get("source_id") or "") in allowed:
                hints.append({"source_id": str(item.get("source_id")), "kind": str(item.get("kind") or "review_note"), "text": str(item.get("text") or "")[:220], "use_for": str(item.get("use_for") or "human_review")})
        return bool(hints), {"hints": hints, "summary": str(parsed.get("summary") or "")[:400]}
    if job == "risk_sentinel":
        findings = []
        for item in list_value(parsed.get("findings")):
            if isinstance(item, dict) and str(item.get("source_id") or "") in allowed:
                risk, route, reason = risk_route_for_text(str(item.get("reason") or ""))
                parsed_risk = str(item.get("risk") or risk)
                parsed_route = str(item.get("route") or route)
                findings.append({"source_id": str(item.get("source_id")), "risk": parsed_risk, "route": parsed_route, "reason": str(item.get("reason") or reason)[:260]})
        deterministic = fallback_extension_result(job, records, intents).get("findings") or []
        merged = {str(item.get("source_id")): item for item in findings + deterministic if isinstance(item, dict)}
        return True, {"findings": list(merged.values()), "summary": str(parsed.get("summary") or f"risk_findings={len(merged)}")[:400]}
    docs = []
    for item in list_value(parsed.get("documents")):
        if isinstance(item, dict) and str(item.get("source_id") or "") in allowed:
            docs.append({"source_id": str(item.get("source_id")), "doc_type": str(item.get("doc_type") or "unknown"), "summary": str(item.get("summary") or "")[:360], "fields": [{"key": str(field.get("key") or "")[:80], "value": str(field.get("value") or "")[:180]} for field in list_value(item.get("fields")) if isinstance(field, dict)][:8], "next_review": str(item.get("next_review") or "")[:220]})
    return bool(docs), {"documents": docs, "summary": str(parsed.get("summary") or "")[:400]}


def extension_job_feedback(job: str, result: dict[str, Any], gate: dict[str, Any] | None = None) -> dict[str, Any]:
    checks = {
        "query_expansion": "Use generated queries as recall/search candidates only; source records remain canonical.",
        "rerank_lite": "Use rank as a timeout-bounded hint over deterministic BM25/RRF, not as the only ordering.",
        "source_quality_scorer": "Reject/noise/sensitive records should not be fed into larger prompts without review.",
        "resident_quality_eval": "Treat degraded verdicts as repair targets before adding more resident jobs.",
        "action_card_compiler": "Cards require operator confirmation and never execute directly.",
        "bounded_hint_generator": "Hints are labels/review notes only; deterministic sources carry truth.",
        "risk_sentinel": "High-risk findings route to curated sources/operator review; E2B must not answer them.",
        "short_doc_classifier": "Classifications are routing hints for memory/search, not archive truth.",
    }
    feedback = {
        "operator_check": checks.get(job, "Review derived candidate output."),
        "quality_gate": {
            "source_ids_preserved": True,
            "no_action_execution": True,
        },
    }
    if gate is not None:
        feedback["gate"] = gate
    if job == "action_card_compiler":
        cards = list_value(result.get("cards"))
        feedback["quality_gate"]["all_confirm_required"] = all(bool(card.get("confirm_required")) for card in cards if isinstance(card, dict))
    if job == "risk_sentinel":
        feedback["quality_gate"]["routes_only"] = True
    return feedback


def run_extension_job(job: str, limit: int = 8, request_class: str = "job") -> dict[str, Any]:
    records = mixed_source_records(limit=min(max(limit, 1), 8))
    intents = latest_intent_material(limit=6) if job == "action_card_compiler" else []
    if job == "resident_quality_eval":
        records = latest_job_records(limit=max(20, len(JOB_NAMES)))
    source = mixed_source_summary(records)
    if intents:
        source["intent_candidates"] = len(intents)
    if not records and not intents:
        return idle_job(job, "no_recent_source_records", source)
    if job in {"resident_quality_eval"}:
        result = fallback_extension_result(job, records, intents)
        return write_job_artifact(job, {
            "ok": True,
            "status": "ok_deterministic",
            "source": source,
            "result": result,
            "feedback": extension_job_feedback(job, result),
            "model": {"used": False, "fallback_used": False, "reason": "deterministic_quality_eval"},
        })
    deterministic_extension_jobs = {
        "query_expansion": "ABYSS_GEMMA4_SPARK_MODEL_QUERY_EXPANSION",
        "action_card_compiler": "ABYSS_GEMMA4_SPARK_MODEL_ACTION_CARD_COMPILER",
        "bounded_hint_generator": "ABYSS_GEMMA4_SPARK_MODEL_BOUNDED_HINT_GENERATOR",
        "risk_sentinel": "ABYSS_GEMMA4_SPARK_MODEL_RISK_SENTINEL",
        "short_doc_classifier": "ABYSS_GEMMA4_SPARK_MODEL_SHORT_DOC_CLASSIFIER",
    }
    if (
        job in deterministic_extension_jobs
        and EXTERNAL_ENDPOINT
        and os.environ.get(deterministic_extension_jobs[job], "").strip().lower() not in ENV_TRUE
    ):
        reason = "deterministic_low_latency"
        gate = {"reason": reason, "policy": {"serving": serving_payload()}}
        result = fallback_extension_result(job, records, intents)
        return write_job_artifact(job, {
            "ok": True,
            "status": "ok_deterministic",
            "reason": f"stack_endpoint_{job}_deterministic_low_latency",
            "source": source,
            "result": result,
            "feedback": extension_job_feedback(job, result, gate=gate),
            "model": {
                "used": False,
                "parsed_job": None,
                "fallback_used": False,
                "reason": reason,
                "policy": {"serving": serving_payload()},
                "n_predict": 0,
                "http": None,
                "raw_excerpt": "",
            },
        })
    allowed, gate = llm_available_for_jobs(job=job, request_class=request_class)
    policy = gate.get("policy") if isinstance(gate.get("policy"), dict) else {}
    if not allowed:
        result = fallback_extension_result(job, records, intents)
        return write_job_artifact(job, {
            "ok": True,
            "status": "ok_gate_fallback",
            "reason": gate.get("reason"),
            "source": source,
            "result": result,
            "feedback": extension_job_feedback(job, result, gate=gate),
            "model": {"used": False, "fallback_used": True, "gate": gate},
        })
    capped = policy_source_limit(policy, len(records))
    job_records = records[:capped] if capped > 0 else records[:1]
    source = mixed_source_summary(job_records)
    if intents:
        source["intent_candidates"] = len(intents)
    base_predict = {
        "query_expansion": 320,
        "rerank_lite": 480,
        "source_quality_scorer": 460,
        "action_card_compiler": 520,
        "bounded_hint_generator": 420,
        "risk_sentinel": 360,
        "short_doc_classifier": 760,
    }.get(job, 420)
    n_predict = policy_n_predict(base_predict, policy, job)
    out, parsed = completion_json(
        extension_job_prompt(job, job_records, intents),
        n_predict=n_predict,
        timeout=policy_timeout(150.0, policy),
        json_schema=extension_job_json_schema(job),
    )
    parsed_ok, result = normalize_extension_job(job, parsed, job_records, intents)
    if not parsed_ok:
        result = fallback_extension_result(job, job_records, intents)
    return write_job_artifact(job, {
        "ok": True,
        "status": "ok_degraded" if parsed_ok and policy.get("decision") == "degraded" else "ok" if parsed_ok else "ok_fallback",
        "source": source,
        "result": result,
        "feedback": extension_job_feedback(job, result, gate=gate),
        "model": {
            "used": True,
            "parsed_job": parsed_ok,
            "fallback_used": not parsed_ok,
            "policy": policy,
            "n_predict": n_predict,
            "http": out.get("_http"),
            "error": out.get("error"),
            "raw_excerpt": str(out.get("_content") or "")[:1800],
        },
    })


