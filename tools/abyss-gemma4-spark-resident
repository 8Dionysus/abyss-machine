def digest_json_schema() -> dict[str, Any]:
    string = {"type": "string", "maxLength": 220}
    return {
        "type": "object",
        "additionalProperties": False,
        "properties": {
            "batch_summary": {"type": "string", "maxLength": 220},
            "items": {
                "type": "array",
                "maxItems": 3,
                "items": {
                    "type": "object",
                    "additionalProperties": False,
                    "properties": {
                        "id": string,
                        "kind": {"type": "string", "enum": ["command", "decision", "question", "note", "context", "noise"]},
                        "summary": {"type": "string", "maxLength": 220},
                        "tasks": {"type": "array", "maxItems": 2, "items": string},
                        "tags": {"type": "array", "maxItems": 3, "items": string},
                        "quality_notes": {"type": "array", "maxItems": 2, "items": string},
                    },
                    "required": ["id", "kind", "summary", "tasks", "tags", "quality_notes"],
                },
            },
        },
        "required": ["batch_summary", "items"],
    }


def normalize_digest_payload(payload: dict[str, Any] | None) -> dict[str, Any] | None:
    if not isinstance(payload, dict) or not isinstance(payload.get("items"), list):
        return None
    normalized_items = []
    for item in payload.get("items", []):
        if not isinstance(item, dict):
            continue
        normalized_items.append({
            "id": item.get("id"),
            "kind": item.get("kind") or "note",
            "summary": item.get("summary") or "",
            "tasks": item.get("tasks") if isinstance(item.get("tasks"), list) else [],
            "tags": item.get("tags") if isinstance(item.get("tags"), list) else [],
            "quality_notes": item.get("quality_notes") if isinstance(item.get("quality_notes"), list) else [],
        })
    return {
        "batch_summary": payload.get("batch_summary") or "",
        "items": normalized_items,
    }


def digest(limit: int = 3) -> dict[str, Any]:
    if not health().get("ok"):
        data = {"schema": f"{SCHEMA_PREFIX}_digest_v1", "version": VERSION, "generated_at": now_iso(), "profile": PROFILE, "status": "skipped", "reason": "resident_server_not_running", "ok": True}
        write_json(DIGEST_LATEST, data)
        append_jsonl(daily_path(DIGEST_ROOT), data)
        return data
    items = dictation_events(limit=limit)
    source = source_record_summary("dictation_transcripts", items)
    if not items:
        data = {"schema": f"{SCHEMA_PREFIX}_digest_v1", "version": VERSION, "generated_at": now_iso(), "profile": PROFILE, "status": "idle", "reason": "no_new_dictation_events", "ok": True, "source": source}
        write_json(DIGEST_LATEST, data)
        append_jsonl(daily_path(DIGEST_ROOT), data)
        return data
    allowed, gate = llm_available_for_jobs(job="dictation_digest", request_class="digest")
    policy = gate.get("policy") if isinstance(gate.get("policy"), dict) else {}
    if allowed:
        capped = policy_source_limit(policy, len(items))
        items = items[:capped] if capped > 0 else items[:1]
    if not allowed:
        data = {
            "schema": f"{SCHEMA_PREFIX}_digest_v1",
            "version": VERSION,
            "generated_at": now_iso(),
            "profile": PROFILE,
            "status": "skipped",
            "reason": gate.get("reason") or "resident_policy_denied",
            "ok": True,
            "source": source_record_summary("dictation_transcripts", items),
            "policy": policy,
            "state_advanced": False,
        }
        write_json(DIGEST_LATEST, data)
        append_jsonl(daily_path(DIGEST_ROOT), data)
        return data
    n_predict = policy_n_predict(560, policy, "dictation_digest")
    timeout = min(policy_timeout(90.0, policy), 90.0)
    out, parsed = completion_json(digest_prompt(items), n_predict=n_predict, timeout=timeout, json_schema=digest_json_schema())
    normalized = normalize_digest_payload(parsed)
    ok = bool(out.get("_http", {}).get("ok")) and normalized is not None
    data = {
        "schema": f"{SCHEMA_PREFIX}_digest_v1",
        "version": VERSION,
        "generated_at": now_iso(),
        "profile": PROFILE,
        "status": "ok" if ok else "parse_failed",
        "ok": ok,
        "source": source_record_summary("dictation_transcripts", items),
        "policy": policy,
        "model": {"n_predict": n_predict, "timeout_sec": timeout},
        "http": out.get("_http"),
        "digest": normalized,
        "raw_excerpt": str(out.get("_content") or "")[:2000],
        "state_advanced": bool(ok),
    }
    if ok:
        state = load_json(STATE_PATH)
        seen = list(dict.fromkeys((state.get("seen_dictation_ids") or []) + [str(item.get("id")) for item in items if item.get("id")]))
        state.update({"updated_at": now_iso(), "seen_dictation_ids": seen[-5000:]})
        write_json(STATE_PATH, state)
    write_json(DIGEST_LATEST, data)
    append_jsonl(daily_path(DIGEST_ROOT), data)
    return data


