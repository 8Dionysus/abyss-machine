def token_accounting_int(value: Any) -> int | None:
    if isinstance(value, bool) or value is None:
        return None
    if isinstance(value, int):
        return value if value >= 0 else None
    if isinstance(value, float) and value >= 0 and value.is_integer():
        return int(value)
    return None


def token_accounting_from_usage(
    usage: Any,
    *,
    model_id: str,
    source_ref: str,
) -> dict[str, Any]:
    payload = usage if isinstance(usage, dict) else {}
    mapping = {
        "input_tokens": ("input_tokens", "prompt_tokens"),
        "output_tokens": ("output_tokens", "completion_tokens"),
        "total_tokens": ("total_tokens", "token_count", "tokens"),
        "cached_tokens": ("cached_tokens", "input_cached_tokens", "prompt_cached_tokens"),
        "reasoning_tokens": ("reasoning_tokens", "output_reasoning_tokens", "completion_reasoning_tokens"),
    }
    counts: dict[str, int] = {}
    for field, keys in mapping.items():
        for key in keys:
            value = token_accounting_int(payload.get(key))
            if value is not None:
                counts[field] = value
                break
    if "total_tokens" not in counts and "input_tokens" in counts and "output_tokens" in counts:
        counts["total_tokens"] = counts["input_tokens"] + counts["output_tokens"]
    record: dict[str, Any] = {
        "schema": TOKEN_ACCOUNTING_CONTRACT,
        "schema_version": TOKEN_ACCOUNTING_SCHEMA_VERSION,
        "timestamp": now_iso(),
        "source_kind": "provider_usage" if counts else "provider_usage_missing",
        "source_ref": source_ref,
        "provider": "llama.cpp_openai_compatible",
        "model_id": model_id,
        "count_basis": "provider_reported" if counts else "unknown",
        "privacy": token_accounting_privacy_flags(),
    }
    record.update(counts)
    return record


def source_record_summary(kind: str, items: list[dict[str, Any]]) -> dict[str, Any]:
    ages = [
        float(item["age_sec"])
        for item in items
        if isinstance(item.get("age_sec"), (int, float))
    ]
    freshness = source_window(kind)
    freshness.update({
        "usable_count": len(items),
        "newest_age_sec": round(min(ages), 1) if ages else None,
        "oldest_age_sec": round(max(ages), 1) if ages else None,
    })
    quality_counts: dict[str, int] = {}
    for item in items:
        quality = item.get("quality") if isinstance(item.get("quality"), dict) else {}
        classification = quality.get("classification")
        if classification:
            quality_counts[str(classification)] = int(quality_counts.get(str(classification), 0)) + 1
    return {
        "kind": kind,
        "count": len(items),
        "ids": [str(item.get("id")) for item in items if item.get("id")],
        "freshness": freshness,
        "quality": quality_counts or None,
    }


