def compact_dictation_items(items: list[dict[str, Any]], text_limit: int = 360) -> list[dict[str, str]]:
    return [
        {
            "id": str(item.get("id") or ""),
            "text": compact_text(str(item.get("text") or ""), text_limit),
        }
        for item in items
        if item.get("id")
    ]


