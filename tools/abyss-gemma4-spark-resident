    return None


def resident_policy(request_class: str = "job", job: str | None = None, write: bool = True) -> dict[str, Any]:
    status_data = status(write=True)
    cooling = run_json(["abyss-machine", "cooling", "status", "--json"], timeout=18.0)
    cpu_route = run_json(["abyss-machine", "ai", "cpu", "route", "--class", "heavy", "--json"], timeout=24.0)
    memory = run_json(["abyss-machine", "memory", "pressure", "--json"], timeout=18.0)
    games = run_json(["abyss-machine", "processes", "game-guard", "--json"], timeout=18.0)
    previous_policy = load_json(POLICY_LATEST)
    throttle_snapshot = thermal_throttle_snapshot()
    throttle_delta = thermal_throttle_delta(throttle_snapshot, previous_policy)
    thermal_thresholds = resident_thermal_thresholds()

    metrics = status_data.get("metrics") if isinstance(status_data.get("metrics"), dict) else {}
    status_temp = float_value(metrics.get("package_temp_c"))
    cooling_temperature = cooling.get("temperature") if isinstance(cooling.get("temperature"), dict) else {}
    cooling_temp = ((cooling_temperature.get("summary") or {}) if isinstance(cooling_temperature, dict) else {})
    cooling_episode = cooling_temperature.get("episode") if isinstance(cooling_temperature.get("episode"), dict) else {}
    cooling_package = float_value(cooling_temp.get("package_temperature_c_max"))
    cooling_max = float_value(cooling_temp.get("temperature_c_max"))
    routed_policy = ((cpu_route.get("policy") or {}).get("routed_heavy") or {}) if isinstance(cpu_route.get("policy"), dict) else {}
    distribution = routed_policy.get("distribution") if isinstance(routed_policy.get("distribution"), dict) else {}
    route_package = float_value(distribution.get("package_temperature_c_max"))
    package_candidates = [value for value in (status_temp, cooling_package, route_package) if value is not None]
    package_temp = max(package_candidates) if package_candidates else None
    conservative_candidates = [value for value in (package_temp, cooling_max) if value is not None]
    conservative_temp = max(conservative_candidates) if conservative_candidates else None

    memory_summary = memory.get("summary") if isinstance(memory.get("summary"), dict) else {}
    games_summary = games.get("summary") if isinstance(games.get("summary"), dict) else {}
    psi_some = float_value(memory_summary.get("psi_some_avg10")) or 0.0
    psi_full = float_value(memory_summary.get("psi_full_avg10")) or 0.0
    mem_available = float_value(memory_summary.get("mem_available_mib")) or 0.0
    swap_used_percent = float_value(memory_summary.get("swap_used_percent")) or 0.0
    zram_data_mib = float_value(memory_summary.get("zram_data_mib")) or 0.0
    zram_resident_mib = float_value(memory_summary.get("zram_resident_mib")) or 0.0
    memory_class = str(memory_summary.get("class") or "unknown")
    active_games = int_value(games_summary.get("active_game_processes"))
    package_critical = bool(distribution.get("package_critical"))
    broad_heat = bool(distribution.get("broad_heat"))
    routed_allowed = bool(routed_policy.get("allowed"))
    routed_unattended = bool(routed_policy.get("unattended_allowed"))
    thermal_class = str(distribution.get("thermal_class") or cooling_temp.get("class") or "unknown")
    previous_temperatures = previous_policy.get("temperatures") if isinstance(previous_policy.get("temperatures"), dict) else {}
    previous_conservative_temp = float_value(previous_temperatures.get("conservative_temp_c"))
    previous_generated_age_sec = seconds_since(previous_policy.get("generated_at"))
    warm_c = thermal_thresholds["warm_c"]
    active_low_c = thermal_thresholds["active_low_c"]
    watch_c = thermal_thresholds["watch_c"]
    hot_c = thermal_thresholds["hot_c"]
    degraded_high_c = thermal_thresholds["degraded_high_c"]
    critical_c = thermal_thresholds["critical_c"]
    absolute_fallback_c = thermal_thresholds["absolute_fallback_c"]
    sustained_window_sec = thermal_thresholds["sustained_critical_window_sec"]
    previous_recent = previous_generated_age_sec is not None and previous_generated_age_sec <= sustained_window_sec
    previous_critical = bool(previous_recent and previous_conservative_temp is not None and previous_conservative_temp >= critical_c)
    generated_at = now_iso()

    reasons: list[str] = []
    warnings: list[str] = []
    decision = "allow"
    primary_reason = "policy_allow"
    n_predict_factor = 1.0
    max_source_records: int | None = resident_default_source_cap(job, request_class)
    tier = resident_job_tier(job)

    def degrade(reason: str) -> None:
        nonlocal decision, primary_reason, n_predict_factor, max_source_records
        if decision != "fallback":
            decision = "degraded"
            primary_reason = reason
            if reason.startswith("thermal") or reason == "recent_throttle_burst":
                n_predict_factor = min(n_predict_factor, 0.55)
            else:
                n_predict_factor = min(n_predict_factor, 0.62)
            max_source_records = 1
        reasons.append(reason)

    def fallback(reason: str) -> None:
        nonlocal decision, primary_reason, n_predict_factor, max_source_records
        decision = "fallback"
        primary_reason = reason
        n_predict_factor = 0.0
        max_source_records = 0
        reasons.append(reason)

    if not status_data.get("ok"):
        fallback("resident_server_not_running")
    if active_games > 0 and request_class != "foreground":
        tiny_game_guard_probe = (
            request_class == "job"
            and tier <= 1
            and memory_class not in {"critical", "hot"}
            and mem_available >= SOFT_MEMORY_MIN_AVAILABLE_MIB
            and psi_some < 0.2
            and psi_full < 0.1
            and not broad_heat
            and not package_critical
            and (conservative_temp is None or conservative_temp < hot_c)
        )
        if tiny_game_guard_probe:
            degrade("game_guard_tiny_probe_degraded")
            warnings.append(
                "game_guard_active_tiny_probe_allowed:"
                f"active_games={active_games}:psi_some={psi_some:.3f}:psi_full={psi_full:.3f}:"
                f"mem_available_mib={mem_available:.1f}"
            )
        else:
            fallback("game_guard_active")

    if memory_class == "critical":
        if request_class == "sustained" or mem_available < SOFT_MEMORY_MIN_AVAILABLE_MIB or psi_some >= SOFT_MEMORY_PSI_SOME_HARD or psi_full >= SOFT_MEMORY_PSI_FULL_HARD:
            fallback("memory_pressure_active")
        else:
            degrade("memory_swap_critical_psi_low")
    elif memory_class == "hot":
        degrade("memory_hot")
    elif memory_class == "watch":
        watch_low_psi = (
            mem_available >= SOFT_MEMORY_MIN_AVAILABLE_MIB
            and psi_some < SOFT_MEMORY_PSI_SOME_WATCH
            and psi_full < SOFT_MEMORY_PSI_FULL_WATCH
        )
        if request_class == "sustained" or not watch_low_psi:
            degrade("memory_watch")
        else:
            reasons.append("memory_watch_low_psi_allowed")

    zram_high_no_psi = (
        swap_used_percent >= 85.0
        and psi_some < SOFT_MEMORY_PSI_SOME_HARD
        and psi_full < SOFT_MEMORY_PSI_FULL_HARD
        and zram_data_mib > 0.0
    )
    if zram_high_no_psi:
        warnings.append(
            f"zram_high_compact_signal:swap_used_percent={swap_used_percent:.3f}:"
            f"zram_data_mib={zram_data_mib:.1f}:zram_resident_mib={zram_resident_mib:.1f}"
        )
        if decision != "fallback" and request_class == "sustained":
            degrade("zram_high_sustained_compact")
        elif decision != "fallback":
            reasons.append("zram_high_low_psi_allowed")

    package_count_delta = int_value(throttle_delta.get("package_throttle_count"))
    package_time_delta = int_value(throttle_delta.get("package_throttle_total_time_ms"))
    package_count_rate = float_value(throttle_delta.get("package_throttle_count_per_sec")) or 0.0
    package_time_rate = float_value(throttle_delta.get("package_throttle_time_ms_per_sec")) or 0.0
    recent_throttle_storm = (
        bool(throttle_delta.get("available"))
        and package_count_rate > 800.0
        and package_time_rate > 2000.0
    )
    critical_now = bool(conservative_temp is not None and conservative_temp >= critical_c)
    absolute_thermal_fallback = bool(conservative_temp is not None and conservative_temp >= absolute_fallback_c)
    previous_critical_started_at = previous_temperatures.get("critical_started_at")
    critical_started_at = None
    critical_duration_sec = 0.0
    if critical_now:
        if previous_critical and previous_critical_started_at:
            critical_started_at = str(previous_critical_started_at)
            critical_duration_sec = seconds_since(critical_started_at) or 0.0
        else:
            critical_started_at = generated_at
    sustained_critical = bool(critical_now and critical_duration_sec >= sustained_window_sec)

    if conservative_temp is None:
        warnings.append("temperature_unavailable")
        if request_class in {"jobs", "sustained"}:
            degrade("temperature_unavailable_degraded")
    elif absolute_thermal_fallback:
        fallback("thermal_absolute_fallback")
    elif critical_now or package_critical:
        if request_class == "sustained" or broad_heat and recent_throttle_storm or sustained_critical and recent_throttle_storm:
            fallback("thermal_sustained_critical")
        else:
            degrade("thermal_transient_critical_spike_degraded")
    elif conservative_temp >= degraded_high_c:
        if request_class == "foreground" or tier <= 1:
            degrade("thermal_high_hot_degraded")
        else:
            degrade("thermal_high_hot_batch_compact")
    elif conservative_temp >= hot_c:
        if broad_heat and not routed_allowed:
            if conservative_temp < degraded_high_c and (request_class == "foreground" or tier <= 1 or (request_class == "job" and tier <= 2)):
                degrade("thermal_broad_heat_degraded_e2b_ecore")
            else:
                fallback("thermal_broad_heat_unroutable")
        else:
            degrade("thermal_hot_routed_degraded")
    elif conservative_temp >= watch_c:
        if broad_heat and not routed_allowed and request_class in {"jobs", "sustained"}:
            degrade("thermal_watch_broad_heat_degraded")
        else:
            reasons.append("thermal_watch_allowed")
    elif conservative_temp >= active_low_c:
        reasons.append("thermal_active_plateau_allowed")
    elif conservative_temp >= warm_c:
        reasons.append("thermal_warm_allowed")

    if package_count_delta > 0:
        warnings.append(f"thermal_throttle_delta:count={package_count_delta}:time_ms={package_time_delta}")
    if decision != "fallback" and conservative_temp is not None and recent_throttle_storm:
        if (sustained_critical or broad_heat) and request_class in {"jobs", "sustained"}:
            fallback("recent_throttle_storm_sustained_heat")
        elif conservative_temp >= hot_c:
            degrade("recent_throttle_storm_degraded")
    if decision != "fallback" and conservative_temp is not None and conservative_temp >= hot_c and package_count_delta > 1500 and package_time_delta > 250:
        degrade("recent_throttle_burst")
    if decision != "fallback" and request_class == "sustained" and conservative_temp is not None and conservative_temp >= critical_c:
        fallback("sustained_requires_subcritical_window")
    elif decision != "fallback" and request_class == "sustained" and conservative_temp is not None and conservative_temp >= hot_c:
        degrade("sustained_hot_compact")

    allowed = decision in {"allow", "degraded"}
    if decision == "allow" and not reasons:
        reasons.append("cool_routed_memory_ok")

    limits = {
            "n_predict_factor": n_predict_factor,
            "max_source_records": max_source_records,
            "single_slot_required": True,
            "queue_buildup_allowed": False,
            "route_application": "resident service already uses taskset -c 6-15; policy still records current ai cpu route",
            "spike_handling": "single critical samples degrade compact resident work; fallback requires absolute heat, sustained critical heat with throttle storm, sustained request class at the hard boundary, or broad heat plus throttle storm",
        }
    data = {
        "schema": f"{SCHEMA_PREFIX}_policy_v1",
        "version": VERSION,
        "generated_at": generated_at,
        "profile": PROFILE,
        "request": {"class": request_class, "job": job, "job_tier": tier},
        "ok": True,
        "allowed": allowed,
        "decision": decision,
        "primary_reason": primary_reason,
        "reasons": reasons,
        "warnings": warnings,
        "limits": limits,
        "temperatures": {
            "package_temp_c": package_temp,
            "conservative_temp_c": conservative_temp,
            "thermal_class": thermal_class,
            "episode": cooling_episode,
            "previous_conservative_temp_c": previous_conservative_temp,
            "previous_generated_age_sec": round(previous_generated_age_sec, 3) if previous_generated_age_sec is not None else None,
            "critical_started_at": critical_started_at,
            "critical_duration_sec": round(critical_duration_sec, 3),
            "spike_model": {
                "critical_now": critical_now,
                "previous_recent": previous_recent,
                "previous_critical": previous_critical,
                "sustained_critical": sustained_critical,
                "absolute_thermal_fallback": absolute_thermal_fallback,
                "recent_throttle_storm": recent_throttle_storm,
            },
            "thresholds": {
                **thermal_thresholds,
                "source": str(AI_CONFIG_PATH) if AI_CONFIG_PATH.exists() else "resident_defaults",
            },
        },
        "inputs": {
            "status": {
                "ok": status_data.get("ok"),
                "status": status_data.get("status"),
                "metrics": metrics,
            },
            "cooling": {
                "ok": cooling.get("ok"),
                "summary": cooling_temp,
            },
            "cpu_route": {
                "ok": cpu_route.get("ok"),
                "policy": cpu_route.get("policy"),
                "route": cpu_route.get("route"),
            },
            "memory": {
                "ok": memory.get("ok"),
                "summary": memory_summary,
            },
            "game_guard": {
                "ok": games.get("ok"),
                "summary": games_summary,
            },
            "thermal_throttle": {
                "snapshot": throttle_snapshot,
                "delta": throttle_delta,
            },
        },
        "paths": {
            "latest": str(POLICY_LATEST),
            "history_glob": str(POLICY_ROOT / "jsonl" / "YYYY" / "MM" / "YYYY-MM-DD.jsonl"),
            "research": str(RESEARCH_ROOT / "2026-05-12-thin-laptop-thermal-policy.md"),
        },
        "non_claims": [
            "This policy gates only resident requests and jobs; it does not change fan curves, power profiles, governors, or abyss-stack routing.",
            "Degraded means bounded model use with smaller prompts/output caps, not a claim that the machine is cool.",
            "A single critical temperature sample is treated as a spike signal for compact degraded work, not proof of sustained overheating by itself.",
            "When game guard is active, only tier-1 request_class=job probes may run, and only with low PSI, enough available memory, and sub-hot thermal evidence.",
        ],
    }
    if write:
        write_json(POLICY_LATEST, data)
        append_jsonl(daily_path(POLICY_ROOT / "jsonl"), data)
