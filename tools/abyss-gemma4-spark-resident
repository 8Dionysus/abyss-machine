        "bounded_hint_generator": {"hints": [{"source_id": "id", "kind": "label|hint|review_note", "text": "short text", "use_for": "human_review|brief|memory_card"}], "summary": "short summary"},
        "risk_sentinel": {"findings": [{"source_id": "id", "risk": "none|low|high_stakes|unsafe_automation|medical|emergency|weapons|privacy", "route": "e2b_ok|operator_needed|blocked_by_policy|curated_source_needed", "reason": "short reason"}], "summary": "short summary"},
        "short_doc_classifier": {"documents": [{"source_id": "id", "doc_type": "log|issue|mail|note|web_page|machine_event|unknown", "summary": "short summary <= 160 chars", "fields": [{"key": "field", "value": "value"}], "next_review": "short note"}], "summary": "short summary"},
    }
    task = {
        "query_expansion": "Generate at most two compact search queries for local recall. aliases must be []. Do not answer the source.",
        "rerank_lite": "Rank the candidate source records for usefulness to the latest local work context. Prefer fresh, sourceful, non-noisy records.",
        "source_quality_scorer": "Score whether each source record is usable, stale, duplicate, noisy, sensitive, or low_signal before model input.",
        "action_card_compiler": "Compile safe action cards from intent candidates. Never execute. confirm_required must be true.",
        "bounded_hint_generator": "Generate short labels, hints, or review notes from deterministic source records. Do not invent new facts.",
        "risk_sentinel": "Detect high-stakes or unsafe contexts and route them away from E2B answering. Route, do not answer.",
        "short_doc_classifier": "Classify short documents and extract tiny review fields without expanding content.",
    }[job]
    input_payload = {"records": records, "intent_candidates": intents}
    allowed = [str(record.get("id")) for record in records if record.get("id")]
    allowed.extend(str(item.get("source_id") or item.get("id")) for item in intents if item.get("source_id") or item.get("id"))
    return (
        "<|turn>user\n"
        f"{task} Return only valid JSON. Use exact source IDs only from ALLOWED_SOURCE_IDS. "
        "All outputs are derived candidates, not commands. Keep text short. If evidence is missing, return empty arrays.\n"
        f"ALLOWED_SOURCE_IDS: {json.dumps(sorted(set(allowed)), ensure_ascii=False)}\n"
        f"SCHEMA: {json.dumps(schema[job], ensure_ascii=False)}\n"
        f"INPUT: {json.dumps(input_payload, ensure_ascii=False)}\n"
        "<turn|>\n<|turn>model\n<|channel>final\n"
    )


