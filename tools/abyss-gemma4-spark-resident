def run_micro(limit: int = 4) -> dict[str, Any]:
    started = time.monotonic()
    state = load_json(STATE_PATH)
    raw_index = int_value(state.get("micro_job_index"), 0)
    sequence_index = raw_index % len(MICRO_JOB_SEQUENCE)
    selected_job = MICRO_JOB_SEQUENCE[sequence_index]
    next_index = (sequence_index + 1) % len(MICRO_JOB_SEQUENCE)
    next_job = MICRO_JOB_SEQUENCE[next_index]
    state["micro_job_index"] = next_index
    state["micro_last_job"] = selected_job
    state["micro_updated_at"] = now_iso()
    write_json(STATE_PATH, state)

    bounded_limit = max(1, min(int_value(limit, 4), 4))
    try:
        job_result = run_job(selected_job, limit=bounded_limit)
    except Exception as exc:  # Keep the timer alive and leave a reviewable artifact.
        job_result = {
            "ok": False,
            "status": "error",
            "error": {"type": type(exc).__name__, "message": str(exc)},
            "model": {"used": False, "fallback_used": False},
        }

    model = job_result.get("model") if isinstance(job_result.get("model"), dict) else {}
    policy = model.get("policy") if isinstance(model.get("policy"), dict) else {}
    if not policy and isinstance(model.get("gate"), dict):
        gate_policy = model["gate"].get("policy")
        policy = gate_policy if isinstance(gate_policy, dict) else {}
    summary = {
        "selected_job": selected_job,
        "next_job": next_job,
        "limit": bounded_limit,
        "status": job_result.get("status"),
        "ok": bool(job_result.get("ok")),
        "model_used": bool(model.get("used")) if model else False,
        "fallback_used": bool(model.get("fallback_used")) if model else False,
        "policy_decision": policy.get("decision"),
        "elapsed_ms": round((time.monotonic() - started) * 1000, 1),
    }
    candidates_data = resident_candidates()
    summary["candidate_readmodel"] = {
        "ok": candidates_data.get("ok"),
        "status": candidates_data.get("status"),
        "candidates": (candidates_data.get("summary") or {}).get("candidates") if isinstance(candidates_data.get("summary"), dict) else None,
    }
    data = {
        "schema": f"{SCHEMA_PREFIX}_micro_tick_v1",
        "version": VERSION,
        "generated_at": now_iso(),
        "profile": PROFILE,
        "ok": summary["ok"],
        "summary": summary,
        "rotation": {
            "sequence": MICRO_JOB_SEQUENCE,
            "sequence_index": sequence_index,
            "next_index": next_index,
        },
        "job": {
            "name": selected_job,
            "latest": str(job_latest_path(selected_job)),
            "source": job_result.get("source"),
            "feedback": job_result.get("feedback"),
            "model": {
                "used": model.get("used") if model else None,
                "fallback_used": model.get("fallback_used") if model else None,
                "parsed_job": model.get("parsed_job") if model else None,
                "policy_decision": policy.get("decision"),
                "n_predict": model.get("n_predict") if model else None,
            },
        },
        "paths": {
            "latest": str(MICRO_LATEST),
            "history_glob": str(MICRO_ROOT / "jsonl" / "YYYY" / "MM" / "YYYY-MM-DD.jsonl"),
            "selected_job_latest": str(job_latest_path(selected_job)),
            "candidates_latest": str(CANDIDATES_LATEST),
        },
        "non_claims": [
            "A micro tick is a bounded background usefulness probe, not a canonical conclusion.",
            "The resident model may use degraded or fallback mode when the machine is busy.",
        ],
    }
    if "error" in job_result:
        data["error"] = job_result.get("error")
    write_json(MICRO_LATEST, data)
    append_jsonl(daily_path(MICRO_ROOT / "jsonl"), data)
    return data


def jobs_validate() -> dict[str, Any]:
    checks: list[dict[str, Any]] = []

    def add(level: str, key: str, message: str, details: Any = None) -> None:
        item = {"level": level, "key": key, "message": message}
        if details is not None:
            item["details"] = details
        checks.append(item)

    resident_candidates(limit=256)
    latest = load_json(JOBS_LATEST)
    add("ok" if latest else "warn", "jobs_latest", "jobs latest exists", {"path": str(JOBS_LATEST)})
    inspection_before = latest.get("generated_at")
    inspection_payload = jobs_latest_payload("latest")
    status_payload = jobs_latest_payload("status")
    inspection_after = load_json(JOBS_LATEST).get("generated_at")
    commands = inspection_payload.get("commands") if isinstance(inspection_payload.get("commands"), dict) else {}
    add(
        "ok" if inspection_payload.get("read_only") is True and inspection_payload.get("mutation") is False and status_payload.get("read_only") is True and inspection_before == inspection_after else "fail",
        "cli:jobs_inspection_read_only",
        "jobs latest/status are read-only and do not advance the batch latest timestamp",
        {
            "before": inspection_before,
            "after": inspection_after,
            "latest_read_only": inspection_payload.get("read_only"),
            "status_read_only": status_payload.get("read_only"),
        },
    )
    add(
        "ok" if commands.get("run") and " jobs run " in commands.get("run") and commands.get("latest") and " jobs latest " in commands.get("latest") else "fail",
        "cli:jobs_run_explicit",
        "jobs batch execution is named explicitly and separated from read-only inspection",
        {"commands": commands},
    )
    for job in JOB_NAMES:
        path = job_latest_path(job)
        item = load_json(path)
        if not item:
            add("fail", f"job:{job}", "job latest missing or invalid", {"path": str(path)})
            continue
        add("ok" if item.get("ok") else "fail", f"job:{job}", f"{job} latest is {item.get('status')}", {"path": str(path), "source": item.get("source"), "feedback": item.get("feedback")})
        if not isinstance(item.get("feedback"), dict):
            add("warn", f"feedback:{job}", "job feedback is missing", {"path": str(path)})
        status = str(item.get("status") or "")
        result = item.get("result")
        if item.get("ok") and status.startswith("ok") and (not isinstance(result, dict) or not result):
            add("fail", f"result:{job}", "ok job has no non-empty structured result", {"path": str(path), "status": status})
        if isinstance(result, dict):
            if job == "command_grammar":
                triggers = [
                    str(trigger.get("trigger") or "")
                    for trigger in list_value(result.get("proposed_triggers"))
                    if isinstance(trigger, dict)
                ]
                placeholders = [
                    trigger
                    for trigger in triggers
                    if is_placeholder_trigger(trigger)
                ]
                add("fail" if triggers else "ok", "quality:command_grammar:triggers", "command grammar has no proposed triggers before manual router approval", {"path": str(path), "triggers": triggers, "placeholders": placeholders})
            elif job == "thermal_performance":
                material = item.get("material_excerpt") if isinstance(item.get("material_excerpt"), dict) else {}
                thresholds = resident_thermal_thresholds()
                offenders = []
                for incident in list_value(result.get("incidents")):
                    if not isinstance(incident, dict):
                        continue
                    observed = incident_observed_temperature_c(incident, material)
                    if str(incident.get("severity") or "") == "critical" and observed is not None and observed < thresholds["critical_c"]:
                        offenders.append({"summary": incident.get("summary"), "observed_temp_c": observed, "critical_c": thresholds["critical_c"]})
                add("fail" if offenders else "ok", "quality:thermal_performance:critical_threshold", "thermal critical labels obey local thresholds", {"path": str(path), "offenders": offenders})
            elif job == "storage_classifier":
                material = item.get("material_excerpt") if isinstance(item.get("material_excerpt"), dict) else {}
                storage = material.get("storage") if isinstance(material.get("storage"), dict) else {}
                expected = {
                    str(action.get("id") or "")
                    for action in list_value(storage.get("actions"))
                    if isinstance(action, dict) and action.get("id")
                }
                actual = {
                    str(entry.get("action_id") or "")
                    for entry in list_value(result.get("items"))
                    if isinstance(entry, dict) and entry.get("action_id")
                }
                missing = sorted(expected - actual)
                add("fail" if missing else "ok", "quality:storage_classifier:coverage", "storage classifier covers every compact cleanup action", {"path": str(path), "expected": len(expected), "actual": len(actual), "missing": missing})
            elif job == "daily_brief":
                qgate = result.get("quality_gate") if isinstance(result.get("quality_gate"), dict) else {}
                add("warn" if qgate.get("source_parroted_policy_label") else "ok", "quality:daily_brief:thermal_label", "daily brief does not promote source thermal labels above local thresholds", {"path": str(path), "quality_gate": qgate})
            elif job == "mcp_context_brief":
                contexts = [entry for entry in list_value(result.get("contexts")) if isinstance(entry, dict) and entry.get("source_id")]
                routes = [entry for entry in list_value(result.get("routes")) if isinstance(entry, dict) and entry.get("source_id")]
                bad_paths = [
                    entry.get("path")
                    for entry in contexts
                    if entry.get("path") and not Path(str(entry.get("path"))).exists()
                ]
                exposed = [
                    entry
                    for entry in contexts
                    if entry.get("raw_payload_exposed") is not False
                    or "raw_payload" in entry
                    or "payload" in entry
                ]
                add("ok" if contexts or status == "idle" else "warn", "quality:mcp_context_brief:contexts", "MCP context brief emits source-bound context summaries", {"path": str(path), "contexts": len(contexts)})
                add("ok" if routes or status == "idle" else "warn", "quality:mcp_context_brief:routes", "MCP context brief exposes bounded retrieval routes", {"path": str(path), "routes": len(routes)})
                add("fail" if bad_paths else "ok", "quality:mcp_context_brief:source_paths", "MCP context source paths still exist", {"path": str(path), "missing": bad_paths[:8]})
                add("fail" if exposed else "ok", "quality:mcp_context_brief:no_raw_payload", "MCP context brief does not expose raw payloads", {"path": str(path), "bad": exposed[:4]})
                health = result.get("health") if isinstance(result.get("health"), dict) else {}
                health_status = str(health.get("status") or "missing")
                add("fail" if health_status == "fail" else "warn" if health_status in {"warn", "missing"} else "ok", "quality:mcp_context_brief:health", "MCP context health sentinel is clean", {"path": str(path), "health": health.get("summary"), "status": health_status})
            elif job == "query_expansion":
                queries = [item for item in list_value(result.get("queries")) if isinstance(item, dict) and item.get("source_id") and item.get("query")]
                add("ok" if queries or status == "idle" else "warn", "quality:query_expansion:queries", "query expansion emits source-bound queries when material exists", {"path": str(path), "queries": len(queries)})
            elif job == "rerank_lite":
                ranked = [item for item in list_value(result.get("ranked")) if isinstance(item, dict) and item.get("source_id")]
                ranks = [int_value(item.get("rank")) for item in ranked]
                add("ok" if ranked and sorted(ranks) == ranks else "warn", "quality:rerank_lite:ranked", "rerank-lite emits ordered source-bound candidates", {"path": str(path), "ranked": len(ranked), "ranks": ranks})
            elif job == "source_quality_scorer":
                rows = [item for item in list_value(result.get("records")) if isinstance(item, dict)]
                bad = [item for item in rows if item.get("classification") not in {"usable", "stale", "duplicate", "noise", "sensitive", "low_signal"}]
                add("fail" if bad else "ok", "quality:source_quality_scorer:classes", "source quality classes stay in contract", {"path": str(path), "records": len(rows), "bad": bad[:4]})
            elif job == "operator_input_context":
                contexts = [item for item in list_value(result.get("contexts")) if isinstance(item, dict) and item.get("source_id")]
                lanes = [item for item in list_value(result.get("lanes")) if isinstance(item, dict) and item.get("source_id")]
                exposed = [
                    item
                    for item in contexts + lanes
                    if item.get("raw_text_exposed") is True
                    or item.get("text") is not None
                    or item.get("raw_text") is not None
                ]
                add("ok" if contexts or lanes or status == "idle" else "warn", "quality:operator_input_context:material", "operator input context emits source-bound contexts or lanes", {"path": str(path), "contexts": len(contexts), "lanes": len(lanes)})
                add("fail" if exposed else "ok", "quality:operator_input_context:no_raw_text", "operator input context does not expose raw typed text", {"path": str(path), "bad": exposed[:4]})
            elif job == "resident_quality_eval":
                rows = [item for item in list_value(result.get("evaluated_jobs")) if isinstance(item, dict)]
                add("ok" if rows else "warn", "quality:resident_quality_eval:coverage", "resident quality eval reviews latest job artifacts", {"path": str(path), "evaluated_jobs": len(rows)})
            elif job == "action_card_compiler":
                cards = [item for item in list_value(result.get("cards")) if isinstance(item, dict)]
                unsafe = [item for item in cards if item.get("confirm_required") is not True or item.get("route") in {"deterministic", "e2b_ok"} and item.get("risk") not in {"none", "low"}]
                add("fail" if unsafe else "ok", "quality:action_card_compiler:no_execute", "action cards require confirmation and route risky cards away", {"path": str(path), "cards": len(cards), "unsafe": unsafe[:4]})
            elif job == "bounded_hint_generator":
                hints = [item for item in list_value(result.get("hints")) if isinstance(item, dict)]
                too_long = [item for item in hints if len(str(item.get("text") or "")) > 260]
                add("fail" if too_long else "ok", "quality:bounded_hint_generator:short", "bounded hints remain short", {"path": str(path), "hints": len(hints), "too_long": len(too_long)})
            elif job == "risk_sentinel":
                findings = [item for item in list_value(result.get("findings")) if isinstance(item, dict)]
                bad_routes = [item for item in findings if item.get("risk") not in {"none", "low"} and item.get("route") == "e2b_ok"]
                add("fail" if bad_routes else "ok", "quality:risk_sentinel:routes", "risk sentinel routes high-risk findings away from E2B answering", {"path": str(path), "findings": len(findings), "bad_routes": bad_routes[:4]})
            elif job == "short_doc_classifier":
                docs = [item for item in list_value(result.get("documents")) if isinstance(item, dict) and item.get("source_id")]
                add("ok" if docs or status == "idle" else "warn", "quality:short_doc_classifier:docs", "short doc classifier emits source-bound documents", {"path": str(path), "documents": len(docs)})
            elif job in EXPERIMENTAL_LANE_JOBS:
                add("ok" if status == "prepared" else "warn", f"quality:{job}:prepared", "experimental lane is prepared but not promoted", {"path": str(path), "status": status, "result_status": result.get("status")})
        if status == "skipped":
            add("warn", f"skipped:{job}", "job latest is skipped; gate fallback should usually preserve material", {"path": str(path)})
    service = service_state()
    add("ok" if service.get("jobs_timer", {}).get("active") == "active" else "warn", "jobs_timer", "jobs timer is active", service.get("jobs_timer"))
    add("ok" if service.get("micro_timer", {}).get("active") == "active" else "warn", "micro_timer", "micro timer is active", service.get("micro_timer"))
    candidate_validation = resident_candidates_validate()
    add("ok" if candidate_validation.get("ok") else "fail", "candidates_validate", "resident candidate read-model validates", candidate_validation.get("summary"))
    fails = sum(1 for item in checks if item["level"] == "fail")
    warnings = sum(1 for item in checks if item["level"] == "warn")
    data = {
        "schema": f"{SCHEMA_PREFIX}_jobs_validate_v1",
        "version": VERSION,
        "generated_at": now_iso(),
        "profile": PROFILE,
        "ok": fails == 0,
        "checks": checks,
        "summary": {"fails": fails, "warnings": warnings, "checks": len(checks), "jobs": len(JOB_NAMES)},
        "paths": {"latest": str(JOBS_ROOT / "validate" / "latest.json"), "jobs_latest": str(JOBS_LATEST), "root": str(JOBS_ROOT)},
    }
    write_json(JOBS_ROOT / "validate" / "latest.json", data)
    return data


def increment_count(container: dict[str, int], key: Any) -> None:
    name = str(key or "unknown")
    container[name] = int(container.get(name, 0)) + 1


def summarize_job_history() -> list[dict[str, Any]]:
    stats: dict[str, dict[str, Any]] = {
        job: {
            "job": job,
            "records": 0,
            "first": None,
            "latest": None,
            "statuses": {},
            "reasons": {},
            "model_used": 0,
            "fallback_used": 0,
            "parsed_job": 0,
        }
        for job in JOB_NAMES
    }
    for path in sorted(JOBS_ROOT.glob("*/jsonl/*/*/*.jsonl")):
        try:
            job = path.relative_to(JOBS_ROOT).parts[0]
        except (ValueError, IndexError):
            continue
        if job not in stats:
            continue
        try:
            lines = path.read_text(encoding="utf-8").splitlines()
        except OSError:
            continue
        for line in lines:
            try:
                item = json.loads(line)
            except json.JSONDecodeError:
                continue
            if not isinstance(item, dict) or item.get("schema") != f"{SCHEMA_PREFIX}_job_v1":
                continue
            if str(item.get("job") or job) != job:
                continue
            stat = stats[job]
            generated_at = item.get("generated_at")
            stat["records"] += 1
            if generated_at and (stat["first"] is None or str(generated_at) < str(stat["first"])):
                stat["first"] = generated_at
            if generated_at and (stat["latest"] is None or str(generated_at) > str(stat["latest"])):
                stat["latest"] = generated_at
            increment_count(stat["statuses"], item.get("status"))
            model = item.get("model") if isinstance(item.get("model"), dict) else {}
            if model.get("used") is True:
                stat["model_used"] += 1
            if model.get("fallback_used") is True:
                stat["fallback_used"] += 1
            if model.get("parsed_job") is True:
                stat["parsed_job"] += 1
            gate = model.get("gate") if isinstance(model.get("gate"), dict) else {}
            policy = model.get("policy") if isinstance(model.get("policy"), dict) else {}
            reason = item.get("reason") or gate.get("reason") or policy.get("primary_reason") or "none"
            increment_count(stat["reasons"], reason)
    result: list[dict[str, Any]] = []
    for stat in stats.values():
        result.append({
            **{key: value for key, value in stat.items() if key not in {"statuses", "reasons"}},
            "statuses": [{"status": key, "count": value} for key, value in sorted(stat["statuses"].items())],
            "reasons": [{"reason": key, "count": value} for key, value in sorted(stat["reasons"].items(), key=lambda item: (-item[1], item[0]))],
        })
    return result


