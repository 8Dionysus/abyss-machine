def extract_json_object(text: str) -> dict[str, Any] | None:
    decoder = json.JSONDecoder()
    best: tuple[int, dict[str, Any]] | None = None
    for index, char in enumerate(text):
        if char != "{":
            continue
        try:
            value, end = decoder.raw_decode(text[index:])
        except json.JSONDecodeError:
            continue
        if isinstance(value, dict) and (best is None or end > best[0]):
            best = (end, value)
    return best[1] if best else None


JSON_OBJECT_SCHEMA = {"type": "object"}


def acquire_completion_slot(timeout: float | None = None) -> tuple[Any | None, dict[str, Any]]:
    wait_timeout = COMPLETION_LOCK_TIMEOUT_SEC if timeout is None else timeout
    COMPLETION_LOCK.parent.mkdir(parents=True, exist_ok=True)
    handle = COMPLETION_LOCK.open("a+", encoding="utf-8")
    started = time.monotonic()
    while True:
        try:
            fcntl.flock(handle.fileno(), fcntl.LOCK_EX | fcntl.LOCK_NB)
            waited_ms = round((time.monotonic() - started) * 1000, 1)
            handle.seek(0)
            handle.truncate()
            handle.write(json.dumps({"pid": os.getpid(), "acquired_at": now_iso()}, ensure_ascii=False) + "\n")
            handle.flush()
            return handle, {"acquired": True, "wait_ms": waited_ms, "path": str(COMPLETION_LOCK)}
        except BlockingIOError:
            if time.monotonic() - started >= wait_timeout:
                handle.close()
                return None, {
                    "acquired": False,
                    "wait_ms": round((time.monotonic() - started) * 1000, 1),
                    "timeout_sec": wait_timeout,
                    "path": str(COMPLETION_LOCK),
                }
            time.sleep(0.25)


def completion(prompt: str, n_predict: int = 512, timeout: float = 90.0, json_schema: dict[str, Any] | None = None) -> dict[str, Any]:
    payload = {"prompt": prompt, "n_predict": n_predict, "temperature": 0.1, "top_p": 0.9, "cache_prompt": True, "stop": ["<|turn>", "<|end|>", "</s>"]}
    if json_schema:
        payload["json_schema"] = json_schema
    lock_handle, lock_info = acquire_completion_slot()
    if lock_handle is None:
        return {"ok": False, "error": "completion_slot_lock_timeout", "_http": {"ok": False}, "_slot_lock": lock_info, "_content": ""}
    try:
        data = http_json("POST", "/completion", payload=payload, timeout=timeout)
        content = data.get("content") or data.get("response") or data.get("text") or ""
        data["_content"] = content if isinstance(content, str) else json.dumps(content, ensure_ascii=False)
        data["_slot_lock"] = lock_info
        return data
    finally:
        fcntl.flock(lock_handle.fileno(), fcntl.LOCK_UN)
        lock_handle.close()


def completion_json(prompt: str, n_predict: int = 512, timeout: float = 90.0, json_schema: dict[str, Any] | None = None) -> tuple[dict[str, Any], dict[str, Any] | None]:
    out = completion(prompt, n_predict=n_predict, timeout=timeout, json_schema=json_schema or JSON_OBJECT_SCHEMA)
    parsed = extract_json_object(str(out.get("_content") or ""))
    return out, parsed


def completion_json_relaxed(prompt: str, n_predict: int = 512, timeout: float = 90.0) -> tuple[dict[str, Any], dict[str, Any] | None]:
    out = completion(prompt, n_predict=n_predict, timeout=timeout, json_schema=None)
    parsed = extract_json_object(str(out.get("_content") or ""))
    return out, parsed


def float_value(value: Any) -> float | None:
    try:
        if value is None or value == "":
            return None
        return float(value)
    except (TypeError, ValueError):
        return None


def int_value(value: Any, default: int = 0) -> int:
    try:
        return int(value)
    except (TypeError, ValueError):
        return default


def thermal_throttle_snapshot() -> dict[str, Any]:
    totals = {
        "core_throttle_count": 0,
        "core_throttle_total_time_ms": 0,
        "core_throttle_max_time_ms": 0,
        "package_throttle_count": 0,
        "package_throttle_total_time_ms": 0,
        "package_throttle_max_time_ms": 0,
    }
    cpus = 0
    for cpu_dir in sorted(Path("/sys/devices/system/cpu").glob("cpu[0-9]*"), key=lambda item: item.name):
        throttle_dir = cpu_dir / "thermal_throttle"
        if not throttle_dir.exists():
            continue
        cpus += 1
        for key in totals:
            path = throttle_dir / key
            try:
                value = int(path.read_text(encoding="utf-8").strip())
            except (OSError, ValueError):
                continue
            if key.endswith("_max_time_ms"):
                totals[key] = max(totals[key], value)
            else:
                totals[key] += value
    return {"generated_at": now_iso(), "cpus_seen": cpus, "totals": totals}


def thermal_throttle_delta(current: dict[str, Any], previous_policy: dict[str, Any]) -> dict[str, Any]:
    previous = (((previous_policy.get("inputs") or {}).get("thermal_throttle") or {}).get("snapshot") or {})
    current_totals = current.get("totals") if isinstance(current.get("totals"), dict) else {}
    previous_totals = previous.get("totals") if isinstance(previous.get("totals"), dict) else {}
    delta: dict[str, Any] = {}
    for key, value in current_totals.items():
        prior = previous_totals.get(key)
        if isinstance(value, int) and isinstance(prior, int) and not key.endswith("_max_time_ms"):
            delta[key] = max(0, value - prior)
    delta["previous_generated_at"] = previous.get("generated_at")
    delta["available"] = bool(previous_totals)
    current_time = parse_iso_timestamp(current.get("generated_at"))
    previous_time = parse_iso_timestamp(previous.get("generated_at"))
    if current_time is not None and previous_time is not None:
        window_sec = max(0.001, (current_time - previous_time).total_seconds())
        delta["window_sec"] = round(window_sec, 3)
        package_count = int_value(delta.get("package_throttle_count"))
        package_time = int_value(delta.get("package_throttle_total_time_ms"))
        delta["package_throttle_count_per_sec"] = round(package_count / window_sec, 3)
        delta["package_throttle_time_ms_per_sec"] = round(package_time / window_sec, 3)
    return delta


