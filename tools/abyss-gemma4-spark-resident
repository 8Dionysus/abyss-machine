def preflight(force: bool = False) -> dict[str, Any]:
    metrics = current_metrics()
    thermal_thresholds = resident_thermal_thresholds()
    checks: list[dict[str, Any]] = []

    def add(level: str, key: str, message: str, details: Any = None) -> None:
        item = {"level": level, "key": key, "message": message}
        if details is not None:
            item["details"] = details
        checks.append(item)

    live = health()
    if EXTERNAL_ENDPOINT:
        add("ok" if live.get("ok") else "fail", "external_endpoint", "stack-owned Gemma4 endpoint is healthy", live)
        add("ok" if MODEL_PATH.exists() else "warn", "model_file", "Gemma4 E2B model file exists for the stack bind mount", {"path": str(MODEL_PATH), "size_bytes": MODEL_PATH.stat().st_size if MODEL_PATH.exists() else None})
        add("ok" if LLAMA_SERVER.exists() and os.access(LLAMA_SERVER, os.X_OK) else "warn", "llama_server", "local llama-server exists only for explicit rollback/fallback", {"path": str(LLAMA_SERVER), "serving": serving_payload()})
    else:
        add("ok" if MODEL_PATH.exists() else "fail", "model_file", "Gemma4 E2B model file exists", {"path": str(MODEL_PATH), "size_bytes": MODEL_PATH.stat().st_size if MODEL_PATH.exists() else None})
        add("ok" if LLAMA_SERVER.exists() and os.access(LLAMA_SERVER, os.X_OK) else "fail", "llama_server", "llama-server executable exists", {"path": str(LLAMA_SERVER)})
    if live.get("ok"):
        add("ok", "already_running", "configured Gemma4 endpoint is already healthy", live.get("health", {}).get("_http"))

    temp = metrics.get("package_temp_c")
    if isinstance(temp, (int, float)):
        if temp >= thermal_thresholds["start_block_c"] and not live.get("ok") and not EXTERNAL_ENDPOINT:
            add("fail" if not force else "warn", "thermal_gate", "package temperature is at the hard emergency boundary for a new resident start", {"package_temp_c": temp, "threshold_c": thermal_thresholds["start_block_c"], "thresholds": thermal_thresholds})
        elif temp >= thermal_thresholds["start_warn_c"]:
            add("warn", "thermal_gate", "package temperature is in watch range; resident start remains allowed with compact policy routing", {"package_temp_c": temp, "threshold_c": thermal_thresholds["start_warn_c"], "thresholds": thermal_thresholds})
        else:
            add("ok", "thermal_gate", "package temperature allows resident start", {"package_temp_c": temp, "thresholds": thermal_thresholds})
    else:
        add("warn", "thermal_gate", "package temperature unavailable")

    power = metrics.get("power", {})
    if power.get("on_ac") is False and power.get("profile") == "power-saver" and not live.get("ok") and not EXTERNAL_ENDPOINT:
        add("fail" if not force else "warn", "power_gate", "battery power-saver mode blocks new resident start", power)
    else:
        add("ok", "power_gate", "power profile allows resident candidate", power)

    memory = run_json(["abyss-machine", "memory", "pressure", "--json"], timeout=18.0)
    memory_summary = memory.get("summary") if isinstance(memory.get("summary"), dict) else {}
    memory_class = memory_summary.get("class")
    if memory_class == "critical" and not live.get("ok") and not EXTERNAL_ENDPOINT:
        add("fail" if not force else "warn", "memory_gate", "memory pressure is critical", memory_summary)
    elif memory_class in {"hot", "watch"}:
        add("warn", "memory_gate", "memory pressure is elevated; allow with monitoring", memory_summary)
    else:
        add("ok" if memory.get("ok") else "warn", "memory_gate", "memory pressure allows resident candidate", memory_summary or memory)

    games = run_json(["abyss-machine", "processes", "game-guard", "--json"], timeout=18.0)
    games_summary = games.get("summary") if isinstance(games.get("summary"), dict) else {}
    if int(games_summary.get("active_game_processes") or 0) > 0 and not live.get("ok") and not EXTERNAL_ENDPOINT:
        add("fail" if not force else "warn", "game_gate", "active game process blocks new resident start", games_summary)
    else:
        add("ok", "game_gate", "no active game process blocks resident candidate", games_summary)

    fails = [item for item in checks if item["level"] == "fail"]
    warnings = [item for item in checks if item["level"] == "warn"]
    data = {
        "schema": f"{SCHEMA_PREFIX}_preflight_v1",
        "version": VERSION,
        "generated_at": now_iso(),
        "profile": PROFILE,
        "status": "allow" if not fails else "blocked",
        "ok": not fails,
        "force": force,
        "checks": checks,
        "summary": {"fails": len(fails), "warnings": len(warnings), "checks": len(checks)},
        "metrics": metrics,
        "thermal_thresholds": thermal_thresholds,
        "non_claims": ["A blocked preflight is a launch gate, not a service failure."],
    }
    write_json(ROOT / "preflight" / "latest.json", data)
    append_jsonl(daily_path(EVENT_ROOT), {"event": "preflight", **data})
    return data


def llama_command() -> list[str]:
    cmd = [
        "taskset", "-c", CPUSET, str(LLAMA_SERVER),
        "-m", str(MODEL_PATH), "-ngl", "99", "-c", os.environ.get("ABYSS_GEMMA4_SPARK_CTX", "4096"),
        "-b", os.environ.get("ABYSS_GEMMA4_SPARK_BATCH", "1024"), "-ub", os.environ.get("ABYSS_GEMMA4_SPARK_UBATCH", "256"),
        "-t", os.environ.get("ABYSS_GEMMA4_SPARK_THREADS", "4"), "-tb", os.environ.get("ABYSS_GEMMA4_SPARK_THREADS_BATCH", "4"),
        "--threads-http", "2", "--host", HOST, "--port", str(PORT), "-np", "1",
        "--cache-prompt", "-cram", os.environ.get("ABYSS_GEMMA4_SPARK_CACHE_RAM_MIB", "512"),
        "--metrics", "--slots", "--jinja", "--reasoning", "off", "--reasoning-budget", "0", "--reasoning-format", "none",
        "--no-webui", "--log-file", str(SERVER_LOG),
    ]
    cache_type_k = os.environ.get("ABYSS_GEMMA4_SPARK_CACHE_TYPE_K", "").strip()
    cache_type_v = os.environ.get("ABYSS_GEMMA4_SPARK_CACHE_TYPE_V", "").strip()
    sleep_idle_seconds = os.environ.get("ABYSS_GEMMA4_SPARK_SLEEP_IDLE_SECONDS", "").strip()
    slot_save_path = os.environ.get("ABYSS_GEMMA4_SPARK_SLOT_SAVE_PATH", "").strip()
    if cache_type_k:
        cmd.extend(["-ctk", cache_type_k])
    if cache_type_v:
        cmd.extend(["-ctv", cache_type_v])
    if sleep_idle_seconds:
        cmd.extend(["--sleep-idle-seconds", sleep_idle_seconds])
    if slot_save_path:
        Path(slot_save_path).mkdir(parents=True, exist_ok=True)
        cmd.extend(["--slot-save-path", slot_save_path])
    return cmd


def serve(args: argparse.Namespace) -> int:
    ensure_dirs()
    if EXTERNAL_ENDPOINT and not ALLOW_LOCAL_FALLBACK:
        live = health()
        record = {
            "schema": f"{SCHEMA_PREFIX}_serve_external_v1",
            "version": VERSION,
            "generated_at": now_iso(),
            "profile": PROFILE,
            "status": "external_endpoint_running" if live.get("ok") else "external_endpoint_unavailable",
            "ok": bool(live.get("ok")),
            "serving": serving_payload(),
            "health": live,
            "non_claims": [
                "This command does not launch a host llama-server while serving_owner is external.",
                "abyss-stack owns the live serving endpoint; abyss-machine records evidence and derived jobs.",
            ],
        }
        write_json(STATUS_LATEST, record)
        append_jsonl(daily_path(EVENT_ROOT), {"event": "serve_external", **record})
        return 0
    pf = preflight(force=bool(args.force))
    if not pf.get("ok"):
        record = {"schema": f"{SCHEMA_PREFIX}_serve_skip_v1", "version": VERSION, "generated_at": now_iso(), "profile": PROFILE, "status": "blocked", "reason": "preflight_blocked", "preflight_summary": pf.get("summary")}
        write_json(STATUS_LATEST, record)
        append_jsonl(daily_path(EVENT_ROOT), {"event": "serve_skip", **record})
        return 0
    if health().get("ok"):
        record = {"schema": f"{SCHEMA_PREFIX}_serve_skip_v1", "version": VERSION, "generated_at": now_iso(), "profile": PROFILE, "status": "already_running", "base_url": BASE_URL}
        write_json(STATUS_LATEST, record)
        append_jsonl(daily_path(EVENT_ROOT), {"event": "serve_skip", **record})
        return 0
    cmd = llama_command()
    record = {"schema": f"{SCHEMA_PREFIX}_serve_start_v1", "version": VERSION, "generated_at": now_iso(), "profile": PROFILE, "status": "starting", "base_url": BASE_URL, "command": cmd, "log": str(SERVER_LOG)}
    write_json(STATUS_LATEST, record)
    append_jsonl(daily_path(EVENT_ROOT), {"event": "serve_start", **record})
    env = os.environ.copy()
    env.update({"XDG_CACHE_HOME": str(machine_cache_root() / "home" / machine_user() / "cache"), "HF_HOME": str(machine_cache_root() / "ai/huggingface"), "TOKENIZERS_PARALLELISM": "false", "OMP_NUM_THREADS": "4", "MKL_NUM_THREADS": "4", "OPENBLAS_NUM_THREADS": "4", "NUMEXPR_NUM_THREADS": "4"})
    os.execvpe(cmd[0], cmd, env)
    return 1


