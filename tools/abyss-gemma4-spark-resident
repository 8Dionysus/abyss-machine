def normalize_source_ids(values: Any, allowed: set[str]) -> list[str]:
    result = []
    for value in list_value(values):
        text = str(value)
        if text in allowed and text not in result:
            result.append(text)
    return result


def normalize_dictation_bundle(payload: dict[str, Any] | None, source_ids: list[str]) -> dict[str, Any]:
    allowed = set(source_ids)
    payload = payload if isinstance(payload, dict) else {}
    quality = payload.get("dictation_quality") if isinstance(payload.get("dictation_quality"), dict) else {}
    work = payload.get("daily_work_blocks") if isinstance(payload.get("daily_work_blocks"), dict) else {}
    intents = payload.get("intent_candidates") if isinstance(payload.get("intent_candidates"), dict) else {}
    grammar = payload.get("command_grammar") if isinstance(payload.get("command_grammar"), dict) else {}

    quality_issues = []
    for item in list_value(quality.get("quality_issues")):
        if not isinstance(item, dict):
            continue
        sid = str(item.get("source_id") or "")
        if sid not in allowed:
            continue
        quality_issues.append({
            "source_id": sid,
            "issue_type": item.get("issue_type") or "unknown",
            "excerpt": str(item.get("excerpt") or "")[:300],
            "suspected_fix": str(item.get("suspected_fix") or "")[:300],
            "confidence": item.get("confidence") or "low",
        })
    vocabulary_candidates = []
    for item in list_value(quality.get("vocabulary_candidates")):
        if not isinstance(item, dict):
            continue
        ids = normalize_source_ids(item.get("source_ids"), allowed)
        if not ids:
            continue
        vocabulary_candidates.append({"term": str(item.get("term") or "")[:120], "source_ids": ids, "reason": str(item.get("reason") or "")[:300]})

    blocks = []
    for item in list_value(work.get("blocks")):
        if not isinstance(item, dict):
            continue
        ids = normalize_source_ids(item.get("source_ids"), allowed)
        if not ids:
            continue
        blocks.append({
            "block_id": str(item.get("block_id") or stable_id("block", item))[:80],
            "topic": str(item.get("topic") or "")[:160],
            "summary": str(item.get("summary") or "")[:600],
            "source_ids": ids,
            "state": item.get("state") or "context",
            "next_review": str(item.get("next_review") or "")[:300],
        })

    candidates = []
    for item in list_value(intents.get("candidates")):
        if not isinstance(item, dict):
            continue
        sid = str(item.get("source_id") or "")
        if sid not in allowed:
            continue
        kind = str(item.get("kind") or "context")
        if kind not in {"possible_task", "decision", "deferred", "open_question", "context"}:
            kind = "context"
        candidates.append({
            "source_id": sid,
            "kind": kind,
            "text": str(item.get("text") or "")[:500],
            "confidence": item.get("confidence") or "low",
            "execute": False,
        })

    patterns = []
    for item in list_value(grammar.get("patterns")):
        if not isinstance(item, dict):
            continue
        ids = normalize_source_ids(item.get("source_ids"), allowed)
        if not ids:
            continue
        patterns.append({
            "phrase": str(item.get("phrase") or "")[:160],
            "normalized_intent": str(item.get("normalized_intent") or "")[:160],
            "source_ids": ids,
            "risk": item.get("risk") or "medium",
        })

    return {
        "dictation_quality": {
            "quality_issues": quality_issues,
            "vocabulary_candidates": vocabulary_candidates,
            "punctuation_patterns": [str(item)[:300] for item in list_value(quality.get("punctuation_patterns"))[:12]],
            "calibration_notes": [str(item)[:300] for item in list_value(quality.get("calibration_notes"))[:12]],
        },
        "daily_work_blocks": {"blocks": blocks},
        "intent_candidates": {"candidates": candidates},
        "command_grammar": sanitize_command_grammar_result({
            "patterns": patterns,
            "proposed_triggers": [
                {"trigger": str(item.get("trigger") or "")[:240], "use_case": str(item.get("use_case") or "")[:240], "safety": str(item.get("safety") or "")[:240]}
                for item in list_value(grammar.get("proposed_triggers")) if isinstance(item, dict)
            ][:12],
            "safety_notes": [str(item)[:300] for item in list_value(grammar.get("safety_notes"))[:12]],
        }),
    }


def fallback_dictation_bundle(items: list[dict[str, Any]]) -> dict[str, Any]:
    quality_issues = []
    vocabulary: dict[str, set[str]] = {}
    candidates = []
    blocks = []
    patterns = []
    task_re = re.compile(r"\b(надо|нужно|давай|сделай|реализ|проверь|протест|испытай|хочу|добав|запусти)\w*", re.IGNORECASE)
    term_re = re.compile(r"\b([A-Za-zА-Яа-я0-9_.-]*(?:Abyss|Agents|AGENTS|DESIGN|E2B|Q4|Q5|Q6|TTS|STT|JSON|LLM|OpenVINO|Codex|Gemma)[A-Za-zА-Яа-я0-9_.-]*)\b")
    for item in items:
        sid = str(item.get("id") or "")
        text = str(item.get("text") or "")
        if not sid or not text:
            continue
        lowered = text.lower()
        if any(needle in lowered for needle in ("опромт", "опромтов", "agentsmd", "agents.amd", "чересчур", "припин", "затест", "пройдись")):
            quality_issues.append({
                "source_id": sid,
                "issue_type": "word",
                "excerpt": text[:220],
                "suspected_fix": "",
                "confidence": "medium",
            })
        if text and text[-1] not in ".!?…":
            quality_issues.append({
                "source_id": sid,
                "issue_type": "punctuation",
                "excerpt": text[-220:],
                "suspected_fix": "Проверить завершающий знак препинания.",
                "confidence": "low",
            })
        for match in term_re.findall(text):
            vocabulary.setdefault(match, set()).add(sid)
        if task_re.search(text):
            candidates.append({
                "source_id": sid,
                "kind": "possible_task",
                "text": text[:500],
                "confidence": "medium",
                "execute": False,
            })
            patterns.append({
                "phrase": task_re.search(text).group(0),
                "normalized_intent": "operator_request_candidate",
                "source_ids": [sid],
                "risk": "medium",
            })
    if items:
        blocks.append({
            "block_id": stable_id("block", [item.get("id") for item in items]),
            "topic": "resident E2B фоновые задачи",
            "summary": "Свежие диктовки касаются запуска фоновых задач, тестов, материальных данных и обратной связи.",
            "source_ids": [str(item.get("id")) for item in items if item.get("id")][:12],
            "state": "active",
            "next_review": "Сверить, какие кандидаты действительно отражают рабочий контекст.",
        })
    return {
        "dictation_quality": {
            "quality_issues": quality_issues[:12],
            "vocabulary_candidates": [{"term": term, "source_ids": sorted(ids), "reason": "Технический или проектный термин из диктовки."} for term, ids in sorted(vocabulary.items())[:16]],
