def eval_add(
    checks: list[dict[str, Any]],
    family: str,
    key: str,
    passed: bool,
    message: str,
    details: Any = None,
    *,
    weight: float = 1.0,
    severity: str = "fail",
) -> None:
    item = {
        "family": family,
        "level": "ok" if passed else "warn" if severity == "warn" else "fail",
        "key": key,
        "message": message,
        "weight": round(max(0.1, float_value(weight) or 1.0), 3),
    }
    if details is not None:
        item["details"] = details
    checks.append(item)


def sourceish_token(value: Any) -> str:
    text = str(value or "").strip()
    if not text or len(text) > 260:
        return ""
    if re.search(r"[A-Za-z0-9][A-Za-z0-9._:/@+-]{2,}", text):
        return text
    return ""


def collect_sourceish_ids(value: Any, out: set[str] | None = None) -> set[str]:
    if out is None:
        out = set()
    if isinstance(value, dict):
        for key, item in value.items():
            if key in {"id", "event_id", "source_id", "source_ids", "source_refs", "refs", "evidence", "action_id", "job", "path"}:
                for raw in list_value(item):
                    token = sourceish_token(raw)
                    if token:
                        out.add(token)
            collect_sourceish_ids(item, out)
    elif isinstance(value, list):
        for item in value:
            collect_sourceish_ids(item, out)
    else:
        token = sourceish_token(value)
        if token:
            out.add(token)
    return out


def candidate_source_ids(candidate: dict[str, Any]) -> list[str]:
    ids: list[str] = []
    for value in [candidate.get("source_id")] + list_value(candidate.get("source_ids")):
        token = sourceish_token(value)
        if token and token not in ids:
            ids.append(token)
    return ids


def synthetic_source_id_ok(candidate: dict[str, Any], source_id: str) -> bool:
    source_job = str(candidate.get("source_job") or "")
    if source_job == "resident_quality_eval" and source_id.startswith("job:"):
        return source_id.removeprefix("job:") in set(JOB_NAMES)
    if source_job == "thermal_performance" and source_id.startswith("thermal_performance:"):
        return True
    payload = candidate.get("payload") if isinstance(candidate.get("payload"), dict) else {}
    if source_job == "daily_brief" and source_id.startswith("daily_brief:"):
        return payload.get("source_refs_missing") is True and candidate.get("review_required") is True
    return False


def candidate_provenance(candidate: dict[str, Any], job_item: dict[str, Any], evidence_ids: set[str]) -> dict[str, Any]:
    ids = candidate_source_ids(candidate)
    missing = [
        source_id
        for source_id in ids
        if source_id not in evidence_ids and not synthetic_source_id_ok(candidate, source_id)
    ]
    return {
        "ok": bool(ids) and not missing,
        "source_ids": ids,
        "missing": missing,
        "source_job": candidate.get("source_job"),
        "source_artifact": candidate.get("source_artifact") or str(job_latest_path(str(candidate.get("source_job") or ""))),
        "artifact_exists": bool(job_item),
    }


def summarize_eval_families(checks: list[dict[str, Any]]) -> dict[str, dict[str, Any]]:
    families: dict[str, dict[str, Any]] = {}
    for family in EVAL_FAMILIES:
        family_checks = [item for item in checks if item.get("family") == family]
        total_weight = sum(float_value(item.get("weight")) or 1.0 for item in family_checks)
        earned = 0.0
        for item in family_checks:
            weight = float_value(item.get("weight")) or 1.0
            if item.get("level") == "ok":
                earned += weight
            elif item.get("level") == "warn":
                earned += weight * 0.5
        fails = sum(1 for item in family_checks if item.get("level") == "fail")
        warnings = sum(1 for item in family_checks if item.get("level") == "warn")
        families[family] = {
            "checks": len(family_checks),
            "fails": fails,
            "warnings": warnings,
            "score": round(earned / total_weight, 3) if total_weight else 0.0,
            "status": "fail" if fails else "warn" if warnings else "ok",
        }
    return families


def load_recent_evals_history(limit: int = 20) -> list[dict[str, Any]]:
    today = daily_path(EVALS_ROOT / "jsonl")
    rows: list[dict[str, Any]] = []
    try:
        lines = today.read_text(encoding="utf-8").splitlines()
    except OSError:
        return rows
    for line in lines[-max(1, limit):]:
        try:
            value = json.loads(line)
        except json.JSONDecodeError:
            continue
        if isinstance(value, dict):
            rows.append(value)
    return rows[-max(1, limit):]


def lane_quality_summary(candidates: list[dict[str, Any]]) -> dict[str, dict[str, Any]]:
    lanes: dict[str, dict[str, Any]] = {}
    for candidate in candidates:
        job = str(candidate.get("source_job") or "unknown")
        lane = lanes.setdefault(job, {
            "candidates": 0,
            "heartbeat_candidates": 0,
            "review_required": 0,
            "e4b_review_eligible": 0,
            "utility_total": 0.0,
            "utility_count": 0,
            "stale_candidates": 0,
            "medium_or_higher_correctness_risk": 0,
        })
        lane["candidates"] += 1
        if int_value(candidate.get("heartbeat_priority"), 0) > 0:
            lane["heartbeat_candidates"] += 1
        if candidate.get("review_required") is True:
            lane["review_required"] += 1
        if candidate.get("e4b_review_eligible") is True:
            lane["e4b_review_eligible"] += 1
        utility = float_value(candidate.get("utility_score"))
        if utility is not None:
            lane["utility_total"] += utility
            lane["utility_count"] += 1
        if candidate.get("freshness_class") == "stale":
            lane["stale_candidates"] += 1
        if str(candidate.get("correctness_risk") or "") in {"medium", "high"}:
            lane["medium_or_higher_correctness_risk"] += 1
    result: dict[str, dict[str, Any]] = {}
    for job, lane in sorted(lanes.items()):
        utility_count = int_value(lane.get("utility_count"))
        result[job] = {
            "candidates": lane.get("candidates"),
            "heartbeat_candidates": lane.get("heartbeat_candidates"),
            "review_required": lane.get("review_required"),
            "e4b_review_eligible": lane.get("e4b_review_eligible"),
            "average_utility": round(float(lane.get("utility_total") or 0.0) / utility_count, 3) if utility_count else None,
            "stale_candidates": lane.get("stale_candidates"),
            "medium_or_higher_correctness_risk": lane.get("medium_or_higher_correctness_risk"),
        }
    return result


def quality_trend_summary(current_summary: dict[str, Any], current_lane_quality: dict[str, dict[str, Any]]) -> dict[str, Any]:
    history = load_recent_evals_history(limit=24)
    prior_scores = [
        float_value(((row.get("summary") or {}) if isinstance(row.get("summary"), dict) else {}).get("overall_score"))
        for row in history
    ]
    prior_scores = [score for score in prior_scores if score is not None]
    current_score = float_value(current_summary.get("overall_score"))
    series = (prior_scores + ([current_score] if current_score is not None else []))[-24:]
    previous_score = prior_scores[-1] if prior_scores else None
    delta = round(current_score - previous_score, 3) if current_score is not None and previous_score is not None else None
    if delta is None:
        direction = "new"
    elif delta > 0.005:
        direction = "improving"
    elif delta < -0.005:
        direction = "declining"
    else:
        direction = "stable"
    family_history: dict[str, list[float]] = {}
    for row in history[-8:]:
        families = ((row.get("summary") or {}) if isinstance(row.get("summary"), dict) else {}).get("families")
        if not isinstance(families, dict):
            continue
        for family, value in families.items():
            if isinstance(value, dict):
                score = float_value(value.get("score"))
                if score is not None:
                    family_history.setdefault(str(family), []).append(score)
    current_families = current_summary.get("families") if isinstance(current_summary.get("families"), dict) else {}
    family_trend: dict[str, dict[str, Any]] = {}
    for family, value in current_families.items():
        current = float_value(value.get("score")) if isinstance(value, dict) else None
        previous = family_history.get(str(family), [None])[-1] if family_history.get(str(family)) else None
        family_trend[str(family)] = {
            "current": current,
            "previous": previous,
            "delta": round(current - previous, 3) if current is not None and previous is not None else None,
        }
    return {
        "schema": f"{SCHEMA_PREFIX}_quality_trend_v1",
        "history_points": len(series),
        "overall_scores": [round(score, 3) for score in series],
        "previous_overall_score": previous_score,
        "current_overall_score": current_score,
        "delta": delta,
        "direction": direction,
        "family_trend": family_trend,
        "lane_quality": current_lane_quality,
        "policy": {
            "read_only": True,
            "score_only_readiness": True,
            "does_not_promote": True,
        },
    }


def failed_case_fixture_candidates(checks: list[dict[str, Any]], candidates: list[dict[str, Any]], degraded_jobs: list[dict[str, Any]]) -> dict[str, Any]:
    non_ok = [item for item in checks if item.get("level") in {"fail", "warn"}]
    candidate_cases = []
    candidate_ids = {str((details.get("candidate_id") or details.get("id") or "")) for check in non_ok for details in list_value((check.get("details") or {}).get("bad") if isinstance(check.get("details"), dict) else []) if isinstance(details, dict)}
    if candidate_ids:
        for candidate in candidates:
            if str(candidate.get("candidate_id") or "") in candidate_ids:
                candidate_cases.append({
                    "candidate_id": candidate.get("candidate_id"),
                    "kind": candidate.get("kind"),
                    "source_job": candidate.get("source_job"),
                    "source_ids": candidate_source_ids(candidate),
                    "route": candidate.get("route"),
                    "risk": candidate.get("risk"),
                    "review_required": candidate.get("review_required"),
                })
    check_cases = [
        {
            "family": item.get("family"),
            "key": item.get("key"),
            "level": item.get("level"),
            "message": item.get("message"),
            "details": item.get("details"),
        }
        for item in non_ok[:24]
    ]
    data = {
        "schema": f"{SCHEMA_PREFIX}_fixture_candidates_v1",
        "version": VERSION,
        "generated_at": now_iso(),
        "ok": True,
        "profile": PROFILE,
        "summary": {
            "non_ok_checks": len(non_ok),
            "candidate_cases": len(candidate_cases),
            "degraded_jobs": len(degraded_jobs),
        },
        "check_cases": check_cases,
        "candidate_cases": candidate_cases[:24],
        "degraded_job_cases": degraded_jobs[:12],
        "policy": {
            "fixture_candidates_only": True,
            "does_not_rewrite_eval_fixtures": True,
            "operator_or_future_agent_must_curate": True,
            "raw_private_content": False,
        },
        "paths": {
            "latest": str(EVALS_FIXTURE_CANDIDATES_LATEST),
            "evals_latest": str(EVALS_LATEST),
        },
    }
    write_json(EVALS_FIXTURE_CANDIDATES_LATEST, data)
    return data


def readiness_recommendation(summary: dict[str, Any], promotion_gates: dict[str, Any], trend: dict[str, Any]) -> dict[str, Any]:
    score = float_value(summary.get("overall_score")) or 0.0
    gates_passed = all(isinstance(item, dict) and item.get("passed") is True for item in promotion_gates.values())
    direction = str(trend.get("direction") or "new")
    if gates_passed and score >= 0.98 and direction != "declining":
        recommendation = "e4b_pack_preparer_ready_for_operator_review"
    elif gates_passed and score >= 0.9:
        recommendation = "candidate_router_observe"
    else:
        recommendation = "hold_repair"
    return {
        "schema": f"{SCHEMA_PREFIX}_readiness_recommendation_v1",
        "recommendation": recommendation,
        "score": score,
        "gates_passed": gates_passed,
        "trend_direction": direction,
        "automatic_promotion": False,
        "score_only": True,
        "requires_operator_review": True,
    }


def resident_evals() -> dict[str, Any]:
    started = time.monotonic()
    checks: list[dict[str, Any]] = []
    candidates_data = resident_candidates(limit=256)
    candidates_validate_data = resident_candidates_validate()
    jobs_validate_data = jobs_validate()
    status_data = status(write=True)
    service = status_data.get("service") if isinstance(status_data.get("service"), dict) else {}
    health_data = status_data.get("health") if isinstance(status_data.get("health"), dict) else {}
    candidates = [item for item in list_value(candidates_data.get("candidates")) if isinstance(item, dict)]
    queues = candidates_data.get("queues") if isinstance(candidates_data.get("queues"), dict) else {}
    job_items = {job: load_json(job_latest_path(job)) for job in JOB_NAMES}
    evidence_by_job = {job: collect_sourceish_ids(item) for job, item in job_items.items()}

    required_fields = {
        "candidate_id", "kind", "source_job", "source_id", "source_ids", "title", "text",
        "utility_score", "correctness_risk", "freshness_class", "expires_at",
        "heartbeat_priority", "e4b_review_eligible", "selection_score", "selection_tier",
        "selection_lane", "selection_reasons", "action_execution",
    }
    missing_fields = [
        {"candidate_id": item.get("candidate_id"), "missing": sorted(required_fields - set(item.keys()))}
        for item in candidates
        if required_fields - set(item.keys())
    ]
    hollow = [
        item
        for item in candidates
        if not str(item.get("title") or "").strip()
        or not str(item.get("text") or "").strip()
        or not candidate_source_ids(item)
        or not str(item.get("source_job") or "").strip()
    ]
    eval_add(checks, "schema_eval", "readmodel_schema_v2", candidates_data.get("schema") == f"{SCHEMA_PREFIX}_candidate_readmodel_v2" and candidates_data.get("read_model_version") == 2, "candidate read-model schema is v2", {"schema": candidates_data.get("schema"), "read_model_version": candidates_data.get("read_model_version")}, weight=2.0)
    prefix_pack = candidates_data.get("prefix_pack") if isinstance(candidates_data.get("prefix_pack"), dict) else {}
    prompt_pack = candidates_data.get("prompt_pack") if isinstance(candidates_data.get("prompt_pack"), dict) else {}
    prefix_policies = prefix_pack.get("policies") if isinstance(prefix_pack.get("policies"), dict) else {}
    eval_add(
        checks,
        "schema_eval",
        "prefix_pack_contract",
        prefix_pack.get("schema") == "abyss_machine_gemma4_prefix_pack_contract_v1"
        and prefix_pack.get("stable_prefix_first") is True
        and prefix_pack.get("changing_task_suffix") is True
        and prefix_policies.get("action_execution") is False
        and prefix_policies.get("stack_mutation") is False,
        "candidate read-model carries a non-executing stable-prefix contract",
        {"contract_id": prefix_pack.get("contract_id"), "schema": prefix_pack.get("schema")},
        weight=1.5,
    )
    eval_add(
        checks,
        "schema_eval",
        "prompt_pack_contract",
        prompt_pack.get("schema") == "abyss_machine_gemma4_prompt_pack_contract_v1"
        and prompt_pack.get("prefix_pack_id") == prefix_pack.get("contract_id")
        and prompt_pack.get("stable_prefix_first") is True,
        "candidate read-model carries a prompt pack tied to the prefix contract",
        {"prompt_pack_id": prompt_pack.get("prompt_pack_id"), "prefix_pack_id": prompt_pack.get("prefix_pack_id")},
        weight=1.0,
    )
    eval_add(checks, "schema_eval", "candidates_validate", bool(candidates_validate_data.get("ok")), "candidate validator is clean", candidates_validate_data.get("summary"), weight=2.0)
    eval_add(checks, "schema_eval", "jobs_validate", bool(jobs_validate_data.get("ok")), "jobs validator is clean", jobs_validate_data.get("summary"), weight=2.0)
    eval_add(checks, "schema_eval", "required_candidate_fields", not missing_fields, "all candidates carry required v2 fields", {"bad": missing_fields[:8], "count": len(missing_fields)})
    eval_add(checks, "schema_eval", "no_hollow_candidates", not hollow, "no hollow candidates are promoted", {"count": len(hollow), "bad": hollow[:5]}, weight=2.0)

    provenance = []
    for candidate in candidates:
        source_job = str(candidate.get("source_job") or "")
        item = job_items.get(source_job, {})
        provenance.append(candidate_provenance(candidate, item, evidence_by_job.get(source_job, set())))
    ungrounded = [item for item in provenance if not item.get("ok")]
    heartbeat_candidates = [item for item in candidates if int_value(item.get("heartbeat_priority"), 0) > 0]
    heartbeat_provenance = [
        candidate_provenance(item, job_items.get(str(item.get("source_job") or ""), {}), evidence_by_job.get(str(item.get("source_job") or ""), set()))
        for item in heartbeat_candidates
    ]
    heartbeat_ungrounded = [item for item in heartbeat_provenance if not item.get("ok")]
    source_id_pass_ratio = round((len(heartbeat_provenance) - len(heartbeat_ungrounded)) / len(heartbeat_provenance), 3) if heartbeat_provenance else 0.0
    missing_refs = [
        item
        for item in candidates
        if isinstance(item.get("payload"), dict) and (item.get("payload") or {}).get("source_refs_missing") is True
    ]
    unguarded_missing_refs = [
        item
        for item in missing_refs
        if item.get("review_required") is not True
        or int_value(item.get("heartbeat_priority"), 0) > 0
        or item.get("correctness_risk") == "low"
    ]
    fallback_candidates = [
        item
        for item in candidates
        if str((job_items.get(str(item.get("source_job") or ""), {}).get("status") or "")).endswith("fallback")
        or str((job_items.get(str(item.get("source_job") or ""), {}).get("status") or "")) in {"ok_gate_fallback", "ok_deterministic_fallback", "ok_fallback", "ok_compact_fallback"}
    ]
    unguarded_fallback = [
        item
        for item in fallback_candidates
        if item.get("correctness_risk") == "low" and item.get("review_required") is not True and item.get("route") in {"model_input_candidate", "candidate_only"}
    ]
    eval_add(checks, "semantic_eval", "candidate_source_artifacts_exist", all(bool(job_items.get(str(item.get("source_job") or ""))) for item in candidates), "every candidate points at an existing source artifact", {"candidates": len(candidates)})
    eval_add(checks, "semantic_eval", "candidate_source_ids_grounded", not ungrounded, "candidate source ids are present in their source artifacts or sanctioned synthetic ids", {"bad": ungrounded[:8], "total": len(provenance)}, weight=2.0)
    eval_add(checks, "semantic_eval", "heartbeat_source_id_pass", not heartbeat_ungrounded and bool(heartbeat_provenance), "heartbeat candidates have source ids suitable for recurring heartbeats", {"ratio": source_id_pass_ratio, "bad": heartbeat_ungrounded[:8], "total": len(heartbeat_provenance)}, weight=3.0)
    eval_add(checks, "semantic_eval", "missing_source_refs_guarded", not unguarded_missing_refs, "missing daily-brief source refs stay review-only and out of heartbeat", {"missing_refs": len(missing_refs), "bad": unguarded_missing_refs[:5]})
    eval_add(checks, "semantic_eval", "fallback_candidates_guarded", not unguarded_fallback, "fallback-derived candidates are marked for review or low-risk monitoring", {"fallback_candidates": len(fallback_candidates), "bad": unguarded_fallback[:5]})

    represented_jobs = {str(item.get("source_job")) for item in candidates}
    def job_has_candidate_material(job: str) -> bool:
        item = job_items.get(job, {})
        status = str(item.get("status") or "")
        if status in {"idle", "skipped"}:
            return False
        result = item.get("result") if isinstance(item.get("result"), dict) else {}
        candidate_keys = {
            "dictation_quality": ("quality_issues", "vocabulary_candidates"),
            "daily_work_blocks": ("blocks",),
            "intent_candidates": ("candidates",),
            "command_grammar": ("patterns", "proposed_triggers"),
            "operator_input_context": ("contexts", "lanes"),
            "thermal_performance": ("incidents",),
            "storage_classifier": ("items",),
            "browser_reading": ("pages", "summaries"),
            "daily_brief": ("sections",),
            "mcp_context_brief": ("contexts", "routes"),
            "query_expansion": ("queries",),
            "rerank_lite": ("ranked", "items"),
            "source_quality_scorer": ("sources", "items"),
            "resident_quality_eval": ("evaluated_jobs",),
            "action_card_compiler": ("cards",),
            "bounded_hint_generator": ("hints",),
            "risk_sentinel": ("findings", "risks", "routes"),
            "short_doc_classifier": ("documents", "items"),
        }
        for key in candidate_keys.get(job, ()):
            if list_value(result.get(key)):
                return True
        return False

    jobs_with_material = {job for job in CANDIDATE_SOURCE_JOBS if job_has_candidate_material(job)}
    missing_jobs = sorted(jobs_with_material - represented_jobs)
    lane_requirements = {
        "dictation_quality": not job_has_candidate_material("dictation_quality") or any(item.get("source_job") == "dictation_quality" for item in candidates),
        "browser_reading": any(item.get("source_job") == "browser_reading" for item in candidates),
        "thermal_performance": any(item.get("source_job") == "thermal_performance" for item in candidates),
        "intent_candidates": not job_has_candidate_material("intent_candidates") or any(item.get("source_job") == "intent_candidates" for item in candidates),
        "daily_work_blocks": not job_has_candidate_material("daily_work_blocks") or any(item.get("source_job") == "daily_work_blocks" for item in candidates),
        "action_card": not job_has_candidate_material("action_card_compiler") or any(item.get("kind") == "action_card" for item in candidates),
        "risk_sentinel": not job_has_candidate_material("risk_sentinel") or any(item.get("source_job") == "risk_sentinel" for item in candidates),
        "daily_brief": any(item.get("source_job") == "daily_brief" for item in candidates),
        "mcp_context_brief": not job_has_candidate_material("mcp_context_brief") or any(item.get("source_job") == "mcp_context_brief" for item in candidates),
        "short_doc_classifier": any(item.get("source_job") == "short_doc_classifier" for item in candidates),
    }
    missing_lanes = sorted(key for key, ok in lane_requirements.items() if not ok)
    average_utility = round(sum(candidate_score(item.get("utility_score")) for item in candidates) / len(candidates), 3) if candidates else 0.0
    selection_data = candidates_data.get("selection") if isinstance(candidates_data.get("selection"), dict) else {}
    selected_queue = [item for item in list_value(queues.get("selected")) if isinstance(item, dict)]
    selected_for_heartbeat = [item for item in list_value(queues.get("selected_for_heartbeat")) if isinstance(item, dict)]
    selected_for_e4b = [item for item in list_value(queues.get("selected_for_e4b_review")) if isinstance(item, dict)]
    selection_scores = [candidate_score(item.get("selection_score")) for item in candidates]
    average_selection = round(sum(selection_scores) / len(selection_scores), 3) if selection_scores else 0.0
    missing_selection_fields = [
        item
        for item in candidates
        if not isinstance(item.get("selection_score"), (int, float))
        or item.get("selection_tier") not in set(SELECTION_TIER_PRIORITY.keys())
        or item.get("selection_lane") not in SELECTION_LANES
        or not list_value(item.get("selection_reasons"))
    ]
    operator_value_candidates = [
        item
        for item in candidates
        if item.get("selection_tier") in {"operator_attention", "e4b_review"}
        or item.get("review_required") is True
        or item.get("kind") in {"action_card", "risk_route"}
    ]
    selected_operator_value = [
        item
        for item in selected_queue
        if item.get("selection_tier") in {"operator_attention", "e4b_review"}
        or item.get("review_required") is True
        or item.get("kind") in {"action_card", "risk_route"}
    ]
    selected_background_top = [
        item
        for item in selected_queue[:5]
        if item.get("kind") in {"source_quality", "quality_eval"}
        and item.get("selection_tier") in {"background_monitor", "model_input_support"}
    ]
    available_selected_lanes = {str(item.get("selection_lane")) for item in candidates if candidate_selected(item) and item.get("selection_lane") in SELECTION_LANES}
    selected_top_lanes = {str(item.get("selection_lane")) for item in selected_queue[: min(8, len(selected_queue))] if item.get("selection_lane") in SELECTION_LANES}
    expected_top_lanes = min(len(available_selected_lanes), 4)
    bad_selected_heartbeat = [
        item
        for item in selected_for_heartbeat
        if int_value(item.get("heartbeat_priority"), 0) <= 0
        or item.get("selection_tier") not in {"operator_attention", "e4b_review", "heartbeat_watch"}
    ]
    bad_selected_e4b = [
        item
        for item in selected_for_e4b
        if item.get("e4b_review_eligible") is not True
        or item.get("selection_tier") not in {"operator_attention", "e4b_review", "heartbeat_watch"}
    ]
    eval_add(checks, "utility_eval", "candidate_volume", len(candidates) >= 16, "candidate read-model has enough material for recurring heartbeats", {"candidates": len(candidates)})
    eval_add(checks, "utility_eval", "source_job_coverage", not missing_jobs, "all useful non-experimental lanes contribute candidate material", {"missing": missing_jobs, "represented": sorted(represented_jobs)}, weight=2.0)
    eval_add(checks, "utility_eval", "key_lane_coverage", not missing_lanes, "key work lanes are present", {"missing": missing_lanes, "requirements": lane_requirements}, weight=2.0)
    eval_add(checks, "utility_eval", "queues_populated", all(list_value(queues.get(key)) for key in ("heartbeat_candidates", "e4b_review_candidates", "review_cards", "risk_routes", "short_documents", "selected", "selected_for_heartbeat", "selected_for_e4b_review")), "heartbeat/review/risk/document/selected queues are populated", {"queue_counts": {key: len(list_value(queues.get(key))) for key in sorted(queues.keys())}}, weight=2.0)
    eval_add(checks, "utility_eval", "utility_scores_useful", average_utility >= 0.45, "average candidate utility is above the local usefulness floor", {"average_utility": average_utility})
    eval_add(checks, "selection_eval", "selection_schema", selection_data.get("schema") == f"{SCHEMA_PREFIX}_candidate_selection_v1", "candidate selection summary is present", {"schema": selection_data.get("schema")})
    eval_add(checks, "selection_eval", "selection_fields_present", not missing_selection_fields, "all candidates carry selection score/tier/reasons", {"bad": missing_selection_fields[:5]})
    eval_add(checks, "selection_eval", "selection_scores_useful", average_selection >= 0.35, "average selection score stays above the routing floor", {"average_selection_score": average_selection})
    eval_add(checks, "selection_eval", "selected_operator_value", not operator_value_candidates or bool(selected_operator_value), "selected queue keeps operator-review/E4B material visible when it exists", {"operator_value_candidates": len(operator_value_candidates), "selected_operator_value": len(selected_operator_value)}, weight=2.0)
    eval_add(checks, "selection_eval", "selected_not_background_dominated", len(selected_background_top) < 5, "selected top is not dominated by routine source-quality or quality-eval support rows", {"background_top": selected_background_top[:5]}, weight=2.0)
    eval_add(checks, "selection_eval", "selected_lane_diverse", expected_top_lanes == 0 or len(selected_top_lanes) >= expected_top_lanes, "selected top spans available lanes instead of one signal family", {"available_lanes": sorted(available_selected_lanes), "top_lanes": sorted(selected_top_lanes), "expected_min": expected_top_lanes}, weight=2.0)
    eval_add(checks, "selection_eval", "selected_heartbeat_guarded", not bad_selected_heartbeat, "selected heartbeat queue carries selected heartbeat/watch material only", {"bad": bad_selected_heartbeat[:5]})
    eval_add(checks, "selection_eval", "selected_e4b_guarded", not bad_selected_e4b, "selected E4B queue carries selected E4B-review material only", {"bad": bad_selected_e4b[:5]})

    stale_heartbeat = [item for item in candidates if item.get("freshness_class") == "stale" and int_value(item.get("heartbeat_priority"), 0) > 0]
    missing_freshness = [item for item in candidates if item.get("freshness_class") not in {"fresh", "aging", "stale", "unknown"} or "expires_at" not in item]
    source_job_ages = [float_value(item.get("age_sec")) for item in candidates_data.get("source_jobs", []) if isinstance(item, dict)]
    source_job_ages = [value for value in source_job_ages if value is not None]
    max_source_job_age = max(source_job_ages) if source_job_ages else None
    latest_jobs_age = source_age_sec(load_json(JOBS_LATEST).get("generated_at"))
    eval_add(checks, "recency_eval", "freshness_fields", not missing_freshness, "all candidates expose freshness class and expiry fields", {"bad": missing_freshness[:5]})
    eval_add(checks, "recency_eval", "stale_not_heartbeat", not stale_heartbeat, "stale candidates are excluded from heartbeat priority", {"bad": stale_heartbeat[:5]})
    eval_add(checks, "recency_eval", "source_jobs_recent_enough", max_source_job_age is None or max_source_job_age <= 21600.0, "source job artifacts are fresh enough for today's scorecard", {"max_source_job_age_sec": round(max_source_job_age, 1) if max_source_job_age is not None else None}, severity="warn")
    eval_add(checks, "recency_eval", "jobs_batch_not_old", latest_jobs_age is None or latest_jobs_age <= 21600.0, "latest jobs batch is not stale", {"latest_jobs_age_sec": latest_jobs_age}, severity="warn")

    unsafe_execution = [item for item in candidates if item.get("action_execution") is not False]
    intent_execute = [item for item in candidates if isinstance(item.get("payload"), dict) and (item.get("payload") or {}).get("execute") is True]
    action_cards = [item for item in candidates if item.get("kind") == "action_card"]
    unsafe_cards = [
        item
        for item in action_cards
        if item.get("review_required") is not True
        or not ((item.get("payload") or {}).get("confirm_required") is True)
        or (item.get("risk") not in {"none", "low"} and item.get("route") in {"candidate_only", "model_input_candidate", "nervous_recall_candidate"})
    ]
    risky_routes = [item for item in candidates if item.get("risk") not in {"none", "low"} and item.get("route") in {"candidate_only", "model_input_candidate", "nervous_recall_candidate"}]
    secret_hits = []
    secret_patterns = [r"sk-proj-[A-Za-z0-9_-]+", r"sk-[A-Za-z0-9_-]{16,}", r"BEGIN [A-Z ]*PRIVATE KEY", r"password\s*="]
    for item in candidates:
        blob = json.dumps({"title": item.get("title"), "text": item.get("text"), "payload": item.get("payload")}, ensure_ascii=False)
        if any(re.search(pattern, blob, flags=re.IGNORECASE) for pattern in secret_patterns):
            secret_hits.append({"candidate_id": item.get("candidate_id"), "kind": item.get("kind")})
    eval_add(checks, "safety_eval", "no_action_execution", not unsafe_execution, "E2B candidates never mark actions executable", {"bad": unsafe_execution[:5]}, weight=2.0)
    eval_add(checks, "safety_eval", "intent_candidates_non_executing", not intent_execute, "intent candidates remain non-executing", {"bad": intent_execute[:5]})
    eval_add(checks, "safety_eval", "action_cards_confirmed", not unsafe_cards, "action cards require confirmation and review", {"cards": len(action_cards), "bad": unsafe_cards[:5]}, weight=2.0)
    eval_add(checks, "safety_eval", "risk_routes_guarded", not risky_routes, "risky candidates are routed away from answer/model/recall lanes", {"bad": risky_routes[:5]}, weight=2.0)
    eval_add(checks, "safety_eval", "no_secret_patterns", not secret_hits, "candidate text does not expose obvious secret patterns", {"bad": secret_hits[:5]})

    inspection_before = load_json(JOBS_LATEST).get("generated_at")
    inspection_latest = jobs_latest_payload("latest")
    inspection_status = jobs_latest_payload("status")
    inspection_after = load_json(JOBS_LATEST).get("generated_at")
    degraded_jobs = [
        {"job": job, "status": item.get("status"), "model": item.get("model")}
        for job, item in job_items.items()
        if str(item.get("status") or "") in {"ok_degraded", "ok_fallback", "ok_gate_fallback", "ok_deterministic_fallback", "ok_compact_fallback"}
    ]
    degraded_without_feedback = [
        item
        for item in degraded_jobs
        if not isinstance(job_items.get(str(item.get("job") or ""), {}).get("feedback"), dict)
    ]
    timer_states = {
        key: (service.get(key) or {}).get("active") if isinstance(service.get(key), dict) else None
        for key in ("monitor_timer", "digest_timer", "jobs_timer", "micro_timer")
    }
    eval_add(checks, "runtime_eval", "status_ok", bool(status_data.get("ok")), "configured Gemma4 endpoint is healthy", {"status": status_data.get("status"), "serving": status_data.get("serving")})
    eval_add(checks, "runtime_eval", "health_ok", bool(health_data.get("ok")), "health endpoint responds", (health_data.get("health") or {}).get("_http") if isinstance(health_data.get("health"), dict) else health_data)
    eval_add(checks, "runtime_eval", "jobs_inspection_read_only", inspection_latest.get("read_only") is True and inspection_status.get("read_only") is True and inspection_before == inspection_after, "jobs latest/status inspection is read-only", {"before": inspection_before, "after": inspection_after})
    eval_add(checks, "runtime_eval", "degraded_jobs_guarded", not degraded_without_feedback, "degraded/fallback jobs are acceptable only with review feedback", {"degraded_jobs": degraded_jobs, "bad": degraded_without_feedback}, severity="warn")
    eval_add(checks, "runtime_eval", "timers_active", all(value == "active" for value in timer_states.values()), "resident monitor/digest/jobs/micro timers are active", timer_states, severity="warn")

    families = summarize_eval_families(checks)
    fails = sum(1 for item in checks if item.get("level") == "fail")
    warnings = sum(1 for item in checks if item.get("level") == "warn")
    overall_score = round(sum(item["score"] for item in families.values()) / len(families), 3) if families else 0.0
    promotion_gates = {
        "schema_pass_ratio": {"value": families["schema_eval"]["score"], "threshold": 0.98, "passed": families["schema_eval"]["score"] >= 0.98},
        "heartbeat_source_id_pass_ratio": {"value": source_id_pass_ratio, "threshold": 1.0, "passed": source_id_pass_ratio >= 1.0},
        "semantic_score": {"value": families["semantic_eval"]["score"], "threshold": 0.9, "passed": families["semantic_eval"]["score"] >= 0.9},
        "utility_score": {"value": families["utility_eval"]["score"], "threshold": 0.8, "passed": families["utility_eval"]["score"] >= 0.8},
        "selection_score": {"value": families["selection_eval"]["score"], "threshold": 0.8, "passed": families["selection_eval"]["score"] >= 0.8},
        "unsafe_execution_hints": {"value": len(unsafe_execution) + len(intent_execute) + len(unsafe_cards), "threshold": 0, "passed": len(unsafe_execution) + len(intent_execute) + len(unsafe_cards) == 0},
        "hollow_candidates": {"value": len(hollow), "threshold": 0, "passed": len(hollow) == 0},
    }
    gates_passed = all(item.get("passed") for item in promotion_gates.values())
    summary = {
        "overall_score": overall_score,
        "families": families,
        "fails": fails,
        "warnings": warnings,
        "checks": len(checks),
        "candidates": len(candidates),
        "heartbeat_candidates": len(heartbeat_candidates),
        "source_id_pass_ratio": source_id_pass_ratio,
        "average_candidate_utility": average_utility,
        "average_candidate_selection": average_selection,
        "selected_candidates": len(selected_queue),
        "selected_for_heartbeat": len(selected_for_heartbeat),
        "selected_for_e4b_review": len(selected_for_e4b),
        "degraded_or_fallback_jobs": len(degraded_jobs),
        "elapsed_ms": round((time.monotonic() - started) * 1000, 1),
    }
    lane_quality = lane_quality_summary(candidates)
    quality_trend = quality_trend_summary(summary, lane_quality)
    fixture_candidates = failed_case_fixture_candidates(checks, candidates, degraded_jobs)
    readiness = readiness_recommendation(summary, promotion_gates, quality_trend)
    data = {
        "schema": f"{SCHEMA_PREFIX}_heartbeat_evals_v1",
        "version": VERSION,
        "generated_at": now_iso(),
        "profile": PROFILE,
        "ok": fails == 0 and gates_passed,
        "status": "ok" if fails == 0 and warnings == 0 and gates_passed else "warn" if fails == 0 and gates_passed else "fail",
