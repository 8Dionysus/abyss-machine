    }


def resident_audit(include_generation: bool = True) -> dict[str, Any]:
    started = time.monotonic()
    checks: list[dict[str, Any]] = []

    def add(level: str, key: str, message: str, details: Any = None) -> None:
        item = {"level": level, "key": key, "message": message}
        if details is not None:
            item["details"] = details
        checks.append(item)

    status_data = status(write=True)
    preflight_data = preflight(force=False)
    jobs_validate_data = jobs_validate()
    evals_validate_data = resident_evals_validate()
    validate_data = validate()
    service = status_data.get("service") if isinstance(status_data.get("service"), dict) else {}
    health_data = status_data.get("health") if isinstance(status_data.get("health"), dict) else {}
    generation = tiny_generation_probe() if include_generation else {"ok": None, "status": "skipped", "reason": "generation_probe_disabled"}
    tiny_policy = resident_policy(request_class="job", job="dictation_quality", write=False)
    batch_policy = resident_policy(request_class="jobs", job="dictation_quality", write=False)
    source_freshness = source_freshness_summary()
    evals_latest = load_json(EVALS_LATEST)
    tiny_game_summary = (((tiny_policy.get("inputs") or {}).get("game_guard") or {}).get("summary") or {}) if isinstance(tiny_policy.get("inputs"), dict) else {}
    active_games = int_value(tiny_game_summary.get("active_game_processes"))

    add("ok" if status_data.get("ok") else "fail", "status", "configured Gemma4 endpoint is healthy", {"status": status_data.get("status"), "serving": status_data.get("serving")})
    add("ok" if health_data.get("ok") else "fail", "health", "health endpoint responds", (health_data.get("health") or {}).get("_http") if isinstance(health_data.get("health"), dict) else health_data)
    if EXTERNAL_ENDPOINT:
        add("ok" if service.get("active") != "active" else "warn", "host_service_inactive", "host service does not duplicate stack-owned serving", service)
        add("ok" if (service.get("timer") or {}).get("active") != "active" else "warn", "start_timer_inactive", "legacy start timer stays inactive under stack ownership", service.get("timer"))
    for key in ("monitor_timer", "digest_timer", "jobs_timer", "micro_timer"):
        timer = service.get(key) if isinstance(service.get(key), dict) else {}
        add("ok" if timer.get("active") == "active" else "warn", key, f"{key} is active", timer)
    add("ok" if preflight_data.get("ok") else "warn", "preflight", "preflight has no fails", preflight_data.get("summary"))
    add("ok" if validate_data.get("ok") else "fail", "validate", "resident validate passes", validate_data.get("summary"))
    add("ok" if jobs_validate_data.get("ok") else "fail", "jobs_validate", "resident jobs validate passes", jobs_validate_data.get("summary"))
    add("ok" if evals_validate_data.get("ok") else "fail", "evals_validate", "resident heartbeat evals validate passes", evals_validate_data.get("summary"))
    dictation_source = source_freshness.get("dictation_latest") if isinstance(source_freshness.get("dictation_latest"), dict) else {}
    browser_source = source_freshness.get("browser_content") if isinstance(source_freshness.get("browser_content"), dict) else {}
    add(
        "ok" if int_value(dictation_source.get("usable_records")) > 0 else "warn",
        "source:dictation_freshness",
        "dictation source freshness window state",
        dictation_source,
    )
    add(
        "ok" if int_value(browser_source.get("usable_records")) > 0 else "warn",
        "source:browser_freshness",
        "browser source freshness window state",
        browser_source,
    )
    add("ok" if generation.get("ok") or generation.get("status") == "skipped" else "fail", "tiny_generation", "tiny live generation works or was explicitly skipped", generation)
    if active_games > 0:
        add(
            "ok" if tiny_policy.get("allowed") and tiny_policy.get("decision") in {"allow", "degraded"} else "fail",
            "policy:game_guard_tiny_probe",
            "tier-1 request_class=job remains available in bounded mode under active game guard",
            {"active_games": active_games, "decision": tiny_policy.get("decision"), "reason": tiny_policy.get("primary_reason"), "limits": tiny_policy.get("limits"), "warnings": tiny_policy.get("warnings")},
        )
        add(
            "ok" if not batch_policy.get("allowed") else "warn",
            "policy:game_guard_batch_block",
            "full jobs batch stays blocked under active game guard",
            {"active_games": active_games, "decision": batch_policy.get("decision"), "reason": batch_policy.get("primary_reason")},
        )
    else:
        add("ok" if tiny_policy.get("allowed") else "warn", "policy:tiny_probe", "tier-1 tiny probe policy is available when no game guard is active", {"decision": tiny_policy.get("decision"), "reason": tiny_policy.get("primary_reason")})

    fails = sum(1 for item in checks if item["level"] == "fail")
    warnings = sum(1 for item in checks if item["level"] == "warn")
    data = {
        "schema": f"{SCHEMA_PREFIX}_audit_v1",
        "version": VERSION,
        "generated_at": now_iso(),
        "profile": PROFILE,
        "ok": fails == 0,
        "summary": {
            "status": "ok" if fails == 0 and warnings == 0 else "warn" if fails == 0 else "fail",
            "fails": fails,
            "warnings": warnings,
            "checks": len(checks),
            "elapsed_ms": round((time.monotonic() - started) * 1000, 1),
        },
        "checks": checks,
        "current": {
            "status": {"ok": status_data.get("ok"), "status": status_data.get("status"), "serving": status_data.get("serving"), "metrics": status_data.get("metrics")},
            "preflight": {"ok": preflight_data.get("ok"), "summary": preflight_data.get("summary")},
            "validate": {"ok": validate_data.get("ok"), "summary": validate_data.get("summary")},
            "jobs_validate": {"ok": jobs_validate_data.get("ok"), "summary": jobs_validate_data.get("summary")},
            "evals_validate": {"ok": evals_validate_data.get("ok"), "summary": evals_validate_data.get("summary")},
            "evals": {"ok": evals_latest.get("ok"), "status": evals_latest.get("status"), "summary": evals_latest.get("summary"), "quality_trend": evals_latest.get("quality_trend"), "readiness_recommendation": evals_latest.get("readiness_recommendation")},
            "tiny_generation": generation,
            "policy_probes": {
                "tier1_job": {"allowed": tiny_policy.get("allowed"), "decision": tiny_policy.get("decision"), "reason": tiny_policy.get("primary_reason"), "limits": tiny_policy.get("limits"), "warnings": tiny_policy.get("warnings")},
                "jobs_batch": {"allowed": batch_policy.get("allowed"), "decision": batch_policy.get("decision"), "reason": batch_policy.get("primary_reason"), "limits": batch_policy.get("limits"), "warnings": batch_policy.get("warnings")},
            },
            "latest_jobs": latest_job_summary(),
            "micro_latest": load_json(MICRO_LATEST),
            "source_freshness": source_freshness,
        },
        "history": {
            "jobs": summarize_job_history(),
            "micro": summarize_micro_history(),
        },
        "paths": {
            "latest": str(AUDIT_LATEST),
            "root": str(AUDIT_ROOT),
            "status_latest": str(STATUS_LATEST),
            "jobs_validate_latest": str(JOBS_ROOT / "validate" / "latest.json"),
            "evals_latest": str(EVALS_LATEST),
            "evals_validate_latest": str(EVALS_VALIDATE_LATEST),
            "evals_fixture_candidates_latest": str(EVALS_FIXTURE_CANDIDATES_LATEST),
        },
        "non_claims": [
            "This audit does not start, stop, restart, or reconfigure services.",
            "The tiny generation probe is a liveness and latency signal, not a quality promotion gate.",
            "Heartbeat evals replay existing artifacts and do not start a resident jobs batch.",
            "Job artifacts remain local derived candidates and do not execute operator intent.",
        ],
    }
    write_json(AUDIT_LATEST, data)
    append_jsonl(daily_path(AUDIT_ROOT / "jsonl"), data)
    return data


