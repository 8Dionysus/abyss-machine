def dictation_events(limit: int = 20) -> list[dict[str, Any]]:
    files = sorted(DICTATION_JSONL_ROOT.glob("*/*/*.jsonl"))[-8:]
    events: list[dict[str, Any]] = []
    for path in files:
        try:
            lines = path.read_text(encoding="utf-8").splitlines()
        except OSError:
            continue
        for line in lines[-200:]:
            try:
                item = json.loads(line)
            except json.JSONDecodeError:
                continue
            if not isinstance(item, dict) or not item.get("ok") or not item.get("text"):
                continue
            generated_at = item.get("generated_at")
            if not source_is_fresh(generated_at, DICTATION_SOURCE_MAX_AGE_SEC):
                continue
            intent = item.get("intent") if isinstance(item.get("intent"), dict) else {}
            events.append({"id": item.get("id"), "generated_at": generated_at, "age_sec": source_age_sec(generated_at), "action": item.get("action"), "intent_type": intent.get("type"), "triggered": intent.get("triggered"), "text": str(item.get("text") or "")[:1400]})
    state = load_json(STATE_PATH)
    seen = set(state.get("seen_dictation_ids") or [])
    return [item for item in events if item.get("id") and item.get("id") not in seen][-limit:]


def recent_dictation_records(limit: int = 24) -> list[dict[str, Any]]:
    files = sorted(DICTATION_JSONL_ROOT.glob("*/*/*.jsonl"))[-10:]
    records: list[dict[str, Any]] = []
    for path in files:
        try:
            lines = path.read_text(encoding="utf-8").splitlines()
        except OSError:
            continue
        for line in lines[-300:]:
            try:
                item = json.loads(line)
            except json.JSONDecodeError:
                continue
            if not isinstance(item, dict) or not item.get("ok") or not item.get("text"):
                continue
            intent = item.get("intent") if isinstance(item.get("intent"), dict) else {}
            text = str(item.get("text") or "").strip()
            if not text:
                continue
            generated_at = item.get("generated_at")
            if not source_is_fresh(generated_at, DICTATION_SOURCE_MAX_AGE_SEC):
                continue
            records.append({
                "id": item.get("id"),
                "generated_at": generated_at,
                "age_sec": source_age_sec(generated_at),
                "action": item.get("action"),
                "intent_type": intent.get("type"),
                "intent_triggered": intent.get("triggered"),
                "text_length": len(text),
                "text": compact_text(text, 280),
            })
    unique: dict[str, dict[str, Any]] = {}
    for item in records:
        if item.get("id"):
            unique[str(item["id"])] = item
    return list(unique.values())[-limit:]


def dictation_model_source_issue(items: list[dict[str, Any]]) -> str | None:
    if not items:
        return "no_recent_dictation_records"
    ages = [
        float(item["age_sec"])
        for item in items
        if isinstance(item.get("age_sec"), (int, float))
    ]
    if ages and min(ages) > DICTATION_MODEL_SOURCE_MAX_AGE_SEC:
        return "dictation_source_outside_model_window"
    total_chars = sum(int_value(item.get("text_length")) for item in items)
    if total_chars < 16:
        return "dictation_source_too_short_for_model"
    return None


def recent_browser_records(limit: int = 8) -> list[dict[str, Any]]:
    files = sorted(BROWSER_CONTENT_ROOT.glob("*/*/*.jsonl"))[-7:]
    records_by_page: dict[str, dict[str, Any]] = {}
    for path in files:
        try:
            lines = path.read_text(encoding="utf-8").splitlines()
        except OSError:
            continue
        for line in lines[-120:]:
            try:
                item = json.loads(line)
            except json.JSONDecodeError:
                continue
            if not isinstance(item, dict):
                continue
            raw_text = str(item.get("text") or "")
            page_identity = item.get("page_identity") if isinstance(item.get("page_identity"), dict) else {}
            is_ai_interaction = bool(page_identity.get("is_ai"))
            if item.get("skipped_text") is True:
                continue
            if item.get("has_sensitive_fields") is True and not is_ai_interaction:
                continue
            generated_at = item.get("generated_at") or item.get("captured_at")
            if not source_is_fresh(generated_at, BROWSER_SOURCE_MAX_AGE_SEC):
                continue
            url = item.get("url") if isinstance(item.get("url"), dict) else {}
            upstream_quality = item.get("content_quality") if isinstance(item.get("content_quality"), dict) else None
            clean_text, quality = browser_clean_text_and_quality(
                raw_text,
                title=str(item.get("title") or ""),
                url=str(url.get("url") or ""),
                upstream_quality=upstream_quality,
                upstream_clean_text=str(item.get("clean_text") or "") or None,
            )
            if quality.get("classification") == "noise" or len(clean_text.strip()) < 160:
                continue
            page_key = str(url.get("url") or item.get("title") or item.get("clean_text_sha256") or item.get("text_sha256") or stable_id("browser", line))
            source_id = stable_id("browser", {"generated_at": item.get("generated_at"), "title": item.get("title"), "text_sha256": item.get("text_sha256")})
            record = {
                "id": source_id,
                "source_id": item.get("source_id"),
                "generated_at": generated_at,
                "age_sec": source_age_sec(generated_at),
                "title": item.get("title"),
                "url": url.get("url"),
                "url_sha256": url.get("url_sha256"),
                "text_sha256": item.get("text_sha256"),
                "text_length": item.get("text_length") or len(raw_text),
                "clean_text_length": quality.get("clean_text_length"),
                "quality": quality,
                "page_identity": page_identity if page_identity else None,
                "web_context_quality": item.get("web_context_quality") if isinstance(item.get("web_context_quality"), dict) else None,
                "text": compact_text(clean_text, 900),
            }
            previous = records_by_page.get(page_key)
            if previous is None or browser_record_rank(record) >= browser_record_rank(previous):
                records_by_page[page_key] = record
    records = sorted(records_by_page.values(), key=browser_record_rank, reverse=True)
    return records[:limit]


