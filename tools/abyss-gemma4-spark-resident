def run_machine_bundle(selected_jobs: list[str] | None = None, request_class: str = "job") -> dict[str, dict[str, Any]]:
    all_jobs = ["thermal_performance", "storage_classifier", "daily_brief"]
    jobs = selected_jobs if selected_jobs is not None else all_jobs
    material = machine_bundle_material()
    source = {
        "kind": "machine_material",
        "count": len(material.get("nervous_events") or []) + len(material.get("storage", {}).get("actions") or []),
        "refs": {
            "storage_cleanup_latest": str(STORAGE_CLEANUP_LATEST),
            "thermal_attribution_latest": str(THERMAL_ATTRIBUTION_LATEST),
            "process_latest": str(PROCESS_LATEST),
            "nervous_events_count": len(material.get("nervous_events") or []),
        },
    }
    fallback = fallback_machine_bundle(material)
    predict = {"thermal_performance": 360, "storage_classifier": 640, "daily_brief": 220}
    artifacts: dict[str, dict[str, Any]] = {}
    for job in jobs:
        if (
            job == "storage_classifier"
            and EXTERNAL_ENDPOINT
            and os.environ.get("ABYSS_GEMMA4_SPARK_MODEL_STORAGE_CLASSIFIER", "").strip().lower() not in ENV_TRUE
        ):
            result = fallback[job]
            artifacts[job] = write_job_artifact(job, {
                "ok": True,
                "status": "ok_deterministic",
                "reason": "stack_endpoint_storage_classifier_deterministic_full_coverage",
                "source": source,
                "material_excerpt": material,
                "result": result,
                "feedback": machine_job_feedback(job, gate={"reason": "deterministic_full_coverage", "policy": {"serving": serving_payload()}}, result=result),
                "model": {
                    "used": False,
                    "parsed_job": None,
                    "fallback_used": False,
                    "reason": "deterministic_full_coverage",
                    "policy": {"serving": serving_payload()},
                    "n_predict": 0,
                    "http": None,
                    "raw_excerpt": "",
                },
            })
            continue
        if (
            job == "daily_brief"
            and EXTERNAL_ENDPOINT
            and os.environ.get("ABYSS_GEMMA4_SPARK_MODEL_DAILY_BRIEF", "").strip().lower() not in ENV_TRUE
        ):
            result = fallback[job]
            artifacts[job] = write_job_artifact(job, {
                "ok": True,
                "status": "ok_deterministic",
                "reason": "stack_endpoint_daily_brief_deterministic_low_latency",
                "source": source,
                "material_excerpt": material,
                "result": result,
                "feedback": machine_job_feedback(job, gate={"reason": "deterministic_low_latency", "policy": {"serving": serving_payload()}}, result=result),
                "model": {
                    "used": False,
                    "parsed_job": None,
                    "fallback_used": False,
                    "reason": "deterministic_low_latency",
                    "policy": {"serving": serving_payload()},
                    "n_predict": 0,
                    "http": None,
                    "raw_excerpt": "",
                },
            })
            continue
        job_allowed, job_gate = llm_available_for_jobs(job=job, request_class=request_class)
        policy = job_gate.get("policy") if isinstance(job_gate.get("policy"), dict) else {}
        if not job_allowed:
            result = fallback[job]
            artifacts[job] = write_job_artifact(job, {
                "ok": True,
                "status": "ok_gate_fallback",
                "reason": job_gate.get("reason"),
                "source": source,
                "material_excerpt": material,
                "result": result,
                "feedback": machine_job_feedback(job, gate=job_gate, result=result),
                "model": {"used": False, "fallback_used": True, "gate": job_gate},
            })
            continue
        n_predict = policy_n_predict(predict[job], policy, job)
        if job == "storage_classifier" and policy.get("decision") == "degraded" and policy.get("primary_reason") == "zram_high_compact_background":
            result = fallback[job]
            artifacts[job] = write_job_artifact(job, {
                "ok": True,
                "status": "ok_compact_fallback",
                "reason": "zram_high_compact_background",
                "source": source,
                "material_excerpt": material,
                "result": result,
                "feedback": machine_job_feedback(job, gate=job_gate, result=result),
                "model": {
                    "used": False,
                    "parsed_job": None,
                    "fallback_used": True,
                    "policy": policy,
                    "n_predict": 0,
                    "http": None,
                    "raw_excerpt": "",
                },
            })
            continue
        out, parsed = completion_json(machine_job_prompt(job, material), n_predict=n_predict, timeout=policy_timeout(210.0, policy), json_schema=machine_job_json_schema(job))
        parsed_ok, result = normalize_machine_job(job, parsed, material)
        if not parsed_ok:
            result = fallback[job]
        artifacts[job] = write_job_artifact(job, {
            "ok": True,
            "status": "ok_degraded" if parsed_ok and policy.get("decision") == "degraded" else "ok" if parsed_ok else "ok_fallback",
            "source": source,
            "material_excerpt": material,
            "result": result,
            "feedback": machine_job_feedback(job, gate=job_gate, result=result),
            "model": {
                "used": True,
                "parsed_job": parsed_ok,
                "fallback_used": not parsed_ok,
                "policy": policy,
                "n_predict": n_predict,
                "http": out.get("_http"),
                "error": out.get("error"),
                "raw_excerpt": str(out.get("_content") or "")[:1800],
            },
        })
    return artifacts


def run_job(job: str, limit: int = 8) -> dict[str, Any]:
    if job in {"dictation_quality", "daily_work_blocks", "intent_candidates", "command_grammar"}:
        return run_dictation_bundle(limit=limit, selected_jobs=[job])[job]
    if job == "operator_input_context":
        return run_operator_input_context(limit=limit)
    if job == "browser_reading":
        return run_browser_reading(limit=min(limit, 8))
    if job == "mcp_context_brief":
        return run_mcp_context_brief(limit=limit)
    if job in {"thermal_performance", "storage_classifier", "daily_brief"}:
        return run_machine_bundle(selected_jobs=[job])[job]
    if job in EXTENSION_JOB_NAMES:
        return run_extension_job(job, limit=limit)
    if job in EXPERIMENTAL_LANE_JOBS:
        return run_experimental_lane_job(job)
    raise ValueError(f"unknown job: {job}")


def job_latest_brief(job: str) -> dict[str, Any]:
    path = job_latest_path(job)
    item = load_json(path)
    model = item.get("model") if isinstance(item.get("model"), dict) else {}
    policy = model.get("policy") if isinstance(model.get("policy"), dict) else {}
    source = item.get("source") if isinstance(item.get("source"), dict) else {}
    result = item.get("result") if isinstance(item.get("result"), dict) else {}
    return {
        "job": job,
        "path": str(path),
        "exists": bool(item),
        "schema": item.get("schema"),
        "generated_at": item.get("generated_at"),
        "age_sec": source_age_sec(item.get("generated_at")),
        "ok": item.get("ok"),
        "status": item.get("status"),
        "source": {
            "kind": source.get("kind"),
            "count": source.get("count"),
        },
        "result_keys": sorted(str(key) for key in result.keys())[:16],
        "model": {
            "used": model.get("used"),
            "fallback_used": model.get("fallback_used"),
            "parsed_job": model.get("parsed_job"),
            "policy_decision": policy.get("decision"),
            "policy_reason": policy.get("primary_reason"),
        },
    }


