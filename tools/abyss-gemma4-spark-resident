def candidate_score(value: Any, default: float = 0.5) -> float:
    score = float_value(value)
    if score is None:
        score = default
    return round(max(0.0, min(1.0, score)), 3)


def candidate_route(value: Any, risk: str = "none") -> str:
    route = str(value or "").strip() or "human_review"
    if risk not in {"", "none", "low"} and route in {"e2b_ok", "deterministic", "model_input", "model_input_candidate"}:
        return "operator_review"
    mapping = {
        "recall": "nervous_recall_candidate",
        "web": "search_candidate",
        "code": "code_search_candidate",
        "nervous": "nervous_recall_candidate",
        "human_review": "human_review",
        "brief": "brief_candidate",
        "memory_card": "memory_card_candidate",
        "model_input": "model_input_candidate",
        "review_only": "human_review",
        "reject": "reject",
        "e2b_ok": "candidate_only",
        "deterministic": "operator_confirm",
    }
    return mapping.get(route, route)


def confidence_score(value: Any, default: float = 0.55) -> float:
    return {
        "very_low": 0.2,
        "low": 0.35,
        "medium": 0.6,
        "high": 0.82,
        "very_high": 0.92,
    }.get(str(value or "").strip().lower(), default)


def candidate_freshness_meta(source_item: dict[str, Any] | None, generated_at: Any = None) -> dict[str, Any]:
    source = source_item.get("source") if isinstance(source_item, dict) and isinstance(source_item.get("source"), dict) else {}
    freshness = source.get("freshness") if isinstance(source.get("freshness"), dict) else {}
    max_age = float_value(freshness.get("max_age_sec"))
    newest_age = float_value(freshness.get("newest_age_sec"))
    artifact_age = source_age_sec(generated_at)
    age = newest_age if newest_age is not None else artifact_age
    if age is None:
        freshness_class = "unknown"
    elif max_age is not None and age > max_age:
        freshness_class = "stale"
    elif max_age is not None and age > max_age * 0.75:
        freshness_class = "aging"
    elif artifact_age is not None and artifact_age > 86400.0:
        freshness_class = "stale"
    elif artifact_age is not None and artifact_age > 21600.0:
        freshness_class = "aging"
    else:
        freshness_class = "fresh"
    expires_at = None
    generated = parse_iso_timestamp(generated_at)
    if generated is not None:
        ttl = max_age if max_age is not None else 21600.0
        expires_at = (generated + timedelta(seconds=ttl)).replace(microsecond=0).isoformat().replace("+00:00", "Z")
    return {
        "freshness_class": freshness_class,
        "source_age_sec": round(age, 1) if age is not None else None,
        "artifact_age_sec": artifact_age,
        "max_age_sec": round(max_age, 1) if max_age is not None else None,
        "expires_at": expires_at,
    }


def candidate_correctness_risk(risk: str, source_item: dict[str, Any] | None, source_ids: list[str]) -> str:
    status = str(source_item.get("status") or "") if isinstance(source_item, dict) else ""
    model = source_item.get("model") if isinstance(source_item, dict) and isinstance(source_item.get("model"), dict) else {}
    if not source_ids:
        return "high"
    if str(risk or "none") not in {"", "none", "low"}:
        return "medium"
    if status in {"ok_fallback", "ok_gate_fallback", "ok_degraded", "ok_deterministic_fallback"}:
        return "medium"
    if model.get("fallback_used") is True:
        return "medium"
    return "low"


def candidate_utility_score(base_score: float, route: str, review_required: bool, freshness_class: str, correctness_risk: str) -> float:
    score = base_score
    if route in {"model_input_candidate", "nervous_recall_candidate", "brief_candidate"}:
        score += 0.08
    if review_required:
        score += 0.04
    if freshness_class == "aging":
        score -= 0.12
    elif freshness_class == "stale":
        score -= 0.28
    if correctness_risk == "medium":
        score -= 0.08
    elif correctness_risk == "high":
        score -= 0.25
    return candidate_score(score)


def candidate_heartbeat_priority(utility_score: float, review_required: bool, risk: str, freshness_class: str) -> int:
    if freshness_class == "stale":
        return 0
    priority = int(round(utility_score * 4))
    if review_required:
        priority += 1
    if risk not in {"", "none", "low"}:
        priority += 1
    return max(0, min(5, priority))


