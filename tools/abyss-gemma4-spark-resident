def resident_candidates_validate() -> dict[str, Any]:
    checks: list[dict[str, Any]] = []

    def add(level: str, key: str, message: str, details: Any = None) -> None:
        item = {"level": level, "key": key, "message": message}
        if details is not None:
            item["details"] = details
        checks.append(item)

    latest = load_json(CANDIDATES_LATEST)
    add("ok" if latest else "fail", "candidates_latest", "candidate read-model latest exists", {"path": str(CANDIDATES_LATEST)})
    if latest:
        add("ok" if latest.get("schema") == f"{SCHEMA_PREFIX}_candidate_readmodel_v2" else "fail", "schema", "candidate read-model schema is current", {"schema": latest.get("schema")})
        prefix_pack = latest.get("prefix_pack") if isinstance(latest.get("prefix_pack"), dict) else {}
        prefix_policies = prefix_pack.get("policies") if isinstance(prefix_pack.get("policies"), dict) else {}
        prompt_pack = latest.get("prompt_pack") if isinstance(latest.get("prompt_pack"), dict) else {}
        prompt_policies = prompt_pack.get("policies") if isinstance(prompt_pack.get("policies"), dict) else {}
        add(
            "ok" if prefix_pack.get("schema") == "abyss_machine_gemma4_prefix_pack_contract_v1" and prefix_pack.get("stable_prefix_first") is True and prefix_pack.get("changing_task_suffix") is True else "fail",
            "prefix_pack_contract",
            "candidate read-model exposes a stable-prefix/changing-suffix prompt contract",
            {"schema": prefix_pack.get("schema"), "contract_id": prefix_pack.get("contract_id")},
        )
        add(
            "fail" if prefix_policies.get("action_execution") is not False or prefix_policies.get("stack_mutation") is not False or prefix_policies.get("memory_writeback") is not False else "ok",
            "prefix_pack_non_executing",
            "prefix-pack contract cannot authorize execution, stack mutation, or memory writeback",
            {"policies": prefix_policies},
        )
        add(
            "ok" if prompt_pack.get("schema") == "abyss_machine_gemma4_prompt_pack_contract_v1" and prompt_pack.get("prefix_pack_id") == prefix_pack.get("contract_id") and prompt_pack.get("stable_prefix_first") is True else "fail",
            "prompt_pack_contract",
            "candidate read-model prompt pack points at the stable prefix contract",
            {"schema": prompt_pack.get("schema"), "prompt_pack_id": prompt_pack.get("prompt_pack_id")},
        )
        add(
            "fail" if prompt_policies.get("action_execution") is not False or prompt_policies.get("service_control") is not False or prompt_policies.get("raw_private_content") is not False else "ok",
            "prompt_pack_non_executing",
            "prompt-pack contract remains non-executing and compact",
            {"policies": prompt_policies},
        )
        source_jobs = latest.get("source_jobs") if isinstance(latest.get("source_jobs"), list) else []
        missing_jobs = sorted(set(CANDIDATE_SOURCE_JOBS) - {str(item.get("job")) for item in source_jobs if isinstance(item, dict)})
        add("fail" if missing_jobs else "ok", "source_jobs", "all candidate source jobs are represented", {"missing": missing_jobs, "expected": CANDIDATE_SOURCE_JOBS})
        candidates = [item for item in list_value(latest.get("candidates")) if isinstance(item, dict)]
        add("ok" if candidates else "warn", "candidates", "candidate queue has entries when source lanes have material", {"count": len(candidates)})
        bad_ids = [item for item in candidates if not item.get("candidate_id") or not item.get("source_job") or not item.get("source_id") or not list_value(item.get("source_ids"))]
        add("fail" if bad_ids else "ok", "candidate_identity", "candidates carry stable IDs, source jobs, and source IDs", {"bad": bad_ids[:5]})
        missing_v2 = [
            item
            for item in candidates
            if item.get("freshness_class") not in {"fresh", "aging", "stale", "unknown"}
            or item.get("correctness_risk") not in {"low", "medium", "high"}
            or not isinstance(item.get("utility_score"), (int, float))
            or not isinstance(item.get("heartbeat_priority"), int)
            or "e4b_review_eligible" not in item
            or not isinstance(item.get("selection_score"), (int, float))
            or item.get("selection_tier") not in set(SELECTION_TIER_PRIORITY.keys())
            or item.get("selection_lane") not in SELECTION_LANES
            or not list_value(item.get("selection_reasons"))
        ]
        add("fail" if missing_v2 else "ok", "candidate_v2_fields", "v2 candidates expose freshness, utility, heartbeat, E4B review, and selection fields", {"bad": missing_v2[:5]})
        experimental = [item for item in candidates if item.get("source_job") in EXPERIMENTAL_LANE_JOBS]
        add("fail" if experimental else "ok", "no_experimental_live", "experimental lanes are not promoted into live candidate queue", {"count": len(experimental)})
        executors = [item for item in candidates if item.get("action_execution") is not False]
        add("fail" if executors else "ok", "no_action_execution", "candidate queue never marks entries executable", {"bad": executors[:5]})
        action_cards = [item for item in candidates if item.get("kind") == "action_card"]
        unsafe_cards = [
            item
            for item in action_cards
            if not item.get("review_required")
            or not ((item.get("payload") or {}).get("confirm_required") is True)
            or (item.get("risk") not in {"none", "low"} and item.get("route") in {"candidate_only", "operator_confirm", "model_input_candidate"})
        ]
        add("fail" if unsafe_cards else "ok", "action_cards_guarded", "action cards require confirmation and risky cards route away", {"cards": len(action_cards), "unsafe": unsafe_cards[:5]})
        bad_risk_routes = [item for item in candidates if item.get("risk") not in {"none", "low"} and item.get("route") in {"candidate_only", "model_input_candidate", "nervous_recall_candidate"}]
        add("fail" if bad_risk_routes else "ok", "risk_routes_guarded", "high-risk candidates do not route to E2B/model-input/recall as safe answers", {"bad": bad_risk_routes[:5]})
        queues = latest.get("queues") if isinstance(latest.get("queues"), dict) else {}
        add("ok" if isinstance(queues, dict) and queues else "warn", "queues", "candidate read-model exposes review/search queues", {"keys": sorted(queues.keys()) if isinstance(queues, dict) else []})
        missing_queues = sorted({"heartbeat_candidates", "e4b_review_candidates", "selected", "selected_for_heartbeat", "selected_for_e4b_review"} - set(queues.keys()))
        add("fail" if missing_queues else "ok", "queues_v2", "candidate read-model exposes heartbeat, E4B, and selected queues", {"missing": missing_queues})
        selection = latest.get("selection") if isinstance(latest.get("selection"), dict) else {}
        add("ok" if selection.get("schema") == f"{SCHEMA_PREFIX}_candidate_selection_v1" else "fail", "selection_schema", "candidate read-model exposes a bounded selection summary", {"schema": selection.get("schema") if isinstance(selection, dict) else None})
        selected = [item for item in list_value(queues.get("selected")) if isinstance(item, dict)]
        selected_for_heartbeat = [item for item in list_value(queues.get("selected_for_heartbeat")) if isinstance(item, dict)]
        selected_for_e4b = [item for item in list_value(queues.get("selected_for_e4b_review")) if isinstance(item, dict)]
        operator_value_exists = any(item.get("selection_tier") in {"operator_attention", "e4b_review"} or item.get("review_required") is True for item in candidates)
        selected_operator_value = any(item.get("selection_tier") in {"operator_attention", "e4b_review"} or item.get("review_required") is True for item in selected)
        background_top = [item for item in selected[:5] if item.get("kind") in {"source_quality", "quality_eval"} and item.get("selection_tier") in {"background_monitor", "model_input_support"}]
        available_selected_lanes = {str(item.get("selection_lane")) for item in candidates if candidate_selected(item) and item.get("selection_lane") in SELECTION_LANES}
        selected_top_lanes = {str(item.get("selection_lane")) for item in selected[: min(8, len(selected))] if item.get("selection_lane") in SELECTION_LANES}
        expected_lanes = min(len(available_selected_lanes), 4)
        add("fail" if operator_value_exists and not selected_operator_value else "ok", "selection_operator_value", "selection keeps operator-review/E4B material visible when it exists", {"selected": len(selected), "operator_value_exists": operator_value_exists})
        add("fail" if operator_value_exists and len(background_top) >= 5 else "ok", "selection_not_background_dominated", "top selection is not dominated by routine source-quality or quality-eval support rows", {"background_top": background_top[:5]})
        add("fail" if expected_lanes and len(selected_top_lanes) < expected_lanes else "ok", "selection_lane_diverse", "selected top spans available selection lanes instead of one signal family", {"available_lanes": sorted(available_selected_lanes), "top_lanes": sorted(selected_top_lanes), "expected_min": expected_lanes})
        bad_selected_heartbeat = [item for item in selected_for_heartbeat if int_value(item.get("heartbeat_priority"), 0) <= 0 or item.get("selection_tier") not in {"operator_attention", "e4b_review", "heartbeat_watch"}]
        bad_selected_e4b = [item for item in selected_for_e4b if item.get("e4b_review_eligible") is not True or item.get("selection_tier") not in {"operator_attention", "e4b_review", "heartbeat_watch"}]
        add("fail" if bad_selected_heartbeat else "ok", "selected_heartbeat_guarded", "selected heartbeat queue carries selected heartbeat/watch material only", {"bad": bad_selected_heartbeat[:5]})
        add("fail" if bad_selected_e4b else "ok", "selected_e4b_guarded", "selected E4B queue carries selected E4B-review material only", {"bad": bad_selected_e4b[:5]})
        represented_jobs = {str(item.get("source_job")) for item in candidates if isinstance(item, dict)}
        def validation_job_has_candidate_material(job: str) -> bool:
            item = load_json(job_latest_path(job))
            if str(item.get("status") or "") in {"idle", "skipped"}:
                return False
            result = item.get("result") if isinstance(item.get("result"), dict) else {}
            candidate_keys = {
                "dictation_quality": ("quality_issues", "vocabulary_candidates"),
                "daily_work_blocks": ("blocks",),
                "intent_candidates": ("candidates",),
                "command_grammar": ("patterns", "proposed_triggers"),
                "operator_input_context": ("contexts", "lanes"),
                "thermal_performance": ("incidents",),
                "storage_classifier": ("items",),
                "browser_reading": ("pages", "summaries"),
                "daily_brief": ("sections",),
                "mcp_context_brief": ("contexts", "routes"),
                "source_quality_scorer": ("sources", "items"),
                "resident_quality_eval": ("evaluated_jobs",),
                "action_card_compiler": ("cards",),
                "bounded_hint_generator": ("hints",),
                "risk_sentinel": ("findings", "risks", "routes"),
                "short_doc_classifier": ("documents", "items"),
            }
            return any(list_value(result.get(key)) for key in candidate_keys.get(job, ()))
        promotable_jobs = {job for job in set(CANDIDATE_SOURCE_JOBS) - {"query_expansion", "rerank_lite"} if validation_job_has_candidate_material(job)}
        required_promoted = sorted(promotable_jobs - represented_jobs)
        add("warn" if required_promoted else "ok", "promoted_useful_lanes", "useful resident lanes are promoted into candidates when material exists", {"missing": required_promoted})
    fails = sum(1 for item in checks if item["level"] == "fail")
    warnings = sum(1 for item in checks if item["level"] == "warn")
    data = {
        "schema": f"{SCHEMA_PREFIX}_candidates_validate_v1",
        "version": VERSION,
        "generated_at": now_iso(),
        "profile": PROFILE,
        "ok": fails == 0,
        "checks": checks,
        "summary": {"fails": fails, "warnings": warnings, "checks": len(checks), "candidates": len(list_value(latest.get("candidates"))) if latest else 0},
        "paths": {"latest": str(CANDIDATES_ROOT / "validate" / "latest.json"), "candidates_latest": str(CANDIDATES_LATEST)},
    }
    write_json(CANDIDATES_ROOT / "validate" / "latest.json", data)
    return data


