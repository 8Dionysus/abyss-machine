def validate() -> dict[str, Any]:
    checks: list[dict[str, Any]] = []

    def add(level: str, key: str, message: str, details: Any = None) -> None:
        item = {"level": level, "key": key, "message": message}
        if details is not None:
            item["details"] = details
        checks.append(item)

    for path in (MODEL_PATH, SELF):
        add("ok" if path.exists() else "fail", f"path:{path.name}", "required path exists", str(path))
    add(("ok" if LLAMA_SERVER.exists() else "fail") if not EXTERNAL_ENDPOINT else ("ok" if LLAMA_SERVER.exists() else "warn"), "path:llama-server", "local llama-server exists; required only for host-local fallback", {"path": str(LLAMA_SERVER), "serving": serving_payload()})
    svc = service_state()
    if EXTERNAL_ENDPOINT:
        add("ok" if svc.get("active") != "active" else "warn", "host_service_inactive", "host resident service should not run while stack owns serving", svc)
        add("ok" if svc.get("timer", {}).get("active") != "active" else "warn", "start_timer_inactive", "host start timer should not launch a duplicate server while stack owns serving", svc.get("timer"))
    else:
        add("ok" if svc.get("enabled") in {"enabled", "linked", "static"} else "warn", "service_enabled", "resident service is enabled for user manager", svc)
        add("ok" if svc.get("timer", {}).get("active") == "active" else "warn", "start_timer_active", "resident start timer is active", svc.get("timer"))
    add("ok" if svc.get("monitor_timer", {}).get("active") == "active" else "warn", "monitor_timer_active", "monitor timer is active", svc.get("monitor_timer"))
    add("ok" if svc.get("digest_timer", {}).get("active") == "active" else "warn", "digest_timer_active", "digest timer is active", svc.get("digest_timer"))
    add("ok" if svc.get("jobs_timer", {}).get("active") == "active" else "warn", "jobs_timer_active", "jobs timer is active", svc.get("jobs_timer"))
    add("ok" if svc.get("micro_timer", {}).get("active") == "active" else "warn", "micro_timer_active", "micro timer is active", svc.get("micro_timer"))
    candidates_latest = load_json(CANDIDATES_LATEST)
    add("ok" if candidates_latest.get("schema") == f"{SCHEMA_PREFIX}_candidate_readmodel_v2" else "warn", "candidates_latest", "candidate read-model latest exists", {"path": str(CANDIDATES_LATEST), "schema": candidates_latest.get("schema")})
    evals_latest = load_json(EVALS_LATEST)
    add("ok" if evals_latest.get("schema") == f"{SCHEMA_PREFIX}_heartbeat_evals_v1" else "warn", "evals_latest", "heartbeat eval scorecard latest exists", {"path": str(EVALS_LATEST), "schema": evals_latest.get("schema")})
    evals_validate_latest = load_json(EVALS_VALIDATE_LATEST)
    add("ok" if evals_validate_latest.get("ok") else "warn", "evals_validate_latest", "heartbeat eval validation latest passes", {"path": str(EVALS_VALIDATE_LATEST), "ok": evals_validate_latest.get("ok"), "summary": evals_validate_latest.get("summary")})
    pf = preflight(force=False)
    add("ok" if pf.get("ok") or health().get("ok") else "warn", "preflight", "preflight allows start or service is already running", pf.get("summary"))
    h = health()
    add("ok" if h.get("ok") else "warn", "health", "resident server health endpoint responds", h.get("health", {}).get("_http") or h.get("health"))
    fails = sum(1 for item in checks if item["level"] == "fail")
    warnings = sum(1 for item in checks if item["level"] == "warn")
    data = {"schema": f"{SCHEMA_PREFIX}_validate_v1", "version": VERSION, "generated_at": now_iso(), "profile": PROFILE, "ok": fails == 0, "checks": checks, "summary": {"fails": fails, "warnings": warnings, "checks": len(checks)}}
    write_json(ROOT / "validate" / "latest.json", data)
    return data


def systemctl(action: str) -> dict[str, Any]:
    out = run(["systemctl", "--user", action, SERVICE], timeout=20.0)
    return {"schema": f"{SCHEMA_PREFIX}_systemctl_v1", "generated_at": now_iso(), "action": action, "ok": out.get("ok"), "returncode": out.get("returncode"), "stdout": out.get("stdout"), "stderr": out.get("stderr")}


def main() -> int:
    parser = argparse.ArgumentParser(description="Gemma4 E2B resident candidate controller")
    parser.add_argument("command", choices=["paths", "preflight", "serve", "status", "monitor", "digest", "policy", "smoke", "audit", "validate", "job", "micro", "jobs", "jobs-validate", "candidates", "candidates-validate", "evals", "evals-validate", "start", "stop"])
    parser.add_argument("job_name", nargs="?")
    parser.add_argument("--json", action="store_true")
    parser.add_argument("--force", action="store_true")
    parser.add_argument("--limit", type=int, default=None)
    parser.add_argument("--request-class", choices=["foreground", "digest", "job", "jobs", "sustained"], default="job")
    parser.add_argument("--no-generation", action="store_true", help="skip the audit tiny live generation probe")
    args = parser.parse_args()
    if args.command not in {"job", "policy", "jobs"} and args.job_name:
        parser.error(f"{args.command} does not accept an extra positional argument: {args.job_name}")
    ensure_dirs()
    if args.command == "paths":
        result = paths_payload()
    elif args.command == "preflight":
        result = preflight(force=args.force)
    elif args.command == "serve":
        return serve(args)
    elif args.command == "status":
        result = status(write=True)
    elif args.command == "monitor":
        result = monitor()
    elif args.command == "digest":
        result = digest(limit=args.limit or 3)
    elif args.command == "policy":
        if args.job_name and args.job_name not in JOB_NAMES:
            parser.error(f"unknown job_name for policy: {args.job_name}")
        result = resident_policy(request_class=args.request_class, job=args.job_name, write=True)
    elif args.command == "smoke":
        result = smoke()
    elif args.command == "audit":
        result = resident_audit(include_generation=not args.no_generation)
    elif args.command == "validate":
        result = validate()
    elif args.command == "job":
        if not args.job_name:
            parser.error("job command requires job_name")
        if args.job_name not in JOB_NAMES:
            parser.error(f"unknown job_name: {args.job_name}")
        result = run_job(args.job_name, limit=args.limit or 8)
        if args.job_name in CANDIDATE_SOURCE_JOBS:
            candidate_data = resident_candidates()
            result.setdefault("paths", {})
            if isinstance(result["paths"], dict):
                result["paths"]["candidates_latest"] = str(CANDIDATES_LATEST)
            result["candidate_readmodel"] = {"ok": candidate_data.get("ok"), "status": candidate_data.get("status"), "summary": candidate_data.get("summary")}
    elif args.command == "micro":
        result = run_micro(limit=args.limit or 4)
    elif args.command == "jobs":
        jobs_action = str(args.job_name or "latest")
        if jobs_action in {"latest", "status", "list"}:
            result = jobs_latest_payload(mode=jobs_action)
        elif jobs_action == "run":
            result = run_jobs(limit=args.limit or 8, action=jobs_action)
        elif jobs_action == "refresh":
            result = refresh_jobs_aggregate()
        else:
            parser.error("jobs action must be one of: latest, status, list, run, refresh")
    elif args.command == "jobs-validate":
        result = jobs_validate()
    elif args.command == "candidates":
        result = resident_candidates(limit=args.limit or 64)
    elif args.command == "candidates-validate":
        result = resident_candidates_validate()
    elif args.command == "evals":
        result = resident_evals()
    elif args.command == "evals-validate":
        result = resident_evals_validate()
    elif args.command == "start":
        result = systemctl("start")
    elif args.command == "stop":
        result = systemctl("stop")
    else:
        parser.error("unknown command")
    print(json.dumps(result, ensure_ascii=False, indent=2) if args.json else (str(result.get("status") or result.get("ok"))))
    return 0 if result.get("ok", True) else 1


if __name__ == "__main__":
    raise SystemExit(main())
