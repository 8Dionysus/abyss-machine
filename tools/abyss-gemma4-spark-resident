def resident_evals_validate() -> dict[str, Any]:
    checks: list[dict[str, Any]] = []

    def add(level: str, key: str, message: str, details: Any = None) -> None:
        item = {"level": level, "key": key, "message": message}
        if details is not None:
            item["details"] = details
        checks.append(item)

    latest = load_json(EVALS_LATEST)
    if not latest:
        latest = resident_evals()
    age = source_age_sec(latest.get("generated_at"))
    families = (latest.get("summary") or {}).get("families") if isinstance(latest.get("summary"), dict) else {}
    promotion_gates = latest.get("promotion_gates") if isinstance(latest.get("promotion_gates"), dict) else {}
    quality_trend = latest.get("quality_trend") if isinstance(latest.get("quality_trend"), dict) else {}
    fixture_candidates = latest.get("fixture_candidates") if isinstance(latest.get("fixture_candidates"), dict) else {}
    readiness = latest.get("readiness_recommendation") if isinstance(latest.get("readiness_recommendation"), dict) else {}
    failed_gates = [key for key, value in promotion_gates.items() if isinstance(value, dict) and value.get("passed") is not True]
    add("ok" if latest.get("schema") == f"{SCHEMA_PREFIX}_heartbeat_evals_v1" else "fail", "schema", "eval scorecard schema is current", {"schema": latest.get("schema")})
    add("ok" if latest.get("ok") else "fail", "latest_ok", "latest eval scorecard passes promotion gates", {"status": latest.get("status"), "summary": latest.get("summary")})
    add("ok" if age is not None and age <= 21600.0 else "warn", "freshness", "eval scorecard is fresh enough for resident audit", {"age_sec": age})
    add("ok" if all(family in families for family in EVAL_FAMILIES) else "fail", "families", "all eval families are present", {"families": sorted(families.keys()) if isinstance(families, dict) else []})
    add("ok" if not failed_gates else "fail", "promotion_gates", "promotion gates pass", {"failed": failed_gates, "gates": promotion_gates})
    add("ok" if quality_trend.get("schema") == f"{SCHEMA_PREFIX}_quality_trend_v1" and isinstance(quality_trend.get("lane_quality"), dict) else "fail", "quality_trend", "quality trend and lane quality are tracked", {"schema": quality_trend.get("schema"), "history_points": quality_trend.get("history_points")})
    add("ok" if fixture_candidates.get("schema") == f"{SCHEMA_PREFIX}_fixture_candidates_v1" else "fail", "fixture_candidates", "failed live cases are surfaced as fixture candidates", {"schema": fixture_candidates.get("schema"), "summary": fixture_candidates.get("summary")})
    add("ok" if readiness.get("score_only") is True and readiness.get("automatic_promotion") is False else "fail", "score_only_readiness", "readiness recommendation is score-only and non-promoting", readiness)
    fails = sum(1 for item in checks if item["level"] == "fail")
    warnings = sum(1 for item in checks if item["level"] == "warn")
    data = {
        "schema": f"{SCHEMA_PREFIX}_heartbeat_evals_validate_v1",
        "version": VERSION,
        "generated_at": now_iso(),
        "profile": PROFILE,
        "ok": fails == 0,
        "checks": checks,
        "summary": {"fails": fails, "warnings": warnings, "checks": len(checks), "eval_status": latest.get("status"), "overall_score": ((latest.get("summary") or {}).get("overall_score") if isinstance(latest.get("summary"), dict) else None)},
        "paths": {"latest": str(EVALS_VALIDATE_LATEST), "evals_latest": str(EVALS_LATEST), "fixture_candidates_latest": str(EVALS_FIXTURE_CANDIDATES_LATEST)},
    }
    write_json(EVALS_VALIDATE_LATEST, data)
    return data


