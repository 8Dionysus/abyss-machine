FALLBACK_JOB_STATUSES = {"ok_fallback", "ok_gate_fallback", "ok_compact_fallback"}


def job_run_entry(name: str, item: dict[str, Any]) -> dict[str, Any]:
    model = item.get("model") if isinstance(item.get("model"), dict) else {}
    policy = model.get("policy") if isinstance(model.get("policy"), dict) else {}
    if not policy and isinstance(model.get("gate"), dict):
        gate_policy = model["gate"].get("policy")
        policy = gate_policy if isinstance(gate_policy, dict) else {}
    return {
        "ok": item.get("ok"),
        "status": item.get("status"),
        "latest": str(job_latest_path(name)),
        "source": item.get("source"),
        "feedback": item.get("feedback"),
        "model": {
            "used": model.get("used") if model else None,
            "fallback_used": model.get("fallback_used") if model else None,
            "policy_decision": policy.get("decision"),
            "policy_reason": policy.get("primary_reason"),
            "n_predict": model.get("n_predict") if model else None,
        },
    }


def jobs_summary_from_results(results: dict[str, dict[str, Any]], started: float) -> dict[str, Any]:
    summary = {
        "jobs": len(results),
        "ok": sum(1 for item in results.values() if item.get("ok")),
        "failed": sum(1 for item in results.values() if not item.get("ok")),
        "idle": sum(1 for item in results.values() if item.get("status") == "idle"),
        "skipped": sum(1 for item in results.values() if item.get("status") == "skipped"),
        "degraded": sum(1 for item in results.values() if item.get("status") == "ok_degraded"),
        "gate_fallback": sum(1 for item in results.values() if item.get("status") == "ok_gate_fallback"),
        "fallback_artifacts": sum(1 for item in results.values() if item.get("status") in FALLBACK_JOB_STATUSES),
        "model_used": sum(1 for item in results.values() if isinstance(item.get("model"), dict) and item.get("model", {}).get("used")),
        "model_parse_fallback": sum(1 for item in results.values() if isinstance(item.get("model"), dict) and item.get("model", {}).get("used") and item.get("model", {}).get("fallback_used")),
        "elapsed_ms": round((time.monotonic() - started) * 1000, 1),
    }
    candidates_data = resident_candidates()
    summary["candidate_readmodel"] = {
        "ok": candidates_data.get("ok"),
        "status": candidates_data.get("status"),
        "candidates": (candidates_data.get("summary") or {}).get("candidates") if isinstance(candidates_data.get("summary"), dict) else None,
    }
    return summary


def jobs_latest_payload(mode: str = "latest") -> dict[str, Any]:
    latest = load_json(JOBS_LATEST)
    summary = latest.get("summary") if isinstance(latest.get("summary"), dict) else {}
    jobs = [job_latest_brief(job) for job in JOB_NAMES]
    stale_or_missing = [
        row["job"]
        for row in jobs
        if not row.get("exists") or row.get("status") in {"skipped", "error"} or not row.get("ok")
    ]
    data = {
        "schema": f"{SCHEMA_PREFIX}_jobs_{mode}_v1",
        "version": VERSION,
        "generated_at": now_iso(),
        "profile": PROFILE,
        "ok": bool(latest),
        "status": "ok" if latest else "missing",
        "read_only": True,
        "mutation": False,
        "mode": mode,
        "latest_run": {
            "path": str(JOBS_LATEST),
            "exists": bool(latest),
            "schema": latest.get("schema"),
            "generated_at": latest.get("generated_at"),
            "age_sec": source_age_sec(latest.get("generated_at")),
            "ok": latest.get("ok"),
            "summary": summary,
        },
        "jobs": jobs if mode in {"status", "list"} else [],
        "candidate_readmodel": candidate_readmodel_latest_brief() if mode == "status" else {},
        "summary": {
            "jobs": len(jobs),
            "latest_exists": bool(latest),
            "latest_age_sec": source_age_sec(latest.get("generated_at")),
            "stale_or_missing": len(stale_or_missing),
        },
        "commands": {
            "latest": "abyss-machine ai llm resident jobs latest --json",
            "status": "abyss-machine ai llm resident jobs status --json",
            "list": "abyss-machine ai llm resident jobs list --json",
            "run": "abyss-machine ai llm resident jobs run --json",
            "refresh": "abyss-machine ai llm resident jobs refresh --json",
            "validate": "abyss-machine ai llm resident jobs-validate --json",
        },
        "non_claims": [
            "This command is read-only and does not start model generation.",
            "Use jobs run for explicit model generation.",
            "Use jobs refresh to rebuild the aggregate and candidate read-model from individual latest artifacts without model generation.",
        ],
    }
    if mode in {"status", "list"}:
        data["stale_or_missing_jobs"] = stale_or_missing
    return data


def run_jobs(limit: int = 8, action: str = "run") -> dict[str, Any]:
    started = time.monotonic()
    results: dict[str, dict[str, Any]] = {}
    results.update(run_dictation_bundle(limit=limit, request_class="jobs"))
    results["operator_input_context"] = run_operator_input_context(limit=limit)
    results["browser_reading"] = run_browser_reading(limit=min(limit, 4), request_class="jobs")
    results.update(run_machine_bundle(request_class="jobs"))
    results["mcp_context_brief"] = run_mcp_context_brief(limit=limit)
    for job in EXTENSION_JOB_NAMES:
        results[job] = run_extension_job(job, limit=min(limit, 8), request_class="jobs")
    for job in EXPERIMENTAL_LANE_JOBS:
        results[job] = run_experimental_lane_job(job)
    summary = jobs_summary_from_results(results, started)
    data = {
        "schema": f"{SCHEMA_PREFIX}_jobs_run_v1",
        "version": VERSION,
        "generated_at": now_iso(),
        "profile": PROFILE,
        "operation": "jobs_run",
        "action": action,
        "read_only": False,
        "mutation": True,
        "run_receipt": {
            "command": f"abyss-machine ai llm resident jobs {action} --json",
            "started_monotonic": started,
            "limit": limit,
        },
        "ok": summary["failed"] == 0,
        "summary": summary,
        "jobs": {name: job_run_entry(name, item) for name, item in results.items()},
        "paths": {
            "latest": str(JOBS_LATEST),
            "root": str(JOBS_ROOT),
            "candidates_latest": str(CANDIDATES_LATEST),
            "history_glob": str(JOBS_ROOT / "runs" / "jsonl" / "YYYY" / "MM" / "YYYY-MM-DD.jsonl"),
        },
    }
    write_json(JOBS_LATEST, data)
    append_jsonl(daily_path(JOBS_ROOT / "runs" / "jsonl"), data)
    return data


