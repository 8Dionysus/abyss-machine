    return max(minimums.get(str(job or ""), 120), min(caps.get(str(job or ""), base), int(base * factor)))


def policy_source_limit(policy: dict[str, Any], fallback_limit: int) -> int:
    limits = policy.get("limits") if isinstance(policy.get("limits"), dict) else {}
    max_records = int_value(limits.get("max_source_records"), fallback_limit)
    if max_records <= 0:
        return 0
    return min(fallback_limit, max_records)


def policy_timeout(default: float, policy: dict[str, Any]) -> float:
    if policy.get("decision") == "degraded":
        return max(default, 150.0)
    return default


