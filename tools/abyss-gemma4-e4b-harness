def llama_completion_path(profile: dict[str, Any]) -> Path:
    runtime = profile.get("runtime") if isinstance(profile.get("runtime"), dict) else {}
    cli = Path(str(runtime.get("llama_cli") or ""))
    return cli.with_name(LLAMA_COMPLETION_NAME) if cli.name else Path("")


def profile_context_size(profile: dict[str, Any]) -> int:
    return max(8192, min(int_value(profile.get("context_size"), 8192), 32768))


def memory_summary(memory: dict[str, Any]) -> dict[str, Any]:
    summary = memory.get("meminfo", {}).get("summary", {}) if isinstance(memory.get("meminfo"), dict) else {}
    zram = memory.get("zram", {}).get("summary", {}) if isinstance(memory.get("zram"), dict) else {}
    psi = memory.get("psi") if isinstance(memory.get("psi"), dict) else {}
    return {
        "class": memory.get("class"),
        "mem_available_mib": summary.get("mem_available_mib"),
        "swap_used_percent": summary.get("swap_used_percent"),
        "swap_free_mib": summary.get("swap_free_mib"),
        "psi_some_avg10": (psi.get("some") or {}).get("avg10") if isinstance(psi.get("some"), dict) else None,
        "psi_full_avg10": (psi.get("full") or {}).get("avg10") if isinstance(psi.get("full"), dict) else None,
        "zram_resident_mib": zram.get("total_memory_mib"),
        "zram_logical_to_memory_ratio": zram.get("logical_to_memory_ratio"),
    }


def preflight(write_latest: bool = True) -> dict[str, Any]:
    registry, profile = registry_profile()
    completion_path = llama_completion_path(profile)
    memory = run_json(["abyss-machine", "memory", "status", "--json"], timeout=30.0)
    resource = run_json(["abyss-machine", "resource", "plan", "--class", "heavy", "--kind", "ai", "--no-thermal-sample", "--json"], timeout=45.0)
    mem = memory_summary(memory)
    blocked: list[str] = []
    warnings: list[str] = []
    if not registry.get("ok"):
        blocked.append("llm_registry_unavailable")
    if not profile:
        blocked.append("gemma4.workhorse_profile_missing")
    if profile and profile.get("local_exists") is not True:
        blocked.append("gemma4.workhorse_model_missing")
    if not completion_path.exists():
        blocked.append("llama_completion_missing")
    if resource.get("decision") != "allow":
        blocked.append(f"resource_decision={resource.get('decision')}")
    swap_used = float_value(mem.get("swap_used_percent"))
    if swap_used is not None and swap_used > MAX_SWAP_USED_PERCENT_FOR_MODEL:
        blocked.append(f"swap_used_percent={swap_used}>{MAX_SWAP_USED_PERCENT_FOR_MODEL:g}")
    swap_free = float_value(mem.get("swap_free_mib"))
    if swap_free is not None and swap_free < MIN_SWAP_FREE_MIB_FOR_MODEL:
        blocked.append(f"swap_free_mib={swap_free}<{MIN_SWAP_FREE_MIB_FOR_MODEL:g}")
    mem_available = float_value(mem.get("mem_available_mib"))
    if mem_available is not None and mem_available < MIN_MEM_AVAILABLE_MIB_FOR_MODEL:
        blocked.append(f"mem_available_mib={mem_available}<{MIN_MEM_AVAILABLE_MIB_FOR_MODEL:g}")
    psi_some = float_value(mem.get("psi_some_avg10")) or 0.0
    psi_full = float_value(mem.get("psi_full_avg10")) or 0.0
    if psi_some >= 2.0 or psi_full >= 1.0:
        blocked.append(f"memory_psi_stall_some={psi_some}_full={psi_full}")
    if swap_used is not None and swap_used > 75.0:
        warnings.append(f"swap_used_percent={swap_used}")
    data = {
        "schema": f"{SCHEMA_PREFIX}_preflight_v1",
        "version": VERSION,
        "generated_at": now_iso(),
        "ok": not blocked,
        "profile": PROFILE,
        "decision": "allow" if not blocked else "block",
        "blocked_reasons": blocked,
        "warnings": warnings,
        "model": {
            "local_path": profile.get("local_path"),
            "local_exists": profile.get("local_exists"),
            "quant": profile.get("quant"),
            "context_size": profile_context_size(profile),
            "size_bytes": profile.get("size_bytes"),
            "llama_completion": str(completion_path),
            "llama_completion_exists": completion_path.exists(),
        },
        "memory": mem,
        "resource": {
            "decision": resource.get("decision"),
            "blocked_reasons": resource.get("blocked_reasons"),
            "denied_reasons": resource.get("denied_reasons"),
            "systemd": resource.get("systemd"),
        },
        "policy": {
            "resident_service": False,
            "starts_llama_server": False,
            "default_review_runs_model": False,
            "action_execution": False,
            "swap_hard_block_percent": MAX_SWAP_USED_PERCENT_FOR_MODEL,
            "min_swap_free_mib": MIN_SWAP_FREE_MIB_FOR_MODEL,
            "min_mem_available_mib": MIN_MEM_AVAILABLE_MIB_FOR_MODEL,
        },
        "paths": paths_payload()["latest"],
    }
    if write_latest:
        write_json(ROOT / "preflight" / "latest.json", data)
    return data


def candidate_source_ids(candidate: dict[str, Any]) -> list[str]:
    source_ids: list[str] = []
    for item in list_value(candidate.get("source_ids")):
        text = str(item or "").strip()
        if text and text not in source_ids:
            source_ids.append(text)
    single = str(candidate.get("source_id") or "").strip()
    if single and single not in source_ids:
        source_ids.append(single)
    return source_ids[:8]


def candidate_excerpt(candidate: dict[str, Any], payload: dict[str, Any]) -> str:
    for key in ("excerpt", "summary", "reason", "next_action", "follow_up", "classification", "verdict"):
        value = payload.get(key)
        if value:
            return compact_text(value, 360)
    for key in ("text", "title"):
        value = candidate.get(key)
        if value:
            return compact_text(value, 360)
    return compact_text(candidate.get("candidate_id"), 160)


def candidate_uncertainty_notes(candidate: dict[str, Any], source_ids: list[str], payload: dict[str, Any]) -> list[str]:
    notes: list[str] = []
    if not source_ids:
        notes.append("missing_source_ids")
    freshness = str(candidate.get("freshness_class") or "")
    if freshness and freshness != "fresh":
        notes.append(f"freshness={freshness}")
    correctness = str(candidate.get("correctness_risk") or "")
    if correctness in {"medium", "high"}:
        notes.append(f"correctness_risk={correctness}")
    utility = float_value(candidate.get("utility_score"))
    if utility is not None and utility < 0.35:
        notes.append(f"low_utility={utility:.2f}")
    if candidate.get("review_required") is True:
        notes.append("operator_review_required")
    tier = str(candidate.get("selection_tier") or "")
    if tier:
        notes.append(f"selection_tier={tier}")
    for key in ("missing_data", "missing_evidence", "source_refs_missing"):
        value = payload.get(key)
        if value:
            notes.append(f"{key}={compact_text(value, 140)}")
    if not notes:
        notes.append("derived_candidate_not_source_truth")
    return notes[:8]


def candidate_rejection_reasons(candidate: dict[str, Any], source_ids: list[str], payload: dict[str, Any]) -> list[str]:
    reasons: list[str] = []
    if not source_ids:
        reasons.append("missing_source_ids")
    if candidate.get("action_execution") is True:
        reasons.append("unsafe_action_execution_claim")
    if str(candidate.get("freshness_class") or "") == "stale":
        reasons.append("stale_candidate")
    utility = float_value(candidate.get("utility_score"))
    if utility is not None and utility < 0.2:
        reasons.append(f"utility_below_pack_threshold={utility:.2f}")
    route = str(candidate.get("route") or "")
    if route in {"direct", "execute", "e2b_ok", "service_mutation"}:
        reasons.append(f"unsafe_route={route}")
    if payload.get("source_refs_missing") is True:
        reasons.append("source_refs_missing")
    return reasons[:8]


def candidate_record(candidate: dict[str, Any]) -> dict[str, Any]:
    payload = candidate.get("payload") if isinstance(candidate.get("payload"), dict) else {}
    source_ids = candidate_source_ids(candidate)
    excerpt = candidate_excerpt(candidate, payload)
    uncertainty = candidate_uncertainty_notes(candidate, source_ids, payload)
    return {
        "candidate_id": str(candidate.get("candidate_id") or ""),
        "kind": str(candidate.get("kind") or ""),
        "source_job": str(candidate.get("source_job") or ""),
        "source_id": source_ids[0] if source_ids else "",
        "source_ids": source_ids,
        "title": compact_text(candidate.get("title"), 160),
        "text": compact_text(candidate.get("text"), 420),
        "source_excerpts": [{"source_id": sid, "excerpt": excerpt} for sid in source_ids[:3]] or [{"source_id": "", "excerpt": excerpt}],
        "score": candidate.get("score"),
        "confidence": candidate.get("confidence"),
        "utility_score": float_value(candidate.get("utility_score")),
        "selection_score": float_value(candidate.get("selection_score")),
        "selection_tier": candidate.get("selection_tier"),
        "selection_lane": candidate.get("selection_lane"),
        "selection_reasons": list_value(candidate.get("selection_reasons"))[:8],
        "correctness_risk": candidate.get("correctness_risk"),
        "freshness_class": candidate.get("freshness_class"),
        "heartbeat_priority": int_value(candidate.get("heartbeat_priority")),
        "e4b_review_eligible": candidate.get("e4b_review_eligible") is True,
        "risk": candidate.get("risk") or "none",
        "route": candidate.get("route"),
        "review_required": candidate.get("review_required") is True,
        "action_execution": False,
        "uncertainty_notes": uncertainty,
        "source_artifact": candidate.get("source_artifact"),
        "source_generated_at": candidate.get("source_generated_at"),
        "artifact_age_sec": float_value(candidate.get("artifact_age_sec")),
        "expires_at": candidate.get("expires_at"),
        "payload": {
            key: payload.get(key)
            for key in ("classification", "allowed_use", "rank", "query", "card_id", "confirm_required", "reason", "missing_data", "missing_evidence", "doc_type", "issue_type", "verdict", "next_action", "source_refs_missing")
            if key in payload
        },
    }


def candidate_selection_tier_priority(value: Any) -> int:
    return SELECTION_TIER_PRIORITY.get(str(value or ""), 0)


def candidate_review_sort_key(candidate: dict[str, Any]) -> tuple[int, float, int, int, int, float, int, str]:
    selection_score = float_value(candidate.get("selection_score"))
    if selection_score is None:
        selection_score = float_value(candidate.get("utility_score")) or 0.0
    return (
        candidate_selection_tier_priority(candidate.get("selection_tier")),
        selection_score,
        int_value(candidate.get("heartbeat_priority")),
        1 if candidate.get("e4b_review_eligible") is True else 0,
        1 if candidate.get("review_required") is True else 0,
        float_value(candidate.get("utility_score")) or 0.0,
        0 if str(candidate.get("freshness_class") or "") == "fresh" else -1,
        str(candidate.get("candidate_id") or ""),
    )


def compact_rejected_candidate(candidate: dict[str, Any], reasons: list[str]) -> dict[str, Any]:
    record = candidate_record(candidate)
    return {
        "candidate_id": record.get("candidate_id"),
        "kind": record.get("kind"),
        "source_job": record.get("source_job"),
        "source_ids": record.get("source_ids"),
        "title": record.get("title"),
        "route": record.get("route"),
        "utility_score": record.get("utility_score"),
        "selection_score": record.get("selection_score"),
        "selection_tier": record.get("selection_tier"),
        "selection_lane": record.get("selection_lane"),
        "freshness_class": record.get("freshness_class"),
        "rejection_reasons": reasons,
    }


def runtime_degradation_context(evals_latest: dict[str, Any], policy_latest: dict[str, Any]) -> dict[str, Any]:
    degraded_jobs = []
    for row in list_value(((evals_latest.get("scorecard") or {}) if isinstance(evals_latest.get("scorecard"), dict) else {}).get("degraded_jobs")):
        if not isinstance(row, dict):
            continue
        model = row.get("model") if isinstance(row.get("model"), dict) else {}
        model_policy = model.get("policy") if isinstance(model.get("policy"), dict) else {}
        if not model_policy and isinstance(model.get("gate"), dict):
            model_policy = model.get("gate", {}).get("policy") if isinstance(model.get("gate", {}).get("policy"), dict) else {}
        degraded_jobs.append({
            "job": row.get("job"),
            "status": row.get("status"),
            "policy_decision": model_policy.get("decision"),
            "primary_reason": model_policy.get("primary_reason"),
            "model_used": model.get("used"),
            "fallback_used": model.get("fallback_used"),
        })
    decision = str(policy_latest.get("decision") or "unknown")
    current_status = "current" if decision in {"degraded", "fallback", "blocked"} else "historical_not_current" if degraded_jobs else "none"
    return {
        "schema": f"{SCHEMA_PREFIX}_runtime_degradation_context_v1",
        "current_status": current_status,
        "current_policy": {
            "decision": decision,
            "primary_reason": policy_latest.get("primary_reason"),
            "generated_at": policy_latest.get("generated_at"),
            "request": policy_latest.get("request") if isinstance(policy_latest.get("request"), dict) else {},
            "warnings": list_value(policy_latest.get("warnings"))[:8],
