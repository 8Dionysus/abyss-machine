            "memory_class": (((((policy_latest.get("inputs") or {}) if isinstance(policy_latest.get("inputs"), dict) else {}).get("memory") or {}) if isinstance(((policy_latest.get("inputs") or {}) if isinstance(policy_latest.get("inputs"), dict) else {}).get("memory"), dict) else {}).get("summary") or {}).get("class") if isinstance(((((policy_latest.get("inputs") or {}) if isinstance(policy_latest.get("inputs"), dict) else {}).get("memory") or {}) if isinstance(((policy_latest.get("inputs") or {}) if isinstance(policy_latest.get("inputs"), dict) else {}).get("memory"), dict) else {}).get("summary"), dict) else None,
            "active_game_processes": (((((policy_latest.get("inputs") or {}) if isinstance(policy_latest.get("inputs"), dict) else {}).get("game_guard") or {}) if isinstance(((policy_latest.get("inputs") or {}) if isinstance(policy_latest.get("inputs"), dict) else {}).get("game_guard"), dict) else {}).get("summary") or {}).get("active_game_processes") if isinstance(((((policy_latest.get("inputs") or {}) if isinstance(policy_latest.get("inputs"), dict) else {}).get("game_guard") or {}) if isinstance(((policy_latest.get("inputs") or {}) if isinstance(policy_latest.get("inputs"), dict) else {}).get("game_guard"), dict) else {}).get("summary"), dict) else None,
        },
        "historical_degraded_jobs": degraded_jobs[:12],
        "historical_degraded_count": len(degraded_jobs),
    }


def build_pack_from_resident(resident: dict[str, Any], evals_latest: dict[str, Any], policy_latest: dict[str, Any], limit: int = 24) -> dict[str, Any]:
    candidates = [item for item in list_value(resident.get("candidates")) if isinstance(item, dict)]
    queues = resident.get("queues") if isinstance(resident.get("queues"), dict) else {}
    selected_for_e4b = [item for item in list_value(queues.get("selected_for_e4b_review")) if isinstance(item, dict)]
    candidate_pool = selected_for_e4b if selected_for_e4b else candidates
    rejected_candidates = []
    rejected_ids: set[int] = set()
    for candidate in candidate_pool:
        reasons = candidate_rejection_reasons(candidate, candidate_source_ids(candidate), candidate.get("payload") if isinstance(candidate.get("payload"), dict) else {})
        if reasons:
            rejected_ids.add(id(candidate))
            rejected_candidates.append(compact_rejected_candidate(candidate, reasons))
    if selected_for_e4b:
        preferred = [item for item in candidate_pool if id(item) not in rejected_ids]
    else:
        preferred = sorted([item for item in candidate_pool if id(item) not in rejected_ids], key=candidate_review_sort_key, reverse=True)
    items = [candidate_record(item) for item in preferred[: max(1, min(limit, 128))]]
    scorecard = evals_latest.get("scorecard") if isinstance(evals_latest.get("scorecard"), dict) else {}
    hollow_candidates = [item for item in list_value(scorecard.get("hollow_candidates")) if isinstance(item, dict)]
    eval_rejected_candidates = [item for item in list_value(scorecard.get("rejected_candidates")) if isinstance(item, dict)]
    action_candidates = [
        item
        for item in items
        if item.get("kind") == "action_card"
        or item.get("route") in {"operator_confirm", "operator_review", "operator_needed", "blocked_by_policy", "human_review"}
        or item.get("review_required") is True
    ]
    risk_candidates = [item for item in items if item.get("risk") not in {"", "none", "low"}]
    source_ids = sorted({str(source_id) for item in items for source_id in list_value(item.get("source_ids")) if source_id})
    degradation = runtime_degradation_context(evals_latest, policy_latest)
    uncertainty_notes = sorted({str(note) for item in items for note in list_value(item.get("uncertainty_notes")) if note})
    selected_items = [item for item in items if item.get("selection_tier") in {"operator_attention", "e4b_review", "heartbeat_watch"}]
    selection_tiers = sorted({str(item.get("selection_tier")) for item in items if item.get("selection_tier")})
    selection_lanes = sorted({str(item.get("selection_lane")) for item in items if item.get("selection_lane")})
    resident_prefix = resident.get("prefix_pack") if isinstance(resident.get("prefix_pack"), dict) else {}
    prefix_pack = gemma_prefix_pack_contract(
        consumer=PROFILE,
        producer="e2b_candidate_readmodel_v2_for_e4b_review",
        resident_prefix=resident_prefix,
    )
    handoff_contract = gemma_handoff_contract(prefix_pack)
    prompt_pack = gemma_prompt_pack_contract(prefix_pack, handoff_contract)
    data = {
        "schema": f"{SCHEMA_PREFIX}_e4b_review_pack_v2",
        "compatibility_schema": f"{SCHEMA_PREFIX}_evidence_pack_v1",
        "version": VERSION,
        "generated_at": now_iso(),
        "ok": True,
        "profile": PROFILE,
        "mode": "e2b_candidate_readmodel_v2_for_e4b_review",
        "pack_id": stable_id("e4b-pack", {"source": str(RESIDENT_CANDIDATES_LATEST), "items": items, "degradation": degradation, "prefix_pack_id": prefix_pack.get("contract_id"), "handoff_id": handoff_contract.get("handoff_id")}),
        "raw_private_content": False,
        "action_execution": False,
        "prefix_pack": prefix_pack,
        "handoff_contract": handoff_contract,
        "prompt_pack": prompt_pack,
        "source": {
            "resident_candidates_latest": str(RESIDENT_CANDIDATES_LATEST),
            "resident_candidates_generated_at": resident.get("generated_at"),
            "resident_summary": resident.get("summary"),
            "resident_selection": resident.get("selection") if isinstance(resident.get("selection"), dict) else {},
            "resident_prefix_pack_id": resident_prefix.get("contract_id") if isinstance(resident_prefix, dict) else None,
            "resident_selected_for_e4b_review": len(selected_for_e4b),
            "resident_evals_latest": str(RESIDENT_EVALS_LATEST),
            "resident_evals_generated_at": evals_latest.get("generated_at"),
            "resident_policy_latest": str(RESIDENT_POLICY_LATEST),
            "resident_policy_generated_at": policy_latest.get("generated_at"),
        },
        "summary": {
            "items": len(items),
            "source_ids": len(source_ids),
            "source_excerpts": sum(len(list_value(item.get("source_excerpts"))) for item in items),
            "action_candidates": len(action_candidates),
            "risk_candidates": len(risk_candidates),
            "model_input_candidates": sum(1 for item in items if item.get("route") == "model_input_candidate"),
            "review_required": sum(1 for item in items if item.get("review_required")),
            "e4b_review_eligible": sum(1 for item in items if item.get("e4b_review_eligible")),
            "selected_candidates": len(selected_items),
            "selection_tiers": selection_tiers,
            "selection_lanes": selection_lanes,
            "uncertainty_notes": len(uncertainty_notes),
            "rejected_candidates": len(rejected_candidates) + len(eval_rejected_candidates),
            "hollow_candidates": len(hollow_candidates),
            "runtime_degradation_status": degradation.get("current_status"),
            "historical_degraded_jobs": degradation.get("historical_degraded_count"),
            "prefix_pack_contract": prefix_pack.get("contract_id"),
            "handoff_contract": handoff_contract.get("handoff_id"),
            "prompt_pack_contract": prompt_pack.get("prompt_pack_id"),
        },
        "allowed_source_ids": source_ids,
        "evidence_items": items,
        "rejected_candidates": rejected_candidates[:16],
        "eval_rejected_candidates": eval_rejected_candidates[:16],
        "hollow_candidates": hollow_candidates[:16],
        "runtime_degradation_context": degradation,
        "pack_guidance": {
            "e4b_expected_decisions": ["keep", "drop", "escalate"],
            "requires_missing_evidence_if_drop": True,
            "requires_safe_next_check": True,
            "derived_candidate_not_truth": True,
            "prefer_selection_score_before_utility_score": True,
        },
        "policy": {
            "for_model_input": True,
            "derived_candidate_not_truth": True,
            "e4b_may_review_only": True,
            "e4b_may_not_execute": True,
            "selection_score_is_routing_hint": True,
            "missing_source_ids_in_output_is_invalid": True,
        },
        "paths": paths_payload()["latest"],
        "non_claims": [
            "This pack is derived from E2B candidate artifacts; canonical evidence remains in source artifacts.",
            "This pack does not authorize action execution, memory writes, service control, or stack mutation.",
            "E4B review may keep, drop, or escalate candidates only; it is not a final executor or safety gate.",
        ],
    }
    return data


def build_pack(limit: int = 24, refresh_candidates: bool = False, write_latest: bool = True) -> dict[str, Any]:
    if refresh_candidates or not RESIDENT_CANDIDATES_LATEST.exists():
        run_json(["abyss-machine", "ai", "llm", "resident", "candidates", "--limit", str(max(1, min(limit, 128))), "--json"], timeout=90.0)
    resident = load_json(RESIDENT_CANDIDATES_LATEST)
    evals_latest = load_json(RESIDENT_EVALS_LATEST)
    policy_latest = load_json(RESIDENT_POLICY_LATEST)
    data = build_pack_from_resident(resident, evals_latest, policy_latest, limit=limit)
    if write_latest:
        write_json(PACK_LATEST, data)
        append_jsonl(daily_path(ROOT / "packs" / "jsonl"), data)
    return data


def pack_checks(pack: dict[str, Any]) -> list[dict[str, Any]]:
    checks: list[dict[str, Any]] = []

    def add(level: str, key: str, message: str, details: Any = None) -> None:
        item = {"level": level, "key": key, "message": message}
        if details is not None:
            item["details"] = details
        checks.append(item)

    add("ok" if pack else "fail", "pack_exists", "E4B evidence pack exists", {"path": str(PACK_LATEST)})
    if not pack:
        return checks
    add("ok" if pack.get("schema") == f"{SCHEMA_PREFIX}_e4b_review_pack_v2" else "fail", "pack_schema", "E4B review pack schema is current", {"schema": pack.get("schema")})
    prefix_pack = pack.get("prefix_pack") if isinstance(pack.get("prefix_pack"), dict) else {}
    prefix_policies = prefix_pack.get("policies") if isinstance(prefix_pack.get("policies"), dict) else {}
    handoff_contract = pack.get("handoff_contract") if isinstance(pack.get("handoff_contract"), dict) else {}
    handoff_policies = handoff_contract.get("policies") if isinstance(handoff_contract.get("policies"), dict) else {}
    prompt_pack = pack.get("prompt_pack") if isinstance(pack.get("prompt_pack"), dict) else {}
    prompt_policies = prompt_pack.get("policies") if isinstance(prompt_pack.get("policies"), dict) else {}
    add(
        "ok" if prefix_pack.get("schema") == "abyss_machine_gemma4_prefix_pack_contract_v1" and prefix_pack.get("stable_prefix_first") is True and prefix_pack.get("changing_task_suffix") is True else "fail",
        "prefix_pack_contract",
        "pack exposes stable-prefix/changing-suffix prompt contract",
        {"contract_id": prefix_pack.get("contract_id"), "schema": prefix_pack.get("schema")},
    )
    add(
        "fail" if prefix_policies.get("action_execution") is not False or prefix_policies.get("resident_service") is not False or prefix_policies.get("starts_llama_server") is not False or prefix_policies.get("stack_mutation") is not False else "ok",
        "prefix_pack_non_executing",
        "prefix-pack contract cannot authorize execution, serving, or stack mutation",
        {"policies": prefix_policies},
    )
    add(
        "ok" if handoff_contract.get("schema") == "abyss_machine_gemma4_e2b_e4b_handoff_contract_v1" and set(list_value(handoff_contract.get("expected_decisions"))) >= {"keep", "drop", "escalate"} else "fail",
        "handoff_contract",
        "pack exposes the E2B-to-E4B keep/drop/escalate handoff contract",
        {"handoff_id": handoff_contract.get("handoff_id"), "schema": handoff_contract.get("schema")},
    )
    add(
        "fail" if handoff_policies.get("default_model_execution") is not False or handoff_policies.get("resident_service") is not False or handoff_policies.get("starts_llama_server") is not False or handoff_policies.get("action_execution") is not False else "ok",
        "handoff_non_executing",
        "handoff contract keeps E4B on-demand and non-executing",
        {"policies": handoff_policies},
    )
    add(
        "ok" if prompt_pack.get("schema") == "abyss_machine_gemma4_prompt_pack_contract_v1" and prompt_pack.get("prefix_pack_id") == prefix_pack.get("contract_id") and prompt_pack.get("handoff_id") == handoff_contract.get("handoff_id") else "fail",
        "prompt_pack_contract",
        "prompt pack ties the stable prefix to the E2B-to-E4B handoff",
        {"prompt_pack_id": prompt_pack.get("prompt_pack_id"), "schema": prompt_pack.get("schema")},
    )
    add(
        "fail" if prompt_policies.get("action_execution") is not False or prompt_policies.get("service_control") is not False or prompt_policies.get("raw_private_content") is not False else "ok",
        "prompt_pack_non_executing",
        "prompt-pack contract stays compact and non-executing",
        {"policies": prompt_policies},
    )
    items = [item for item in list_value(pack.get("evidence_items")) if isinstance(item, dict)]
    add("ok" if items else "warn", "evidence_items", "evidence pack has bounded candidate items", {"count": len(items)})
    bad_identity = [item for item in items if not item.get("candidate_id") or not list_value(item.get("source_ids")) or not item.get("source_job")]
    add("fail" if bad_identity else "ok", "candidate_identity", "pack items keep candidate/source identity", {"bad": bad_identity[:5]})
    missing_excerpts = [item for item in items if not list_value(item.get("source_excerpts"))]
    add("fail" if missing_excerpts else "ok", "source_excerpts", "pack items include bounded source excerpts", {"bad": missing_excerpts[:5]})
    missing_uncertainty = [item for item in items if not list_value(item.get("uncertainty_notes"))]
    add("fail" if missing_uncertainty else "ok", "uncertainty_notes", "pack items preserve uncertainty notes", {"bad": missing_uncertainty[:5]})
    missing_selection = [
        item
        for item in items
        if not isinstance(item.get("selection_score"), (int, float))
        or item.get("selection_tier") not in set(SELECTION_TIER_PRIORITY.keys())
        or not str(item.get("selection_lane") or "")
        or not list_value(item.get("selection_reasons"))
    ]
    add("fail" if missing_selection else "ok", "selection_fields", "pack items preserve E2B selection score/tier/reasons", {"bad": missing_selection[:5]})
    selected_items = [item for item in items if item.get("selection_tier") in {"operator_attention", "e4b_review", "heartbeat_watch"}]
    add("ok" if selected_items or not items else "warn", "selected_candidates", "pack is ordered by selected E2B review material", {"selected": len(selected_items), "items": len(items)})
    executors = [item for item in items if item.get("action_execution") is not False]
    add("fail" if executors else "ok", "no_action_execution", "pack cannot mark items executable", {"bad": executors[:5]})
    source_ids = list_value(pack.get("allowed_source_ids"))
    add("ok" if source_ids or not items else "fail", "allowed_source_ids", "non-empty packs expose allowed source IDs", {"count": len(source_ids)})
    add("ok" if isinstance(pack.get("runtime_degradation_context"), dict) else "fail", "runtime_degradation_context", "pack includes current-vs-historical runtime degradation context")
    add("ok" if isinstance(pack.get("rejected_candidates"), list) and isinstance(pack.get("hollow_candidates"), list) else "fail", "weak_candidate_surfaces", "pack exposes rejected and hollow candidate surfaces")
    guidance = pack.get("pack_guidance") if isinstance(pack.get("pack_guidance"), dict) else {}
    add("ok" if set(list_value(guidance.get("e4b_expected_decisions"))) >= {"keep", "drop", "escalate"} else "fail", "decision_contract", "pack asks E4B for keep/drop/escalate review decisions", {"guidance": guidance})
    if pack.get("raw_private_content") is not False:
        add("fail", "raw_private_content", "pack must not claim raw private content")
    else:
        add("ok", "raw_private_content", "pack is compact derived content")
    return checks


def deterministic_review(pack: dict[str, Any], reason: str = "deterministic_contract_review") -> dict[str, Any]:
    items = [item for item in list_value(pack.get("evidence_items")) if isinstance(item, dict)]
    def item_source_ids(item: dict[str, Any]) -> list[str]:
        values = [str(value) for value in list_value(item.get("source_ids")) if value]
        if not values and item.get("source_id"):
            values = [str(item.get("source_id"))]
        return values
    source_ids = sorted({source_id for item in items for source_id in item_source_ids(item) if source_id})
    action_items = [
        item
        for item in items
        if item.get("kind") == "action_card"
        or item.get("review_required") is True
        or item.get("route") in {"operator_confirm", "operator_review", "operator_needed", "blocked_by_policy", "human_review"}
    ]
    risk_items = [item for item in items if item.get("risk") not in {"", "none", "low"}]
    rejected = [item for item in list_value(pack.get("rejected_candidates")) if isinstance(item, dict)]
    judgements = []
    for item in items[:12]:
        decision = "escalate" if item in action_items or item in risk_items else "keep"
        judgements.append({
            "source_ids": item_source_ids(item)[:6],
            "candidate_id": str(item.get("candidate_id")),
            "decision": decision,
            "reason": compact_text("; ".join(str(note) for note in list_value(item.get("uncertainty_notes"))) or item.get("text") or item.get("title"), 260),
            "safe_next_check": "operator_review" if decision == "escalate" else "preserve_as_candidate_evidence",
        })
    for item in rejected[:4]:
        judgements.append({
            "source_ids": list_value(item.get("source_ids"))[:6],
            "candidate_id": str(item.get("candidate_id")),
            "decision": "drop",
            "reason": compact_text("; ".join(str(reason) for reason in list_value(item.get("rejection_reasons"))), 260),
            "safe_next_check": "wait_for_sourceful_fresh_candidate",
        })
    review_items = [
        {
            "source_id": str(item.get("source_id")),
            "candidate_id": str(item.get("candidate_id")),
            "decision": "route_to_operator" if item in action_items or item in risk_items else "review_candidate",
            "reason": compact_text(item.get("text") or item.get("title"), 220),
        }
        for item in items[:8]
    ]
    action_cards = [
        {
            "source_id": str(item.get("source_id")),
            "candidate_id": str(item.get("candidate_id")),
            "intent": compact_text(item.get("text"), 260),
            "risk": item.get("risk") or "low",
            "confirm_required": True,
            "route": "operator_review",
            "blocked_actions": ["direct_execution", "service_mutation_without_operator"],
        }
        for item in action_items[:6]
    ]
    return {
        "verdict": "candidate_review_ready" if items else "blocked_no_evidence",
        "summary": f"{reason}; items={len(items)}; action_candidates={len(action_items)}; risk_candidates={len(risk_items)}",
        "operator_summary": f"{len(items)} E2B candidates packed for E4B review; {len(action_items)} need operator-facing review; {len(rejected)} weak candidates are dropped or held.",
        "source_ids": source_ids,
        "candidate_judgements": judgements,
        "review_items": review_items,
        "action_cards": action_cards,
        "risk_routes": [
            {
                "source_id": str(item.get("source_id")),
                "risk": item.get("risk") or "low",
                "route": "operator_review",
                "reason": compact_text(item.get("text"), 220),
            }
            for item in risk_items[:8]
        ],
        "missing_evidence": [] if items else ["evidence_items"],
        "safe_next_checks": ["preserve_source_ids", "operator_confirms_before_action"] if items else ["refresh_e2b_candidates"],
        "next_queries": [],
        "confidence": "medium" if items else "low",
        "action_execution": False,
    }


