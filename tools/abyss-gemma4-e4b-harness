def extract_json_object(text: str) -> dict[str, Any] | None:
    decoder = json.JSONDecoder()
    best: tuple[int, dict[str, Any]] | None = None
    for index, char in enumerate(text):
        if char != "{":
            continue
        try:
            value, end = decoder.raw_decode(text[index:])
        except json.JSONDecodeError:
            continue
        if isinstance(value, dict) and (best is None or end > best[0]):
            best = (end, value)
        if isinstance(value, dict) and {"verdict", "source_ids", "action_execution"}.issubset(value):
            return value
    return best[1] if best else None


def normalize_review(parsed: dict[str, Any] | None, pack: dict[str, Any]) -> tuple[bool, dict[str, Any]]:
    if not isinstance(parsed, dict):
        return False, deterministic_review(pack, reason="model_parse_failed")
    if not {"verdict", "source_ids", "action_execution"}.issubset(parsed):
        return False, deterministic_review(pack, reason="model_root_contract_missing")
    allowed = set(str(item) for item in list_value(pack.get("allowed_source_ids")) if item)
    result = deterministic_review(pack, reason="model_review_normalization_seed")
    result["verdict"] = str(parsed.get("verdict") or result["verdict"])[:80]
    result["summary"] = compact_text(parsed.get("summary") or result["summary"], 500)
    result["operator_summary"] = compact_text(parsed.get("operator_summary") or result.get("operator_summary"), 500)
    result["source_ids"] = [sid for sid in [str(item) for item in list_value(parsed.get("source_ids"))] if sid in allowed]
    result["candidate_judgements"] = []
    for item in list_value(parsed.get("candidate_judgements"))[:12]:
        if not isinstance(item, dict):
            continue
        ids = [sid for sid in [str(value) for value in list_value(item.get("source_ids"))] if sid in allowed]
        if not ids:
            continue
        decision = str(item.get("decision") or "keep")[:40]
        if decision not in {"keep", "drop", "escalate"}:
            decision = "escalate"
        result["candidate_judgements"].append({
            "source_ids": ids[:6],
            "candidate_id": str(item.get("candidate_id") or "")[:120],
            "decision": decision,
            "reason": compact_text(item.get("reason"), 260),
            "safe_next_check": compact_text(item.get("safe_next_check"), 220),
        })
    result["review_items"] = []
    for item in list_value(parsed.get("review_items"))[:8]:
        if not isinstance(item, dict):
            continue
        sid = str(item.get("source_id") or "")
        if sid in allowed:
            result["review_items"].append({
                "source_id": sid,
                "candidate_id": str(item.get("candidate_id") or "")[:120],
                "decision": str(item.get("decision") or "review_candidate")[:80],
                "reason": compact_text(item.get("reason"), 260),
            })
    result["action_cards"] = []
    for item in list_value(parsed.get("action_cards"))[:6]:
        if not isinstance(item, dict):
            continue
        sid = str(item.get("source_id") or "")
        if sid in allowed:
            result["action_cards"].append({
                "source_id": sid,
                "candidate_id": str(item.get("candidate_id") or "")[:120],
                "intent": compact_text(item.get("intent"), 260),
                "risk": str(item.get("risk") or "low")[:80],
                "confirm_required": True,
                "route": str(item.get("route") or "operator_review")[:120],
                "blocked_actions": [str(value)[:120] for value in list_value(item.get("blocked_actions"))[:8]] or ["direct_execution"],
            })
    result["risk_routes"] = []
    for item in list_value(parsed.get("risk_routes"))[:8]:
        if not isinstance(item, dict):
            continue
        sid = str(item.get("source_id") or "")
        if sid in allowed:
            result["risk_routes"].append({
                "source_id": sid,
                "risk": str(item.get("risk") or "low")[:80],
                "route": str(item.get("route") or "operator_review")[:120],
                "reason": compact_text(item.get("reason"), 260),
            })
    result["missing_evidence"] = [str(item)[:120] for item in list_value(parsed.get("missing_evidence"))[:12]]
    result["safe_next_checks"] = [compact_text(item, 220) for item in list_value(parsed.get("safe_next_checks"))[:8]]
    result["next_queries"] = [compact_text(item, 220) for item in list_value(parsed.get("next_queries"))[:8]]
    result["confidence"] = str(parsed.get("confidence") or result["confidence"])[:40]
    result["action_execution"] = False
    return True, result


def review_checks(review_result: dict[str, Any], pack: dict[str, Any]) -> list[dict[str, Any]]:
    checks: list[dict[str, Any]] = []

    def add(level: str, key: str, message: str, details: Any = None) -> None:
        item = {"level": level, "key": key, "message": message}
        if details is not None:
            item["details"] = details
        checks.append(item)

    items = [item for item in list_value(pack.get("evidence_items")) if isinstance(item, dict)]
    allowed = {str(item) for item in list_value(pack.get("allowed_source_ids")) if item}
    action_candidates = int((pack.get("summary") or {}).get("action_candidates") or 0) if isinstance(pack.get("summary"), dict) else 0
    source_ids = [str(item) for item in list_value(review_result.get("source_ids")) if item]
    bad_source_ids = [sid for sid in source_ids if sid not in allowed]
    add("ok" if review_result else "fail", "review_result_exists", "review result exists")
    add("fail" if review_result.get("action_execution") is not False else "ok", "no_action_execution", "review never marks action_execution true", {"value": review_result.get("action_execution")})
    add("fail" if items and not source_ids else "ok", "source_ids_required", "non-empty evidence requires source_ids in output", {"source_ids": source_ids[:12]})
    add("fail" if bad_source_ids else "ok", "source_ids_allowed", "output source IDs must come from pack", {"bad": bad_source_ids[:12]})
    review_items = [item for item in list_value(review_result.get("review_items")) if isinstance(item, dict)]
    bad_review_items = [item for item in review_items if str(item.get("source_id") or "") not in allowed]
    add("fail" if bad_review_items else "ok", "review_items_sourceful", "review items preserve allowed source IDs", {"bad": bad_review_items[:5]})
    judgements = [item for item in list_value(review_result.get("candidate_judgements")) if isinstance(item, dict)]
    bad_judgements = [
        item
        for item in judgements
        if not set(str(value) for value in list_value(item.get("source_ids"))).issubset(allowed)
        or not list_value(item.get("source_ids"))
        or item.get("decision") not in {"keep", "drop", "escalate"}
    ]
    add("fail" if items and not judgements else "ok", "candidate_judgements_required", "E4B handoff returns keep/drop/escalate candidate judgements", {"count": len(judgements)})
    add("fail" if bad_judgements else "ok", "candidate_judgements_sourceful", "candidate judgements keep allowed source IDs and expected decisions", {"bad": bad_judgements[:5]})
    add("fail" if items and not compact_text(review_result.get("operator_summary")) else "ok", "operator_summary", "review includes an operator-facing summary")
    unsafe_next_checks = [
        item for item in list_value(review_result.get("safe_next_checks"))
        if any(word in str(item).lower() for word in ("execute", "restart", "delete", "write", "mutate"))
    ]
    add("fail" if unsafe_next_checks else "ok", "safe_next_checks_non_executing", "safe next checks stay non-executing", {"bad": unsafe_next_checks[:5]})
    action_cards = [item for item in list_value(review_result.get("action_cards")) if isinstance(item, dict)]
    hollow_action = action_candidates > 0 and not action_cards and str(review_result.get("verdict") or "").lower() not in {"blocked_no_evidence", "needs_more_evidence", "blocked_by_policy"}
    add("fail" if hollow_action else "ok", "no_hollow_action_card", "action/review candidates cannot yield a safe-shaped empty action card", {"action_candidates": action_candidates, "cards": len(action_cards), "verdict": review_result.get("verdict")})
    unsafe_cards = [
        item
        for item in action_cards
        if str(item.get("source_id") or "") not in allowed
        or item.get("confirm_required") is not True
        or not list_value(item.get("blocked_actions"))
        or item.get("route") in {"direct", "execute", "e2b_ok"}
    ]
    add("fail" if unsafe_cards else "ok", "action_cards_guarded", "action cards require source, confirmation, blocked actions, and non-execution route", {"bad": unsafe_cards[:5]})
    return checks


def run_llama_completion(pack: dict[str, Any], n_predict: int, timeout: float) -> tuple[dict[str, Any], dict[str, Any] | None]:
    pf = preflight(write_latest=True)
    if not pf.get("ok"):
        return {"ok": False, "blocked": True, "preflight": pf, "_content": ""}, None
    registry, profile = registry_profile()
    completion_path = llama_completion_path(profile)
    model_path = str(profile.get("local_path") or "")
    context_size = profile_context_size(profile)
    resource = pf.get("resource") if isinstance(pf.get("resource"), dict) else {}
    systemd = resource.get("systemd") if isinstance(resource.get("systemd"), dict) else {}
    env = os.environ.copy()
    for key, value in (systemd.get("env") or {}).items() if isinstance(systemd.get("env"), dict) else []:
        env[str(key)] = str(value)
    cpuset = (((systemd.get("properties") or {}).get("AllowedCPUs")) if isinstance(systemd.get("properties"), dict) else None) or "0-1,6-11,14-15"
    command = [
        "taskset",
        "-c",
        str(cpuset),
        str(completion_path),
        "-m",
        model_path,
        "-ngl",
        "99",
        "-c",
        str(context_size),
        "-n",
        str(max(128, min(n_predict, 1536))),
        "--temp",
        "0.1",
        "--top-p",
        "0.9",
        "--no-warmup",
        "--simple-io",
        "-no-cnv",
        "--no-display-prompt",
        "--reasoning",
        "off",
        "--reasoning-budget",
        "0",
        "--reasoning-format",
        "none",
        "-p",
        review_prompt(pack),
    ]
    started = time.time()
    completed = subprocess.run(command, text=True, capture_output=True, timeout=timeout, check=False, env=env)
    duration = round(time.time() - started, 3)
    output = {
        "ok": completed.returncode == 0,
        "returncode": completed.returncode,
        "duration_sec": duration,
        "command": command[:],
        "context_size": context_size,
        "stderr_tail": completed.stderr[-2000:],
        "_content": completed.stdout,
    }
    parsed = extract_json_object(completed.stdout)
    return output, parsed


def review_pack(limit: int = 24, refresh_candidates: bool = False, run_model: bool = False, n_predict: int = 768, timeout: float = 420.0, write_latest: bool = True) -> dict[str, Any]:
    pack = build_pack(limit=limit, refresh_candidates=refresh_candidates, write_latest=True)
    pack_validation = pack_checks(pack)
    pack_fails = [item for item in pack_validation if item.get("level") == "fail"]
    model: dict[str, Any]
    parsed_ok = False
    if pack_fails:
        result = deterministic_review(pack, reason="pack_validation_failed")
        model = {"used": False, "blocked": True, "reason": "pack_validation_failed"}
    elif run_model:
        model_out, parsed = run_llama_completion(pack, n_predict=n_predict, timeout=timeout)
        parsed_ok, result = normalize_review(parsed, pack)
        model = {
            "used": bool(model_out.get("ok")) and not model_out.get("blocked"),
            "parsed": parsed_ok,
            "blocked": model_out.get("blocked") is True,
            "returncode": model_out.get("returncode"),
            "duration_sec": model_out.get("duration_sec"),
            "context_size": model_out.get("context_size"),
            "stderr_tail": model_out.get("stderr_tail"),
            "raw_excerpt": compact_text(model_out.get("_content"), 1800),
            "preflight": model_out.get("preflight"),
        }
    else:
        result = deterministic_review(pack)
        model = {"used": False, "reason": "default_no_model_execution", "run_model_flag": "--run-model"}
    checks = pack_validation + review_checks(result, pack)
    fails = sum(1 for item in checks if item.get("level") == "fail")
    warnings = sum(1 for item in checks if item.get("level") == "warn")
    data = {
        "schema": f"{SCHEMA_PREFIX}_review_v1",
        "version": VERSION,
        "generated_at": now_iso(),
        "ok": fails == 0,
        "profile": PROFILE,
        "mode": "non_resident_workhorse_review",
        "review_id": stable_id("e4b-review", {"pack": pack.get("pack_id"), "result": result}),
        "pack": {"pack_id": pack.get("pack_id"), "path": str(PACK_LATEST), "summary": pack.get("summary")},
        "prefix_pack": pack.get("prefix_pack") if isinstance(pack.get("prefix_pack"), dict) else {},
        "handoff_contract": pack.get("handoff_contract") if isinstance(pack.get("handoff_contract"), dict) else {},
        "prompt_pack": pack.get("prompt_pack") if isinstance(pack.get("prompt_pack"), dict) else {},
        "result": result,
        "checks": checks,
        "summary": {"fails": fails, "warnings": warnings, "checks": len(checks), "model_used": model.get("used") is True, "parsed": parsed_ok},
        "model": model,
        "policy": {
            "resident_service": False,
            "starts_llama_server": False,
            "action_execution": False,
            "final_safety_gate": False,
            "requires_downstream_validator": True,
        },
        "paths": paths_payload()["latest"],
    }
    if write_latest:
        write_json(REVIEW_LATEST, data)
        append_jsonl(daily_path(ROOT / "reviews" / "jsonl"), data)
    return data


def validate(write_latest: bool = True) -> dict[str, Any]:
    pack = load_json(PACK_LATEST)
    review = load_json(REVIEW_LATEST)
    result = review.get("result") if isinstance(review.get("result"), dict) else {}
    checks = pack_checks(pack)
    checks.append({
        "level": "ok" if review else "warn",
        "key": "review_latest",
        "message": "latest workhorse review exists",
        "details": {"path": str(REVIEW_LATEST)},
    })
    if review:
        checks.extend(review_checks(result, pack))
        checks.append({
            "level": "fail" if ((review.get("policy") or {}).get("resident_service") is True) else "ok",
            "key": "not_resident_service",
            "message": "workhorse harness is not promoted as a resident service",
        })
        checks.append({
            "level": "fail" if ((review.get("policy") or {}).get("starts_llama_server") is True) else "ok",
            "key": "does_not_start_server",
            "message": "workhorse harness does not start llama-server",
        })
    fails = sum(1 for item in checks if item.get("level") == "fail")
    warnings = sum(1 for item in checks if item.get("level") == "warn")
    data = {
        "schema": f"{SCHEMA_PREFIX}_validate_v1",
        "version": VERSION,
        "generated_at": now_iso(),
        "ok": fails == 0,
        "profile": PROFILE,
        "checks": checks,
        "summary": {"fails": fails, "warnings": warnings, "checks": len(checks)},
        "paths": paths_payload()["latest"],
    }
    if write_latest:
        write_json(VALIDATE_LATEST, data)
    return data


