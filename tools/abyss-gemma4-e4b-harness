def print_json(payload: dict[str, Any]) -> None:
    print(json.dumps(payload, ensure_ascii=False, indent=2, sort_keys=True))


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Gemma4 E4B non-resident workhorse harness for Abyss Machine.")
    sub = parser.add_subparsers(dest="command", required=True)
    for name in ("paths", "preflight", "pack", "review", "validate", "self-test"):
        child = sub.add_parser(name)
        child.add_argument("--json", action="store_true", help="emit machine-readable JSON")
        if name in {"pack", "review"}:
            child.add_argument("--limit", type=int, default=24)
            child.add_argument("--refresh-candidates", action="store_true")
        if name == "review":
            child.add_argument("--run-model", action="store_true", help="execute E4B through llama-completion after resource preflight")
            child.add_argument("--n-predict", type=int, default=768)
            child.add_argument("--timeout", type=float, default=420.0)
    return parser


def main(argv: list[str] | None = None) -> int:
    args = build_parser().parse_args(argv)
    if args.command == "paths":
        data = paths_payload()
    elif args.command == "preflight":
        data = preflight()
    elif args.command == "pack":
        data = build_pack(limit=int(args.limit), refresh_candidates=bool(args.refresh_candidates))
    elif args.command == "review":
        data = review_pack(limit=int(args.limit), refresh_candidates=bool(args.refresh_candidates), run_model=bool(args.run_model), n_predict=int(args.n_predict), timeout=float(args.timeout))
    elif args.command == "validate":
        data = validate()
    elif args.command == "self-test":
        data = self_test()
    else:
        raise SystemExit(f"unknown command: {args.command}")
    if getattr(args, "json", False):
        print_json(data)
    else:
        print(f"{args.command}: ok={data.get('ok')} profile={data.get('profile', PROFILE)}")
    return 0 if data.get("ok", True) else 1


if __name__ == "__main__":
    raise SystemExit(main())
