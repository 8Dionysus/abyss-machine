{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/8Dionysus/abyss-machine/schemas/local-provenance-packet.schema.json",
  "title": "abyss-machine local provenance packet",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema",
    "schema_ref",
    "artifact_class",
    "surface_state",
    "owner_repo",
    "authority_ref",
    "producer",
    "producer_command",
    "source_refs",
    "activity",
    "agent_or_tool",
    "created_at",
    "contract_version",
    "privacy_boundary",
    "content_identity",
    "consumer_expectation",
    "verification",
    "promotion_status"
  ],
  "properties": {
    "schema": {
      "const": "abyss_machine_local_provenance_packet_v1"
    },
    "schema_ref": {
      "const": "schemas/local-provenance-packet.schema.json"
    },
    "artifact_class": {
      "const": "host_local_evidence"
    },
    "surface_state": {
      "const": "host_private_generated"
    },
    "owner_repo": {
      "const": "abyss-machine"
    },
    "authority_ref": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "producer": {
      "type": "string",
      "minLength": 1
    },
    "producer_command": {
      "type": "string",
      "minLength": 1
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "activity": {
      "type": "object",
      "additionalProperties": true
    },
    "agent_or_tool": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "contract_version": {
      "type": "string",
      "minLength": 1
    },
    "privacy_boundary": {
      "type": "string",
      "minLength": 1
    },
    "content_identity": {
      "type": "object",
      "additionalProperties": true,
      "anyOf": [
        {
          "required": ["path", "sha256"]
        },
        {
          "required": ["path", "tree_hash"]
        }
      ]
    },
    "consumer_expectation": {
      "type": "string",
      "minLength": 1
    },
    "verification": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "promotion_status": {
      "type": "string",
      "minLength": 1
    }
  }
}
