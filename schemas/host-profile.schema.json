{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/8Dionysus/abyss-machine/schemas/host-profile.schema.json",
  "title": "abyss-machine host profile",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "name": {
      "type": "string"
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "roots": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "profiles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
