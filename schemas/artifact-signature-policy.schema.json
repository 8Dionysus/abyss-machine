{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/8Dionysus/abyss-machine/schemas/artifact-signature-policy.schema.json",
  "title": "abyss-machine artifact signature policy",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema",
    "policy_version",
    "abi_signature",
    "identity_fields",
    "local_provenance_packet",
    "portable_runner_contract",
    "release_sidecar_expectations",
    "artifact_classes",
    "contract_surfaces",
    "release_artifact_rules",
    "deferred_trust_layers"
  ],
  "properties": {
    "schema": {
      "const": "abyss_machine_artifact_signature_policy_manifest_v1"
    },
    "policy_version": {
      "type": "string"
    },
    "abi_signature": {
      "type": "object",
      "additionalProperties": true,
      "required": ["algorithm", "generated_surface"],
      "properties": {
        "algorithm": {"const": "sha256-tree-v1"},
        "generated_surface": {"type": "string"}
      }
    },
    "identity_fields": {
      "type": "array",
      "items": {"type": "string"}
    },
    "local_provenance_packet": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "schema",
        "schema_ref",
        "applies_to_artifact_classes",
        "storage_route",
        "not_public_repo_content",
        "required_fields",
        "consumer_checks",
        "promotion_controls"
      ],
      "properties": {
        "schema": {"const": "abyss_machine_local_provenance_packet_v1"},
        "schema_ref": {"type": "string"},
        "applies_to_artifact_classes": {
          "type": "array",
          "items": {"type": "string"}
        },
        "storage_route": {"type": "string"},
        "not_public_repo_content": {"const": true},
        "required_fields": {
          "type": "array",
          "items": {"type": "string"}
        },
        "consumer_checks": {
          "type": "array",
          "items": {"type": "string"}
        },
        "promotion_controls": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "artifact_classes": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true,
        "required": ["description", "identity"],
        "properties": {
          "identity": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "artifact_class",
              "surface_state",
              "owner_repo",
              "authority_ref",
              "producer",
              "consumer_expectation",
              "privacy_boundary",
              "content_identity",
              "abi_epoch",
              "contract_version",
              "trust_layer",
              "verification",
              "action"
            ],
            "properties": {
              "authority_ref": {
                "type": "array",
                "items": {"type": "string"}
              },
              "trust_layer": {
                "type": "array",
                "items": {"type": "string"}
              },
              "verification": {
                "type": "array",
                "items": {"type": "string"}
              }
            }
          }
        }
      }
    },
    "portable_runner_contract": {
      "type": "object",
      "additionalProperties": true,
      "required": ["entrypoint_sources", "runner_contexts", "required_entrypoints"],
      "properties": {
        "entrypoint_sources": {
          "type": "array",
          "items": {"type": "string"}
        },
        "runner_contexts": {
          "type": "array",
          "items": {"type": "string"}
        },
        "required_entrypoints": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["id", "command"],
            "properties": {
              "id": {"type": "string"},
              "command": {
                "type": "array",
                "items": {"type": "string"}
              }
            }
          }
        }
      }
    },
    "release_sidecar_expectations": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true,
        "required": ["consumer_checks"],
        "properties": {
          "consumer_checks": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string"}
          }
        }
      }
    },
    "contract_surfaces": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "epoch", "artifact_class", "source_paths"],
        "properties": {
          "id": {"type": "string"},
          "epoch": {"type": "string"},
          "artifact_class": {"type": "string"},
          "source_paths": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      }
    },
    "release_artifact_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "artifact_class", "artifact_patterns", "public_repo_policy", "required_controls"],
        "properties": {
          "id": {"type": "string"},
          "artifact_class": {"type": "string"},
          "artifact_patterns": {
            "type": "array",
            "items": {"type": "string"}
          },
          "public_repo_policy": {"type": "string"},
          "required_controls": {
            "type": "array",
            "items": {"type": "string"}
          },
          "sidecar_extensions": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": {"type": "string"}
            }
          }
        }
      }
    },
    "deferred_trust_layers": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true,
        "required": ["trigger", "action", "reason"]
      }
    }
  }
}
